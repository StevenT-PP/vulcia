---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 mt-32">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">

      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center mb-4">
          <span style="font-family: 'Astron', sans-serif; font-size: 1.25rem; color: white; letter-spacing: 0.05em;">Vulcia</span>
        </a>
        <p class="text-[#8888aa] text-sm leading-relaxed max-w-xs">
          L'agence IA qui propulse votre avantage concurrentiel. Agents intelligents, SEO automatisé et sites haute performance.
        </p>
        <div class="flex items-center gap-4 mt-6">
          <a href="https://linkedin.com/company/vulcia" class="text-[#8888aa] hover:text-white transition-colors" aria-label="LinkedIn">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="https://twitter.com/vulcia" class="text-[#8888aa] hover:text-white transition-colors" aria-label="Twitter/X">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>

      <!-- Solutions -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Solutions</h3>
        <ul class="space-y-3">
          {[
            ['Agent IA sur-mesure', '/agent-ia'],
            ['Automatisation IA', '/automatisation-ia'],
            ['Création site web', '/creation-site-web'],
            ['Référencement SEO', '/referencement-seo'],
            ['IA pour médecins', '/ia-pour/medecins'],
            ['IA pour artisans', '/ia-pour/artisans'],
            ['Tous les secteurs', '/ia-pour'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="text-[#8888aa] hover:text-white text-sm transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Agence -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Agence</h3>
        <ul class="space-y-3">
          {[
            ['Offres & Tarifs', '/tarifs'],
            ['Calculateur ROI', '/calculateur-roi'],
            ['Blog IA & SEO', '/blog'],
            ['À propos', '/a-propos'],
            ['Audit IA gratuit', '/contact'],
            ['Mentions légales', '/mentions-legales'],
          ].map(([label, href]) => (
            <li>
              <a href={href} class="text-[#8888aa] hover:text-white text-sm transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-[#8888aa] text-xs">
        &copy; {year} Vulcia. Tous droits réservés. France.
      </p>
      <p class="text-[#8888aa] text-xs">
        Agents IA · SEO Automatisé · Sites Web · France entière
      </p>
    </div>
  </div>
</footer>
