---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Calculateur ROI Agent IA — Estimez vos gains en 2 minutes | Vulcia"
  description="Calculez en 2 minutes le ROI d'un agent IA pour votre entreprise. Économies de temps, CA additionnel, délai de retour sur investissement — estimations basées sur des données réelles."
>
  <Nav />

  <section class="pt-32 pb-24 px-6">
    <div class="max-w-4xl mx-auto">

      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#7c5cfc] mb-4">Outil gratuit</p>
        <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
          Calculez votre ROI<br/><span class="gradient-text">en 2 minutes</span>
        </h1>
        <p class="text-[#8888aa] text-lg max-w-2xl mx-auto">
          Entrez vos chiffres. On calcule ce qu'un agent IA vous rapporte — économies de temps, CA additionnel et délai de retour sur investissement.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <!-- FORMULAIRE -->
        <div class="glass rounded-2xl p-8 space-y-6">
          <h2 class="text-white font-black text-xl mb-6">Votre situation actuelle</h2>

          <div>
            <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Secteur d'activité</label>
            <select id="secteur" class="w-full px-4 py-3 rounded-xl text-white text-sm outline-none" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
              <option value="medical">Médical / Dentaire</option>
              <option value="restaurant">Restaurant / Hôtel</option>
              <option value="artisan">Artisan / BTP</option>
              <option value="juridique">Avocat / Comptable</option>
              <option value="ecommerce">E-commerce</option>
              <option value="immobilier">Immobilier</option>
              <option value="coach">Coach / Formateur</option>
              <option value="autre">Autre PME</option>
            </select>
          </div>

          <div>
            <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">
              Demandes clients par semaine <span id="demandes-val" class="text-[#7c5cfc]">80</span>
            </label>
            <input type="range" id="demandes" min="10" max="500" value="80" step="5"
              class="w-full h-1.5 rounded-full appearance-none cursor-pointer" style="accent-color: #7c5cfc;" />
            <div class="flex justify-between text-xs text-[#8888aa] mt-1">
              <span>10</span><span>500</span>
            </div>
          </div>

          <div>
            <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">
              Temps de traitement moyen par demande <span id="temps-val" class="text-[#7c5cfc]">8 min</span>
            </label>
            <input type="range" id="temps" min="2" max="30" value="8" step="1"
              class="w-full h-1.5 rounded-full appearance-none cursor-pointer" style="accent-color: #7c5cfc;" />
            <div class="flex justify-between text-xs text-[#8888aa] mt-1">
              <span>2 min</span><span>30 min</span>
            </div>
          </div>

          <div>
            <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">
              Coût horaire de votre temps (ou celui de votre équipe)
            </label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[#8888aa] text-sm">€</span>
              <input type="number" id="cout-horaire" value="40" min="15" max="200" step="5"
                class="w-full pl-8 pr-4 py-3 rounded-xl text-white text-sm outline-none" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);" />
            </div>
            <p class="text-xs text-[#8888aa] mt-1">Votre taux horaire ou celui du collaborateur qui gère les demandes</p>
          </div>

          <div>
            <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">
              % de demandes non traitées (leads perdus) <span id="perte-val" class="text-[#7c5cfc]">20%</span>
            </label>
            <input type="range" id="perte" min="0" max="60" value="20" step="5"
              class="w-full h-1.5 rounded-full appearance-none cursor-pointer" style="accent-color: #7c5cfc;" />
            <div class="flex justify-between text-xs text-[#8888aa] mt-1">
              <span>0%</span><span>60%</span>
            </div>
          </div>

          <div>
            <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">
              Valeur moyenne d'un client (€)
            </label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[#8888aa] text-sm">€</span>
              <input type="number" id="valeur-client" value="300" min="20" max="10000" step="10"
                class="w-full pl-8 pr-4 py-3 rounded-xl text-white text-sm outline-none" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);" />
            </div>
          </div>

        </div>

        <!-- RÉSULTATS -->
        <div class="space-y-4">

          <div class="glass rounded-2xl p-6" style="border: 1px solid rgba(124,92,252,0.3);">
            <p class="text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-4">Votre situation actuelle</p>
            <div class="space-y-3">
              <div class="flex justify-between items-center">
                <span class="text-[#8888aa] text-sm">Temps passé/semaine sur les demandes</span>
                <span id="r-temps-actuel" class="text-white font-bold text-sm">—</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-[#8888aa] text-sm">Coût mensuel de ce temps</span>
                <span id="r-cout-actuel" class="text-white font-bold text-sm">—</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-[#8888aa] text-sm">CA perdu / mois (leads non traités)</span>
                <span id="r-ca-perdu" class="text-red-400 font-bold text-sm">—</span>
              </div>
            </div>
          </div>

          <div class="glass rounded-2xl p-6" style="border: 1px solid rgba(52,211,153,0.3);">
            <p class="text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-4">Avec un agent IA Vulcia</p>
            <div class="space-y-3">
              <div class="flex justify-between items-center">
                <span class="text-[#8888aa] text-sm">Temps économisé/semaine</span>
                <span id="r-temps-eco" class="text-green-400 font-bold text-sm">—</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-[#8888aa] text-sm">CA additionnel récupéré/mois</span>
                <span id="r-ca-add" class="text-green-400 font-bold text-sm">—</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-[#8888aa] text-sm">Pack recommandé</span>
                <span id="r-pack" class="text-[#7c5cfc] font-bold text-sm">—</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-[#8888aa] text-sm">Coût mensuel Vulcia</span>
                <span id="r-cout-ia" class="text-white font-bold text-sm">—</span>
              </div>
            </div>
          </div>

          <div class="rounded-2xl p-6 text-center" style="background: linear-gradient(135deg, rgba(124,92,252,0.15), rgba(56,189,248,0.1)); border: 1px solid rgba(124,92,252,0.3);">
            <p class="text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">ROI mensuel net estimé</p>
            <div id="r-roi" class="text-5xl font-black text-white mb-2">—</div>
            <p id="r-delai" class="text-[#8888aa] text-sm">—</p>
          </div>

          <div id="r-mention" class="glass rounded-xl p-4">
            <p class="text-[#8888aa] text-xs leading-relaxed">* Estimations basées sur des moyennes observées chez nos clients. Vos résultats réels dépendent de votre secteur, de vos processus et du volume de demandes. L'audit gratuit affine ces projections pour votre situation précise.</p>
          </div>

          <a href="/contact" class="block w-full py-4 rounded-xl text-white font-bold text-center transition-all hover:opacity-90" style="background: linear-gradient(135deg, #7c5cfc, #5b3fdb); box-shadow: 0 0 30px rgba(124,92,252,0.3);">
            Valider ces chiffres avec un audit gratuit &rarr;
          </a>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
const packs = [
  { name: "Pack Solo", price: 149 },
  { name: "Pack Essentiel", price: 349 },
  { name: "Pack Croissance", price: 790 },
  { name: "Pack Pro", price: 1490 },
];

function getPackRecommande(demandesSemaine: number): { name: string; price: number } {
  if (demandesSemaine <= 30) return packs[0];
  if (demandesSemaine <= 100) return packs[1];
  if (demandesSemaine <= 250) return packs[2];
  return packs[3];
}

function fmt(n: number): string {
  return n.toLocaleString('fr-FR', { maximumFractionDigits: 0 }) + ' €';
}

function calc() {
  const demandes = Number((document.getElementById('demandes') as HTMLInputElement).value);
  const tempsMin = Number((document.getElementById('temps') as HTMLInputElement).value);
  const coutH = Number((document.getElementById('cout-horaire') as HTMLInputElement).value);
  const pertePct = Number((document.getElementById('perte') as HTMLInputElement).value) / 100;
  const valeurClient = Number((document.getElementById('valeur-client') as HTMLInputElement).value);

  (document.getElementById('demandes-val') as HTMLElement).textContent = String(demandes);
  (document.getElementById('temps-val') as HTMLElement).textContent = tempsMin + ' min';
  (document.getElementById('perte-val') as HTMLElement).textContent = Math.round(pertePct * 100) + '%';

  const tempsHSemaine = (demandes * tempsMin) / 60;
  const tempsHMois = tempsHSemaine * 4.33;
  const coutMensuelTemps = tempsHMois * coutH;

  const leadsPerdusSemaine = demandes * pertePct;
  const leadsPerdusMois = leadsPerdusSemaine * 4.33;
  const caPerduMois = leadsPerdusMois * valeurClient;

  const tauxAutomation = 0.75;
  const tempsEcoH = tempsHSemaine * tauxAutomation;
  const tauxRecupLeads = 0.65;
  const caAdditionnel = leadsPerdusMois * tauxRecupLeads * valeurClient;

  const pack = getPackRecommande(demandes);
  const coutIA = pack.price;

  const gainBrut = (tempsHMois * tauxAutomation * coutH) + caAdditionnel;
  const roiNet = gainBrut - coutIA;
  const delaiMois = roiNet > 0 ? Math.max(1, Math.round(coutIA / (gainBrut / 1))) : 0;

  (document.getElementById('r-temps-actuel') as HTMLElement).textContent = tempsHSemaine.toFixed(1) + 'h/semaine';
  (document.getElementById('r-cout-actuel') as HTMLElement).textContent = fmt(Math.round(coutMensuelTemps));
  (document.getElementById('r-ca-perdu') as HTMLElement).textContent = '-' + fmt(Math.round(caPerduMois));
  (document.getElementById('r-temps-eco') as HTMLElement).textContent = '+' + tempsEcoH.toFixed(1) + 'h/semaine';
  (document.getElementById('r-ca-add') as HTMLElement).textContent = '+' + fmt(Math.round(caAdditionnel));
  (document.getElementById('r-pack') as HTMLElement).textContent = pack.name;
  (document.getElementById('r-cout-ia') as HTMLElement).textContent = fmt(coutIA) + '/mois';

  const roiEl = document.getElementById('r-roi') as HTMLElement;
  if (roiNet > 0) {
    roiEl.textContent = '+' + fmt(Math.round(roiNet)) + '/mois';
    roiEl.style.color = '#34d399';
  } else {
    roiEl.textContent = fmt(Math.round(roiNet)) + '/mois';
    roiEl.style.color = '#f87171';
  }

  const delaiEl = document.getElementById('r-delai') as HTMLElement;
  if (roiNet > 0) {
    delaiEl.textContent = 'Rentable dès le premier mois dans la plupart des cas';
  } else {
    delaiEl.textContent = 'Ajustez vos paramètres ou contactez-nous pour une analyse personnalisée';
  }
}

['demandes', 'temps', 'perte'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', calc);
});
['cout-horaire', 'valeur-client', 'secteur'].forEach(id => {
  document.getElementById(id)?.addEventListener('change', calc);
});

calc();
</script>

<style>
  input[type="range"]::-webkit-slider-thumb {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #7c5cfc;
    cursor: pointer;
    -webkit-appearance: none;
  }
  input[type="range"]::-webkit-slider-runnable-track {
    background: rgba(255,255,255,0.1);
    border-radius: 4px;
  }
</style>
