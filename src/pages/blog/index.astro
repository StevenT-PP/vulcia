<Layout
  title="Blog IA & SEO | Vulcia — Guides et études de cas pour PME"
  description="Le blog Vulcia : guides pratiques sur les agents IA, le SEO automatisé et les sites web haute performance pour les entreprises françaises."
>
  <Nav />

  <section class="pt-32 pb-24 px-6">
    <div class="max-w-7xl mx-auto">

      <div class="text-center mb-20">
        <p class="text-xs font-semibold uppercase tracking-widest text-[#7c5cfc] mb-4">Ressources</p>
        <h1 class="text-5xl md:text-6xl font-black text-white mb-6">
          Blog <span class="gradient-text">IA & SEO</span>
        </h1>
        <p class="text-[#8888aa] max-w-lg mx-auto">Guides concrets, études de cas réels et analyses techniques. Pas de théorie, des chiffres et des actions.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map(article => (
          <article class="glass rounded-2xl p-8 hover:bg-white/[0.06] transition-all duration-300 group flex flex-col">
            <div class="flex items-center justify-between mb-6">
              <span class="px-3 py-1 rounded-full text-xs font-semibold" style={`background: ${article.color}15; color: ${article.color}; border: 1px solid ${article.color}30;`}>
                {article.category}
              </span>
              <span class="text-xs text-[#8888aa]">{article.readTime} de lecture</span>
            </div>

            <h2 class="text-lg font-bold text-white mb-3 leading-snug group-hover:text-[#a78bfa] transition-colors flex-1">
              <a href={`/blog/${article.slug}`}>{article.title}</a>
            </h2>

            <p class="text-[#8888aa] text-sm leading-relaxed mb-6 flex-1">{article.excerpt}</p>

            <div class="flex items-center justify-between mt-auto">
              <time class="text-xs text-[#8888aa]">
                {new Date(article.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <a href={`/blog/${article.slug}`} class="text-xs font-semibold transition-colors" style={`color: ${article.color};`}>
                Lire &rarr;
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
