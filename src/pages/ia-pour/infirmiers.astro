---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#34d399";

const tasks = [
  "Gère les demandes de nouveaux patients et collecte les informations administratives (carte vitale, mutuelle, ordonnances)",
  "Programme les tournées de soins selon les disponibilités et la zone géographique",
  "Répond aux questions sur les soins remboursés, les tarifs conventionnés et les dépassements d'honoraires",
  "Envoie les rappels de soins aux patients chroniques (pansements, injections, perfusions, glycémies)",
  "Informe patients et familles sur les procédures PRADO (retour à domicile post-hospitalisation)",
  "Collecte les demandes de devis pour les soins hors nomenclature (garde, nursing, nuit)",
  "Oriente les urgences vers le 15/SAMU et les médecins de garde selon les symptômes décrits",
  "Gère les absences et remplacements avec notification immédiate aux patients de la tournée",
];

const faqItems = [
  {
    q: "L'agent peut-il transmettre des informations médicales sur les patients ?",
    a: "Absolument pas. L'agent ne stocke et ne transmet aucune donnée de santé. Il gère uniquement les informations administratives et logistiques : prise de rendez-vous, rappels de soins, informations tarifaires. Toute question médicale est redirigée vers vous ou le médecin traitant. Hébergement en France, conformité RGPD garantie.",
  },
  {
    q: "L'agent peut-il gérer les feuilles de soins et la télétransmission Sesam-Vitale ?",
    a: "Non — la télétransmission Sesam-Vitale implique des données de santé et reste exclusivement dans votre logiciel IDEL (Alaxione, Oxypharm, Logideal). L'agent gère l'amont : prise de contact, collecte de documents administratifs, programmation. Il peut rappeler aux patients de préparer leur carte vitale avant votre passage.",
  },
  {
    q: "L'agent est-il compatible avec les logiciels IDEL (Alaxione, Oxypharm, Logideal) ?",
    a: "L'agent ne s'intègre pas directement aux logiciels de soins infirmiers pour des raisons de sécurité des données de santé. En revanche, il peut gérer les demandes entrantes et vous transmettre un résumé quotidien (nouveaux patients, documents à réceptionner, créneaux demandés) à intégrer manuellement dans votre planning.",
  },
  {
    q: "Comment gérer les demandes urgentes la nuit ou le week-end ?",
    a: "L'agent détecte les signaux d'urgence dans les messages (douleur aiguë, chute, décompensation) et oriente immédiatement vers le 15, le médecin de garde via Doctolib ou votre remplaçant si configuré. Pour les urgences de soins non vitales (pansement à changer en urgence), il vous envoie une notification push immédiate.",
  },
  {
    q: "En combien de temps est-il opérationnel pour un IDEL en libéral ?",
    a: "5 à 7 jours ouvrés pour un agent avec FAQ, prise de contact et informations tarifaires. La configuration inclut votre zone géographique, vos horaires de tournée et vos spécialités (diabétologie, plaies et cicatrisation, post-opératoire). 0€ d'installation, sans engagement.",
  },
];
---

<Layout
  title="Agent IA pour infirmiers libéraux (IDEL) | Vulcia"
  description="Agent IA pour infirmier libéral : gestion des demandes de soins, rappels patients chroniques, informations PRADO et tarifs conventionnés — sans toucher aux données de santé. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Infirmiers libéraux", "item": "https://vulcia.fr/ia-pour/infirmiers" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Infirmiers libéraux</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour infirmiers libéraux (IDEL)</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Tournées sans interruption.<br/><span class="gradient-text">Patients chroniques suivis.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Demandes de soins gérées, rappels patients automatisés, informations PRADO et tarifs conventionnés disponibles 24h/24 — pendant que vous êtes en tournée.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "-60%", label: "d'appels entrants pour les demandes de soins et questions tarifaires pendant les tournées", color },
            { val: "+40%", label: "de suivi des patients chroniques grâce aux rappels automatiques de soins et d'injections", color: "#38bdf8" },
            { val: "-55%", label: "de no-shows grâce aux rappels de passage et aux confirmations automatiques la veille", color: "#fbbf24" },
            { val: "5 jours", label: "pour être opérationnel avec vos soins, votre zone et vos horaires de tournée", color: "#a78bfa" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre cabinet infirmier</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Soins couverts vs. soins hors périmètre</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">L'agent gère l'administratif. Les soins et les données de santé restent exclusivement entre vous et vos patients.</p>
      <div class="not-prose my-6 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10">
              <th class="text-left text-[#8888aa] font-semibold pb-3 pr-6">Situation patient</th>
              <th class="text-left pb-3 pr-6" style={`color: ${color};`}>Ce que l'agent gère</th>
              <th class="text-left pb-3" style="color: #f87171;">Ce qui reste chez vous</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            {[
              ["Nouveau patient post-hospitalisation (PRADO)", "Collecte administratif, informe sur le protocole PRADO, programme le 1er passage", "Évaluation clinique, prescription de soins, dossier de soins infirmiers"],
              ["Patient chronique (plaie, diabète, chimiothérapie)", "Rappels de passage, confirmation créneau, notification de la famille", "Réalisation des soins, surveillance clinique, liaison avec le médecin"],
              ["Demande d'intégration de nouveau patient", "Qualification géographique, vérification de votre disponibilité, demande de prescription médicale", "Acceptation en soins, évaluation du niveau de dépendance, cotation NGAP"],
              ["Demande de garde ou de nuit", "Informe sur les tarifs (MCI, MCN, IFI), collecte les informations pour le devis", "Décision d'accepter, soins réalisés, transmission au médecin si nécessaire"],
              ["Urgence signalée par le patient ou la famille", "Détecte le signal d'urgence, oriente vers 15/médecin de garde, vous notifie immédiatement", "Prise en charge médicale, protocole d'urgence, liaison SAMU"],
            ].map(([situation, agent, vous]) => (
              <tr>
                <td class="py-3 pr-6 text-white text-xs font-medium align-top">{situation}</td>
                <td class="py-3 pr-6 text-[#8888aa] text-xs align-top">{agent}</td>
                <td class="py-3 text-[#8888aa] text-xs align-top">{vous}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/kinesitherapeutes', title: 'IA pour kinésithérapeutes : agenda plein et no-shows réduits', cat: 'Secteur' },
          { href: '/ia-pour/medecins', title: 'IA pour médecins généralistes', cat: 'Secteur' },
          { href: '/blog/reduire-no-shows-ia', title: 'Réduire les no-shows avec l\'IA : guide complet', cat: 'Guide' },
          { href: '/blog/ia-securite-rgpd-pme', title: 'IA et RGPD : ce que les PME de santé doivent savoir', cat: 'RGPD' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#34d399] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Vous en tournée. L'agent à l'accueil.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos demandes entrantes, vos rappels de soins manqués et votre potentiel de patients chroniques mieux suivis pour vous chiffrer ce que vous gagneriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #059669);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · RGPD conforme HDS · Opérationnel en 5 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
