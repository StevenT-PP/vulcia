---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const tasks = [
  "Répond aux demandes de devis 24h/24 via site, WhatsApp ou email",
  "Collecte les informations nécessaires (surface, localisation, urgence, type de travaux)",
  "Détecte les urgences et vous alerte immédiatement par SMS",
  "Planifie les visites et interventions selon vos disponibilités",
  "Relance automatiquement les devis non signés à J+3 et J+7",
  "Répond aux questions fréquentes (délais, garanties, certifications)",
  "Envoie les devis et documents par email après votre validation",
  "Qualifie les prospects : travaux immédiats vs simple info-prix",
];

const faqItems = [
  {
    q: "Est-ce que l'agent peut envoyer des devis tout seul ?",
    a: "Il peut collecter toutes les informations et pré-remplir un modèle de devis que vous validez en un clic. Pour les prix fixes (entretien chaudière, débouchage standard), il peut envoyer une estimation directement. Pour les chantiers complexes, il prépare le dossier et vous envoie une notification.",
  },
  {
    q: "Que se passe-t-il pour les urgences (fuite, panne de chauffage) ?",
    a: "L'agent est configuré pour détecter les mots-clés d'urgence et vous alerter immédiatement par SMS avec le numéro du client. Le client reçoit votre numéro direct en parallèle. Aucune urgence ne reste sans réponse.",
  },
  {
    q: "Est-ce que ça fonctionne si je travaille seul ?",
    a: "C'est même là où c'est le plus utile. Quand vous êtes sur un chantier et ne pouvez pas répondre, l'agent traite les demandes entrantes. Vous rentrez le soir avec un agenda qualifié et des devis préparés.",
  },
  {
    q: "Compatible avec mon logiciel de facturation ?",
    a: "On peut s'intégrer avec la plupart des logiciels métiers (Evoliz, Sellsy, Batappli, EBP, Sage). L'agent alimente le CRM avec les informations prospects. La connexion dépend du logiciel et du pack choisi.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours. On configure l'agent avec vos types de travaux, vos zones d'intervention, vos tarifs (si fixes), vos délais habituels et votre calendrier. Vous validez sur 30 scénarios tests, puis on met en ligne.",
  },
];
---

<Layout
  title="Agent IA pour artisans et BTP | Vulcia"
  description="Agent IA pour artisans : répondez aux demandes de devis 24h/24, détectez les urgences, relancez automatiquement. Plombier, électricien, maçon — opérationnel en 7 jours. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />

  <Nav />

  <!-- HERO -->
  <section class="pt-32 pb-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div style="position:absolute;width:600px;height:500px;top:-5%;left:-5%;background:radial-gradient(circle,rgba(251,146,60,0.1),transparent 70%);filter:blur(80px);"></div>
    </div>
    <div class="max-w-4xl mx-auto relative">
      <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-8">
        <a href="/" class="hover:text-white transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-white">Agent IA pour artisans</span>
      </nav>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block text-xs font-bold uppercase tracking-widest mb-4 px-3 py-1 rounded-full" style="color: #fb923c; background: rgba(251,146,60,0.1); border: 1px solid rgba(251,146,60,0.2);">Artisans & BTP</span>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Sur le chantier ?<br/><span style="color: #fb923c;">Votre assistant<br/>répond à votre place.</span>
          </h1>
          <p class="text-[#8888aa] leading-relaxed mb-8">
            Un agent IA qui gère vos demandes de devis, détecte les urgences et relance vos prospects — pendant que vous travaillez.
          </p>
          <div class="flex flex-wrap gap-3 mb-8">
            {[
              { v: "-60%", l: "de temps au tél." },
              { v: "0", l: "demande manquée" },
              { v: "+35%", l: "de devis signés" },
            ].map(s => (
              <div class="glass rounded-xl px-4 py-3 text-center">
                <p class="text-2xl font-black text-white">{s.v}</p>
                <p class="text-xs text-[#8888aa]">{s.l}</p>
              </div>
            ))}
          </div>
          <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl text-white font-bold transition-all hover:opacity-90" style="background: linear-gradient(135deg, #fb923c, #ea580c);">
            Audit gratuit pour mon activité &rarr;
          </a>
        </div>
        <div class="glass rounded-2xl p-6">
          <p class="text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-4">Exemple : demande de devis à 20h</p>
          <div class="space-y-3">
            {[
              { c: true, t: "Bonjour, j'ai une fuite sous l'évier. C'est urgent, vous intervenez quand ?" },
              { c: false, t: "Bonjour ! Je suis l'assistant de l'entreprise. Pour une fuite, on peut intervenir rapidement. C'est dans quelle ville ?" },
              { c: true, t: "Lyon 3ème" },
              { c: false, t: "On intervient bien sur Lyon 3. Vous pouvez m'envoyer une photo de la fuite ? Je vais alerter le plombier disponible ce soir." },
              { c: true, t: "[photo envoyée]" },
              { c: false, t: "Photo reçue. Le plombier vous rappelle dans les 20 minutes pour confirmer l'intervention. Vous pouvez l'attendre ?" },
            ].map(msg => (
              <div class={`flex ${msg.c ? 'justify-end' : 'justify-start'}`}>
                <div class={`max-w-[80%] px-4 py-2.5 rounded-2xl text-xs leading-relaxed ${msg.c ? 'text-white' : 'text-[#ccccdd]'}`} style={msg.c ? 'background: rgba(251,146,60,0.2); border: 1px solid rgba(251,146,60,0.3);' : 'background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);'}>
                  {msg.t}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CE QUE FAIT L'AGENT -->
  <section class="py-20 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-black text-white text-center mb-4">Ce que l'agent fait pour votre activité</h2>
      <p class="text-[#8888aa] text-center mb-12">Configuré pour votre corps de métier, vos zones, vos tarifs.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fb923c" stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <p class="text-[#8888aa] text-sm">{task}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AVANT / APRÈS -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-black text-white text-center mb-12">Artisan solo : avant et après</h2>
      <div class="glass rounded-2xl p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h3 class="text-white font-bold mb-5 flex items-center gap-2">
              <span class="w-6 h-6 rounded-full bg-red-500/20 flex items-center justify-center text-red-400 text-xs font-black">×</span>
              Sans agent IA
            </h3>
            <ul class="space-y-3 text-sm text-[#8888aa]">
              <li class="flex items-start gap-2"><span class="text-red-400">·</span> Appels manqués sur chantier = clients perdus</li>
              <li class="flex items-start gap-2"><span class="text-red-400">·</span> Devis non relancés = 30% de perte en moyenne</li>
              <li class="flex items-start gap-2"><span class="text-red-400">·</span> 3-4h/semaine passées au téléphone</li>
              <li class="flex items-start gap-2"><span class="text-red-400">·</span> Urgences détectées trop tard</li>
            </ul>
          </div>
          <div>
            <h3 class="text-white font-bold mb-5 flex items-center gap-2">
              <span class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-black" style="background: rgba(251,146,60,0.2); color: #fb923c;">✓</span>
              Avec agent IA Vulcia
            </h3>
            <ul class="space-y-3 text-sm text-[#8888aa]">
              <li class="flex items-start gap-2"><span style="color: #fb923c;">·</span> 100% des demandes traitées, même en intervention</li>
              <li class="flex items-start gap-2"><span style="color: #fb923c;">·</span> Relances automatiques J+3 et J+7 sur devis</li>
              <li class="flex items-start gap-2"><span style="color: #fb923c;">·</span> -60% de temps passé à gérer les appels</li>
              <li class="flex items-start gap-2"><span style="color: #fb923c;">·</span> Alerte SMS immédiate pour chaque urgence</li>
            </ul>
          </div>
        </div>
        <div class="mt-8 pt-6 border-t border-white/10 text-center">
          <p class="text-[#8888aa] text-sm mb-2">Valeur des devis récupérés grâce aux relances automatiques</p>
          <span class="text-3xl font-black" style="color: #fb923c;">+2 400 €/mois en moyenne</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-black text-white text-center mb-12">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqItems.map(f => (
          <details class="glass rounded-xl group">
            <summary class="p-5 cursor-pointer flex items-center justify-between text-white font-semibold text-sm list-none">
              {f.q}
              <span class="ml-4 flex-shrink-0 transition-transform group-open:rotate-45 text-lg" style="color: #fb923c;">+</span>
            </summary>
            <p class="px-5 pb-5 text-[#8888aa] text-sm leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Ne perdez plus un client faute de réponse</h2>
      <p class="text-[#8888aa] mb-8">Audit gratuit de 30 minutes. On vous montre comment l'agent fonctionnerait dans votre activité — et combien de chiffre d'affaires vous récupérez.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold text-base transition-all hover:opacity-90" style="background: linear-gradient(135deg, #fb923c, #ea580c);">
        Audit gratuit pour mon activité &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">Réponse sous 24h · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  details summary::-webkit-details-marker { display: none; }
</style>
