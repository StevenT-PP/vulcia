---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#10b981";

const tasks = [
  "Prend les rendez-vous consultation, vaccination, chirurgie 24h/24",
  "Qualifie l'urgence : symptômes de l'animal, espèce, poids, traitements en cours",
  "Envoie les confirmations et rappels de RDV automatiquement",
  "Rappelle les dates de vaccination et traitement anti-parasitaire",
  "Répond aux questions fréquentes sur les protocoles de soin et préparation",
  "Gère les ordonnances de renouvellement (redirection vétérinaire si nécessaire)",
  "Informe sur les urgences vétérinaires de garde les plus proches",
  "Collecte les informations pour la fiche animal avant la première consultation",
];

const faqItems = [
  {
    q: "L'agent peut-il donner des conseils médicaux sur les animaux ?",
    a: "Non. L'agent recueille les symptômes et informe le propriétaire du niveau d'urgence apparent, mais ne se substitue jamais à un diagnostic vétérinaire. Pour toute question médicale, il dirige vers la consultation ou l'urgence. Cette limite est non-négociable et intégrée dans la configuration.",
  },
  {
    q: "Compatible avec les logiciels vétérinaires (Vétup, Clovis, Pulse) ?",
    a: "Oui. On s'intègre aux principaux logiciels de gestion vétérinaire pour synchroniser les plannings en temps réel. Le propriétaire voit vos vraies disponibilités et le RDV est créé directement dans votre logiciel.",
  },
  {
    q: "Comment l'agent gère-t-il les urgences vétérinaires ?",
    a: "L'agent est configuré pour détecter les signes d'urgence vitale (convulsions, difficulté respiratoire, ingestion de toxique, traumatisme grave). Dans ces cas, il oriente immédiatement vers votre numéro d'urgence ou la clinique de garde la plus proche.",
  },
  {
    q: "Peut-il gérer les rappels de vaccins pour toute la clientèle ?",
    a: "Oui, c'est l'une des fonctions les plus rentables. L'agent peut envoyer des rappels automatiques par SMS ou WhatsApp 30 jours avant la date de rappel vaccinal de chaque animal. Nos clients constatent en moyenne +25% de taux de rappel de vaccination.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés. On configure l'agent avec vos types de consultations, vos espèces traitées, vos protocoles d'urgence et vos horaires. Vous validez les réponses sur 40 scénarios avant la mise en ligne.",
  },
];
---

<Layout
  title="Agent IA pour vétérinaires — RDV automatiques et rappels de vaccins | IAForge"
  description="Agent IA pour cabinet vétérinaire : prise de RDV 24h/24, rappels de vaccination automatiques, qualification des urgences. RGPD, opérationnel en 7 jours. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://iaforge.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://iaforge.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Vétérinaires", "item": "https://iaforge.fr/ia-pour/veterinaires" }
    ]
  })} />

  <Nav />

  <!-- HERO -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Vétérinaires</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour vétérinaires</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Votre cabinet vétérinaire<br/><span class="gradient-text">disponible 24h/24 pour les propriétaires</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            RDV automatiques, rappels de vaccination, qualification des urgences — votre agent IA répond aux propriétaires pendant que vous vous concentrez sur les soins.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">
              Audit gratuit &rarr;
            </a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">
              Calculer mon ROI
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "+25%", label: "de taux de rappel vaccinal grâce aux relances automatiques", color },
            { val: "-12h", label: "de secrétariat téléphonique économisées par semaine", color: "#34d399" },
            { val: "0 appel", label: "perdu la nuit ou le week-end pour les demandes courantes", color: "#a78bfa" },
            { val: "7 jours", label: "pour être opérationnel, connecté à votre logiciel vétérinaire", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- TACHES -->
  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre cabinet</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AVANT / APRES -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Avant / après pour un cabinet de 2 vétérinaires</h2>
      <div class="glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3">
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-[#8888aa] uppercase tracking-wider">Situation</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-red-400 uppercase tracking-wider text-center">Sans agent</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold uppercase tracking-wider text-center" style={`color: ${color};`}>Avec agent IAForge</div>
          {[
            ["RDV hors horaires", "Non pris, propriétaire va ailleurs", "Pris automatiquement, confirmé par SMS"],
            ["Rappels de vaccination", "Jamais ou manuels (chronophage)", "Automatiques 30j avant, taux +25%"],
            ["Qualification urgences", "Appel manuel, souvent anxiogène", "Triage automatique + orientation immédiate"],
            ["Fiche animal première visite", "Formulaire papier au cabinet", "Collectée avant le RDV, prête à l'arrivée"],
            ["Appels répétitifs horaires/tarifs", "20-30 appels/jour", "< 5 appels/jour (cas complexes)"],
          ].map(([sit, sans, avec]) => (
            <>
              <div class="p-4 border-b border-white/5 text-xs text-white">{sit}</div>
              <div class="p-4 border-b border-white/5 text-xs text-red-400 text-center">{sans}</div>
              <div class="p-4 border-b border-white/5 text-xs text-center font-medium" style={`color: ${color};`}>{avec}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Concentrez-vous sur les soins, pas sur le téléphone</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos flux de RDV, vos rappels de vaccination manqués et on chiffre ce qu'un agent IA vous rapporte concrètement.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #059669);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · RGPD-conforme · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
