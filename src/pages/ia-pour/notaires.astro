---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#7c5cfc";

const tasks = [
  "Qualifie les demandes : type d'acte, nature de la transaction, délai souhaité",
  "Informe sur les actes, les délais et les pièces à fournir selon le dossier",
  "Gère la prise de rendez-vous pour les rendez-vous de signature et de conseil",
  "Collecte les pièces justificatives et relance les clients qui tardent à les envoyer",
  "Répond aux questions fréquentes : frais de notaire, délais légaux, succession",
  "Envoie les convocations et rappels de signature automatiquement",
  "Gère les demandes de devis honoraires (actes standardisés)",
  "Traite les demandes d'information sur les successions et donations",
];

const faqItems = [
  {
    q: "L'agent peut-il donner des conseils juridiques sur les actes ?",
    a: "Non — et c'est une limite non-négociable. L'agent fournit des informations générales (délais légaux, pièces requises, frais réglementés) mais ne donne jamais de conseil personnalisé. Toute question spécifique à la situation du client est redirigée vers un notaire ou un clerc qualifié.",
  },
  {
    q: "Comment sont protégées les données des clients (données personnelles et patrimoniales) ?",
    a: "Les études notariales traitent des données très sensibles. Vulcia utilise exclusivement Mistral AI hébergé à Paris. L'agent ne stocke que les données de contact et les types de demandes — jamais les données patrimoniales, les évaluations ou les contenus d'actes. Conformité CNIL et DPA fourni.",
  },
  {
    q: "Compatible avec les logiciels notariaux (Fiducial, Fichorga, Real.not) ?",
    a: "L'agent s'intègre à votre agenda pour la gestion des RDV. Pour des raisons de sécurité des données, il ne s'intègre pas aux logiciels de rédaction d'actes. La collecte de pièces se fait via formulaire sécurisé dédié.",
  },
  {
    q: "Peut-il gérer les dossiers de succession ?",
    a: "L'agent peut collecter les informations initiales (identité du défunt, héritiers, nature des biens) et relancer les héritiers pour les pièces manquantes. Il ne participe jamais à l'analyse du dossier ou à la rédaction de la déclaration de succession.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés. On configure l'agent avec vos types d'actes, vos questions fréquentes, votre agenda et vos procédures de collecte. Vous validez sur 40 scénarios avant la mise en ligne.",
  },
];
---

<Layout
  title="Agent IA pour offices notariales | Vulcia"
  description="Agent IA pour notaire : qualification des demandes, prise de RDV de signature, collecte de pièces et relances automatiques. RGPD, hébergé en France. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Notaires", "item": "https://vulcia.fr/ia-pour/notaires" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Notaires</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour offices notariales</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Votre étude traite<br/><span class="gradient-text">chaque demande en 60 secondes, 24h/24</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Qualification des demandes, prise de RDV de signature, collecte de pièces et relances — votre agent IA gère l'administratif pendant que vos notaires et clercs rédigent les actes.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "22h", label: "d'administration économisées par semaine et par étude en moyenne", color },
            { val: "-40%", label: "de retards de collecte de pièces grâce aux relances automatiques", color: "#34d399" },
            { val: "0 demande", label: "perdue hors horaires — qualification et information en 60 secondes", color: "#38bdf8" },
            { val: "7 jours", label: "pour être opérationnel, RGPD-conforme, hébergé en France", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre étude</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Avant / après pour une étude de 3 notaires</h2>
      <div class="glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3">
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-[#8888aa] uppercase tracking-wider">Situation</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-red-400 uppercase tracking-wider text-center">Sans agent</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold uppercase tracking-wider text-center" style={`color: ${color};`}>Avec agent Vulcia</div>
          {[
            ["Demandes hors horaires", "Email sans réponse avant 9h", "Qualifié + info envoyée en 60 sec."],
            ["Collecte pièces manquantes", "Rappel téléphonique → chronophage", "Relance auto J+2, J+7, J+14"],
            ["FAQ frais / délais / actes", "20 min/appel, 30 appels/semaine", "Réponse automatique 24h/24"],
            ["Prise de RDV signature", "Secrétaire + allers-retours email", "RDV planifié en 2 min de chat"],
            ["Convocations et rappels", "Envoi manuel par le secrétariat", "Automatique J-7 et J-1"],
          ].map(([sit, sans, avec]) => (
            <>
              <div class="p-4 border-b border-white/5 text-xs text-white">{sit}</div>
              <div class="p-4 border-b border-white/5 text-xs text-red-400 text-center">{sans}</div>
              <div class="p-4 border-b border-white/5 text-xs text-center font-medium" style={`color: ${color};`}>{avec}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto glass rounded-2xl p-8">
      <div class="flex items-start gap-5">
        <div class="text-3xl flex-shrink-0">🔒</div>
        <div>
          <h2 class="text-xl font-black text-white mb-3">Données patrimoniales : hébergement France</h2>
          <p class="text-[#8888aa] text-sm leading-relaxed mb-4">
            Les offices notariales gèrent des données particulièrement sensibles. Vulcia utilise exclusivement <strong class="text-white">Mistral AI hébergé à Paris</strong>. L'agent traite les coordonnées et les types de demandes — jamais les données patrimoniales, les évaluations ou les contenus d'actes.
          </p>
          <ul class="space-y-2">
            {[
              "Aucune donnée patrimoniale ne transit via des serveurs hors UE",
              "DPA (Data Processing Agreement) signé avec chaque étude",
              "Conformité CNIL et droit à l'effacement opérationnel",
              "Audit de configuration inclus dans le déploiement",
            ].map(item => (
              <li class="flex items-center gap-2 text-sm text-[#8888aa]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Vos notaires ont mieux à faire que répondre au téléphone</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos flux de demandes, votre volume de relances pièces et le temps consacré à l'administratif pour vous chiffrer le gain exact.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #5b3fdb);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Données hébergées en France · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
