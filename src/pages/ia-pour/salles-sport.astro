---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#f97316";

const tasks = [
  "Gère les inscriptions et abonnements 24h/24 sans secrétaire",
  "Répond aux questions sur les cours, horaires, coachs et tarifs",
  "Envoie les rappels de cours automatiquement (J-1 et J-2h)",
  "Gère les listes d'attente et notifie en cas de désistement",
  "Relance automatiquement les membres inactifs depuis 3 semaines",
  "Envoie les offres de renouvellement avant l'expiration de l'abonnement",
  "Collecte les avis Google après les 3 premières semaines de l'abonné",
  "Répond aux demandes d'essai gratuit et planifie la visite",
];

const faqItems = [
  {
    q: "Compatible avec les logiciels de gestion de salle (Glofox, Mindbody, Bsport) ?",
    a: "Oui. On s'intègre à Glofox, Mindbody, Bsport, Clubeo et la plupart des logiciels de gestion via API. L'agent voit les vrais créneaux disponibles, gère les inscriptions aux cours et met à jour les plannings en temps réel.",
  },
  {
    q: "L'agent peut-il gérer les périodes de lancement et de promotion ?",
    a: "C'est l'un des meilleurs cas d'usage. En période de rentrée (septembre, janvier), l'agent gère l'afflux de demandes, qualifie les prospects, envoie les offres et planifie les visites — sans vous surcharger. Certains clients triplent leurs inscriptions en septembre grâce à cette automatisation.",
  },
  {
    q: "Comment gérer la rétention des membres qui s'absentent ?",
    a: "L'agent est configuré pour détecter les membres absents depuis X jours et envoyer un message de relance personnalisé — pas un email générique, mais un message qui mentionne leur cours préféré ou leur coach habituel. Le taux de rétention moyen augmente de 20 à 30% avec cette seule fonction.",
  },
  {
    q: "Peut-il gérer les ventes de coaching personnalisé ?",
    a: "Oui. L'agent qualifie les demandes de coaching (objectif, niveau, disponibilités, budget), envoie le programme du coach et planifie le bilan initial. Pour le coaching premium, il filtre et transfert au coach concerné avec la fiche prospect complète.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés. On configure l'agent avec votre planning de cours, vos tarifs d'abonnement, vos coachs et vos procédures d'inscription. Vous validez sur 40 scénarios avant la mise en ligne.",
  },
];
---

<Layout
  title="Agent IA pour salles de sport et studios fitness — Inscriptions et rétention automatisées | Vulcia"
  description="Agent IA pour salle de sport : inscriptions 24h/24, relances membres inactifs, gestion des cours et abonnements. +30% de rétention. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Salles de sport", "item": "https://vulcia.fr/ia-pour/salles-sport" }
    ]
  })} />

  <Nav />

  <!-- HERO -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Salles de sport</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour salles de sport & studios</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Votre salle inscrit<br/><span class="gradient-text">et fidélise ses membres 24h/24</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Inscriptions automatiques, relances membres inactifs, gestion des cours — votre agent IA remplit les créneaux et réduit le churn pendant que vous coachez.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">
              Audit gratuit &rarr;
            </a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">
              Calculer mon ROI
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "+30%", label: "de rétention membres grâce aux relances automatiques inactifs", color },
            { val: "×2", label: "d'inscriptions en septembre grâce à la gestion automatique des demandes", color: "#34d399" },
            { val: "0 appel", label: "perdu hors horaires — chaque demande reçoit une réponse immédiate", color: "#a78bfa" },
            { val: "7 jours", label: "pour être opérationnel, connecté à Glofox, Mindbody ou Bsport", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- TACHES -->
  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre salle</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AVANT / APRES -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Avant / après pour un studio fitness 200 membres</h2>
      <div class="glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3">
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-[#8888aa] uppercase tracking-wider">Situation</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-red-400 uppercase tracking-wider text-center">Sans agent</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold uppercase tracking-wider text-center" style={`color: ${color};`}>Avec agent Vulcia</div>
          {[
            ["Demandes d'inscription hors horaires", "Email sans réponse pendant 24h", "Inscrit et payé en 5 minutes"],
            ["Membres inactifs depuis 3 sem.", "Aucune relance — churn silencieux", "Relance automatique personnalisée"],
            ["Renouvellement abonnement", "Client doit rappeler ou revenir", "Email automatique J-15 avant exp."],
            ["Gestion liste d'attente cours", "Excel ou tableau blanc", "Notification auto en cas de désisto"],
            ["Collecte avis Google", "1 à 2 par mois si demande verbale", "+4 à 6 avis/mois via relance auto"],
          ].map(([sit, sans, avec]) => (
            <>
              <div class="p-4 border-b border-white/5 text-xs text-white">{sit}</div>
              <div class="p-4 border-b border-white/5 text-xs text-red-400 text-center">{sans}</div>
              <div class="p-4 border-b border-white/5 text-xs text-center font-medium" style={`color: ${color};`}>{avec}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- RETENTION -->
  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">La rétention : le vrai levier de croissance</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10 max-w-2xl mx-auto">Acquérir un nouveau membre coûte 5× plus cher que d'en fidéliser un. La relance automatique des membres inactifs est le ROI le plus rapide à obtenir.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {[
          { delai: "Inactif depuis 14 jours", msg: "\"Salut Paul, ça fait 2 semaines qu'on t'a pas vu ! Marie a lancé un nouveau cours HIIT le mercredi soir — tu veux qu'on te réserve une place ?\"", color },
          { delai: "Inactif depuis 30 jours", msg: "\"Paul, ton abonnement tourne mais on te voit plus. Est-ce qu'on peut faire quelque chose ? Un coaching découverte gratuit 30 min avec Marc peut-être ?\"", color: "#fbbf24" },
          { delai: "Avant expiration J-15", msg: "\"Ton abonnement expire dans 15 jours. On te prépare le renouvellement au même tarif — réponds OUI et c'est bon. Ou on peut en parler si tu as des questions.\"", color: "#34d399" },
        ].map(item => (
          <div class="glass rounded-2xl p-5">
            <p class="font-bold text-xs mb-3 uppercase tracking-wider" style={`color: ${item.color};`}>{item.delai}</p>
            <p class="text-[#9090b0] text-xs italic leading-relaxed">{item.msg}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ARTICLES LIES -->
  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/blog/automatiser-relances-clients', title: 'Automatiser ses relances clients avec l\'IA : le guide complet 2026', cat: 'Automatisation' },
          { href: '/blog/agent-ia-whatsapp', title: 'Agent IA sur WhatsApp Business : guide pratique 2026', cat: 'Automatisation' },
          { href: '/blog/chatbot-site-web-2026', title: 'Chatbot IA pour site web en 2026 : tout ce qu\'il faut savoir', cat: 'Agents IA' },
          { href: '/blog/prix-agent-ia-2026', title: 'Combien coûte un agent IA en 2026 ? Prix, packs et ROI expliqués', cat: 'Tarifs' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Arrêtez de perdre des membres faute de relance</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse votre taux de churn, vos pics d'inscription et ce que vous perdez chaque mois en membres inactifs non relancés.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #ea580c);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
