---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#34d399";

const tasks = [
  "Gère les inscriptions aux cours et ateliers 24h/24",
  "Rappelle les cours J-1 et H-2h pour réduire les absences",
  "Gère la liste d'attente et notifie en cas de désistement",
  "Relance les membres inactifs depuis 2 semaines ou un mois",
  "Répond aux questions sur les plannings, tarifs et formules",
  "Gère les abonnements, renouvellements et cartes de cours",
  "Notifie les ateliers et événements spéciaux à venir",
  "Collecte les retours post-cours pour améliorer les plannings",
];

const faqItems = [
  {
    q: "L'agent peut-il gérer les inscriptions sur plusieurs types de cours ?",
    a: "Oui. L'agent connaît votre planning complet : yoga, méditation, pilates, ateliers thématiques. Il gère les capacités par cours (places limitées), les listes d'attente, et adapte les réponses selon les niveaux (débutant, intermédiaire, avancé). Un client qui veut reprendre après une absence reçoit des suggestions adaptées à son profil.",
  },
  {
    q: "Compatible avec Glofox, Mindbody ou Bsport ?",
    a: "Glofox, Mindbody et Bsport sont intégrés via leurs APIs. L'agent lit les disponibilités en temps réel et crée les réservations directement dans votre logiciel. Pour les studios qui gèrent les inscriptions par email ou feuille, l'agent s'adapte avec une intégration Google Sheets.",
  },
  {
    q: "Comment l'agent gère-t-il les abonnements et cartes de cours ?",
    a: "L'agent informe les membres du solde restant sur leur carte de cours, les alerte quand il reste 2 cours, et propose le renouvellement automatiquement. Pour les abonnements mensuels, il envoie un rappel de renouvellement 5 jours avant l'échéance et gère les demandes de pause ou d'annulation.",
  },
  {
    q: "L'agent peut-il relancer les membres inactifs sans paraître intrusif ?",
    a: "C'est un point délicat dans le bien-être. L'agent est configuré avec un ton chaleureux et bienveillant, pas commercial. Après 2 semaines d'absence : message de prise de nouvelles. Après 1 mois : suggestion d'un cours adapté. Après 2 mois : offre de \"cours de retour\" offert ou à tarif réduit. Le ton est toujours bienveillant.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés. On configure l'agent avec votre planning, vos formules, vos instructeurs et votre ton de communication. Pour les studios bien-être, on accorde une attention particulière à l'alignement entre le ton de l'agent et les valeurs de votre espace.",
  },
];
---

<Layout
  title="Agent IA pour studios de yoga et bien-être | Vulcia"
  description="Agent IA pour studio de yoga : inscriptions aux cours 24h/24, rappels, liste d'attente, relances membres inactifs — compatible Glofox, Mindbody, Bsport. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Studios yoga & bien-être", "item": "https://vulcia.fr/ia-pour/studios-yoga" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Studios yoga & bien-être</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour studios yoga & bien-être</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Vos membres fidèles.<br/><span class="gradient-text">Vos cours toujours pleins.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Inscriptions 24h/24, rappels bienveillants, relances membres inactifs et gestion des abonnements — votre agent s'occupe du relationnel pendant que vous guidez.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "+35%", label: "de rétention membres grâce aux relances bienveillantes d'inactivité", color },
            { val: "-50%", label: "d'absences sur liste grâce aux rappels J-1 et H-2h", color: "#f59e0b" },
            { val: "×2", label: "de taux de remplissage des cours via la liste d'attente automatique", color: "#a78bfa" },
            { val: "7 jours", label: "pour être opérationnel, configuré à votre ton et votre planning", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre studio</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">La séquence de rétention bien-être : chaleur et non-intrusion</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">Dans le secteur bien-être, le ton de la relance est aussi important que son timing. Trop commercial = fuite. Trop absent = churn silencieux.</p>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        {[
          { step: "J+14", label: "Prise de nouvelles", msg: "\"Bonjour [Prénom], vous nous manquez ! Tout va bien ? On a de nouveaux cours ce mois-ci qui pourraient vous plaire.\"", color },
          { step: "J+30", label: "Suggestion personnalisée", msg: "\"On a pensé à vous pour notre atelier [Thème adapté] — c'est parfait pour [votre objectif]. Encore 3 places disponibles.\"", color: "#38bdf8" },
          { step: "J+60", label: "Offre de retour", msg: "\"Pour votre retour, on vous offre votre prochain cours. Sans condition. Parce que votre bien-être nous tient à cœur.\"", color: "#a78bfa" },
          { step: "J+90", label: "Pause relationnelle", msg: "Mise en veille 6 mois. Pas de relance pour ne pas devenir intrusif. Réactivation automatique à 9 mois.", color: "#f59e0b" },
        ].map(item => (
          <div class="glass rounded-2xl p-5">
            <div class="text-xs font-bold mb-1" style={`color: ${item.color};`}>{item.step}</div>
            <p class="text-white font-bold text-sm mb-2">{item.label}</p>
            <p class="text-[#8888aa] text-xs leading-relaxed italic">{item.msg}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/salles-sport', title: 'Agent IA pour salles de sport — inscriptions et rétention', cat: 'Secteur' },
          { href: '/ia-pour/coachs', title: 'Agent IA pour coachs et formateurs', cat: 'Secteur' },
          { href: '/blog/reduire-no-shows-ia', title: 'Réduire les no-shows avec l\'IA : guide pratique tous secteurs', cat: 'Automatisation' },
          { href: '/blog/automatiser-relances-clients', title: 'Automatiser ses relances clients avec l\'IA : le guide complet', cat: 'Automatisation' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Vos membres restent. Vos cours sont pleins.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse votre taux de rétention, votre churn et vos cours sous-remplis pour vous montrer ce que vous récupéreriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #059669);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
