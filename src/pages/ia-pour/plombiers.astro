---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#38bdf8";

const tasks = [
  "Répond aux demandes d'urgence 24h/24 : fuite, coupure d'eau, chaudière en panne",
  "Qualifie les interventions : urgente, planifiable, devis nécessaire",
  "Collecte les infos chantier : type de logement, panne décrite, accès, adresse",
  "Gère la prise de RDV entretien et dépannage non-urgents",
  "Envoie les confirmations et rappels automatiques J-1",
  "Relance les devis non signés à J+2 et J+5",
  "Répond aux questions sur les garanties, délais et tarifs d'intervention",
  "Gère les demandes de contrat d'entretien chaudière annuel",
];

const faqItems = [
  {
    q: "L'agent peut-il gérer les urgences nocturnes (fuite d'eau à 2h du matin) ?",
    a: "C'est le cas d'usage le plus courant. L'agent détecte les urgences (fuite active, coupure eau, inondation) et suit votre protocole : soit il contacte l'astreinte, soit il oriente le client vers un numéro d'urgence défini. Il ne laisse jamais un client en galère sans solution.",
  },
  {
    q: "Comment l'agent différencie une urgence d'un dépannage planifiable ?",
    a: "L'agent pose 3 à 4 questions de qualification : l'eau est-elle coupée ? Y a-t-il des dégâts visibles ? Le logement est-il inhabitable ? Selon les réponses, il classe l'intervention et adapte la réponse : déclenchement astreinte, créneau J+1 ou créneau dans la semaine.",
  },
  {
    q: "Compatible avec les logiciels de gestion (Batigest, MEG, SAGE) ?",
    a: "Oui. L'agent peut s'intégrer à votre agenda via API ou export pour y créer les interventions directement. Pour les devis, il collecte les informations et les envoie au technicien sous forme de fiche structurée — la rédaction du devis reste entre vos mains.",
  },
  {
    q: "L'agent peut-il vendre des contrats d'entretien chaudière ?",
    a: "Oui. L'agent est configuré pour présenter votre offre de contrat d'entretien, envoyer la documentation et collecter les informations du client. Il relance les prospects intéressés à J+3 et J+7 si pas de réponse.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés. On configure l'agent avec vos types d'interventions, vos zones géographiques, vos tarifs de base et vos protocoles d'urgence. Vous validez sur 40 scénarios avant la mise en ligne.",
  },
];
---

<Layout
  title="Agent IA pour plombiers et chauffagistes — Urgences et devis 24h/24 | Vulcia"
  description="Agent IA pour plombier : gestion des urgences 24h/24, qualification pannes, devis et relances automatiques. -60% de temps au téléphone. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Plombiers", "item": "https://vulcia.fr/ia-pour/plombiers" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Plombiers & Chauffagistes</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour plombiers & chauffagistes</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Vos urgences traitées<br/><span class="gradient-text">même à 3h du matin</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Urgences qualifiées, devis collectés, relances automatiques — votre agent IA répond aux clients quand vous êtes sur chantier ou que vous dormez.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "-60%", label: "de temps passé au téléphone dès la première semaine", color },
            { val: "+34%", label: "de devis signés grâce aux relances automatiques J+2 et J+5", color: "#34d399" },
            { val: "0 urgence", label: "perdue la nuit ou le week-end — protocole astreinte automatique", color: "#a78bfa" },
            { val: "7 jours", label: "pour être opérationnel, configuré à vos zones et protocoles", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre entreprise</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Arbre de décision urgence / planifiable</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">L'agent qualifie chaque demande en 3 questions et adapte la réponse automatiquement.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {[
          { label: "Urgence critique", desc: "Fuite active, inondation, gaz, no chauffage en hiver avec enfants ou personnes âgées", action: "Déclenchement immédiat astreinte ou numéro d'urgence défini", color: "#f87171" },
          { label: "Urgence simple", desc: "Panne chaudière sans risque immédiat, WC bouché, robinet qui fuit (récupéré)", action: "Créneau proposé J+1 ou J+2 selon disponibilité réelle", color: "#f59e0b" },
          { label: "Planifiable", desc: "Devis rénovation salle de bain, remplacement chauffe-eau, entretien annuel", action: "Collecte d'infos + fiche devis envoyée au technicien pour chiffrage", color },
        ].map(item => (
          <div class="glass rounded-2xl p-5 border" style={`border-color: ${item.color}30;`}>
            <p class="font-bold text-sm mb-2" style={`color: ${item.color};`}>{item.label}</p>
            <p class="text-[#8888aa] text-xs leading-relaxed mb-3">{item.desc}</p>
            <p class="text-white text-xs font-semibold">{item.action}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Avant / après pour une entreprise de 3 techniciens</h2>
      <div class="glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3">
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-[#8888aa] uppercase tracking-wider">Situation</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-red-400 uppercase tracking-wider text-center">Sans agent</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold uppercase tracking-wider text-center" style={`color: ${color};`}>Avec agent Vulcia</div>
          {[
            ["Urgences nocturnes / week-end", "Appel direct gérant ou perdu", "Protocole astreinte automatique"],
            ["Qualification de la panne", "15 min d'appel + questions répétées", "Fiche structurée en 5 min de chat"],
            ["Devis non signés", "Oubliés après 1 semaine", "Relance auto J+2, J+5, J+10"],
            ["Interruptions chantier", "8-12 appels/jour", "< 3 (urgences et cas complexes)"],
            ["Contrats entretien chaudière", "Vendus verbalement, taux < 10%", "Séquence automatique + taux x2"],
          ].map(([sit, sans, avec]) => (
            <>
              <div class="p-4 border-b border-white/5 text-xs text-white">{sit}</div>
              <div class="p-4 border-b border-white/5 text-xs text-red-400 text-center">{sans}</div>
              <div class="p-4 border-b border-white/5 text-xs text-center font-medium" style={`color: ${color};`}>{avec}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/artisans', title: 'Agent IA pour artisans et BTP — guide complet', cat: 'Secteur' },
          { href: '/blog/agent-ia-devis-artisan', title: 'Agent IA pour devis artisan : automatiser de la demande à la signature', cat: 'Automatisation' },
          { href: '/blog/automatiser-relances-clients', title: 'Automatiser ses relances clients avec l\'IA : le guide complet 2026', cat: 'Automatisation' },
          { href: '/blog/seo-local-ia-pme', title: 'SEO local et IA pour PME : dominer Google Maps en 2026', cat: 'SEO Local' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Plus jamais une urgence sans réponse</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos flux d'appels, vos urgences hors horaires et vos devis perdus pour vous chiffrer ce que vous perdez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #0284c7);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
