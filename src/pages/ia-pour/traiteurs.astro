---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#f59e0b";

const tasks = [
  "Qualifie les demandes d'événements : type (mariage, séminaire, cocktail, repas d'entreprise), nombre de convives, budget, date",
  "Envoie les propositions de formules et relance les prospects à J+5 et J+10 sans réponse",
  "Gère les confirmations de menu et collecte les restrictions alimentaires (14 allergènes réglementaires)",
  "Rappelle les échéances clés : confirmation finale J-30, dernier effectif J-7, solde J-3",
  "Répond aux questions sur les formules, prestations incluses et options disponibles",
  "Collecte les informations logistiques : plan d'accès, horaires de mise en place, coordonnées sur place",
  "Gère le planning des événements et bloque les dates selon votre capacité",
  "Relance les prospects ayant demandé un devis sans donner suite depuis 15 jours",
];

const faqItems = [
  {
    q: "L'agent peut-il créer des menus personnalisés ?",
    a: "Non. La création de menus, l'élaboration des offres gastronomiques et la gestion de la cuisine restent humains. L'agent présente vos formules existantes, collecte les préférences et restrictions alimentaires, et transmet toutes les informations à votre équipe pour la personnalisation.",
  },
  {
    q: "Comment l'agent gère-t-il les allergènes obligatoires ?",
    a: "L'agent intègre un formulaire de collecte des 14 allergènes majeurs réglementaires (règlement UE 1169/2011). Il s'assure que chaque client a bien répondu avant de valider la réservation, et génère un récapitulatif transmis à votre brigade. Aucun événement ne part sans cette information.",
  },
  {
    q: "L'agent peut-il gérer le planning avec plusieurs événements simultanés ?",
    a: "L'agent consulte votre planning et refuse automatiquement les demandes pour des dates déjà bloquées. Pour les événements nécessitant votre validation (capacité logistique, distance, équipe disponible), il les marque comme 'à confirmer' et vous notifie immédiatement.",
  },
  {
    q: "Compatible avec quels logiciels de gestion événementielle ?",
    a: "L'agent s'intègre avec Caterease, eMenu et les outils de gestion événementielle courants. Pour les traiteurs qui gèrent leurs événements sur Google Sheets ou Excel, l'agent s'adapte avec une intégration tableur sans changement de vos habitudes.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés. On configure l'agent avec vos formules, tarifs indicatifs, zones d'intervention, capacités et procédure de réservation. Idéal à déployer en janvier pour être prêt pour la haute saison mariages (mai-octobre).",
  },
];
---

<Layout
  title="Agent IA pour traiteurs et événementiel | Vulcia"
  description="Agent IA pour traiteur : qualification des événements 24h/24, collecte des allergènes, relances prospects, rappels d'échéances mariage et séminaire. +40% de devis traités. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Traiteurs", "item": "https://vulcia.fr/ia-pour/traiteurs" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Traiteurs</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour traiteurs et événementiel</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Vos devis signés.<br/><span class="gradient-text">Votre logistique maîtrisée.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Qualification des événements 24h/24, collecte des allergènes, relances prospects et rappels d'échéances — pendant que vous préparez les menus.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "+40%", label: "de devis traités grâce à la qualification automatique des demandes hors horaires", color },
            { val: "+30%", label: "de taux de signature grâce aux relances J+5 et J+10 automatiques", color: "#34d399" },
            { val: "0 allergène", label: "manquant — collecte obligatoire des 14 allergènes avant chaque événement", color: "#f87171" },
            { val: "7 jours", label: "pour être opérationnel, configuré à vos formules et procédures", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre activité traiteur</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Le calendrier de suivi d'un événement mariage</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">Un mariage se prépare sur 12 à 18 mois. L'agent gère chaque point de contact sans que vous ayez à vous en souvenir.</p>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-3">
        {[
          { step: "J-365 à -180", label: "Devis & réservation", msg: "Qualification, proposition de formules, devis envoyé, relances J+5 et J+10, contrat et acompte.", color },
          { step: "J-90", label: "Planification menu", msg: "Rappel pour confirmer ou ajuster la formule choisie. Envoi du formulaire restrictions alimentaires.", color: "#34d399" },
          { step: "J-30", label: "Confirmation finale", msg: "Validation du menu définitif, demande de confirmation des quantités et options (vin, décoration, etc.).", color: "#38bdf8" },
          { step: "J-7", label: "Effectif final", msg: "Nombre de convives définitif, coordonnées du responsable de la journée, horaires de mise en place.", color: "#a78bfa" },
          { step: "J-3", label: "Solde & logistique", msg: "Rappel du solde à régler, plan d'accès au lieu, vérification de l'accès pour la livraison.", color: "#f59e0b" },
        ].map(item => (
          <div class="glass rounded-2xl p-4">
            <div class="text-xs font-bold mb-1" style={`color: ${item.color};`}>{item.step}</div>
            <p class="text-white font-bold text-sm mb-2">{item.label}</p>
            <p class="text-[#8888aa] text-xs leading-relaxed">{item.msg}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Types d'événements gérés par l'agent</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {[
          { type: "Mariages", icon: "💍", detail: "Suivi 12-18 mois, multiples points de contact, gestion des prestataires" },
          { type: "Séminaires entreprise", icon: "💼", detail: "Qualification rapide, budget corporate, facturation en nom de société" },
          { type: "Cocktails dinatoires", icon: "🥂", detail: "Formule rapide, devis en 48h, allergènes obligatoires" },
          { type: "Anniversaires & fêtes privées", icon: "🎂", detail: "Budget variable, ambiance personnalisée, date souvent en urgence" },
          { type: "Repas de Noël", icon: "🎄", detail: "Pic octobre-novembre, relances préventives dès septembre" },
          { type: "Inaugurations & lancements", icon: "🏢", detail: "Image de marque prioritaire, standing élevé, coordination logistique" },
        ].map(item => (
          <div class="glass rounded-xl p-5">
            <div class="text-2xl mb-3">{item.icon}</div>
            <p class="text-white font-semibold text-sm mb-2">{item.type}</p>
            <p class="text-[#8888aa] text-xs leading-relaxed">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/restaurants', title: 'Agent IA pour restaurants et hôtels — réservations et avis automatisés', cat: 'Secteur' },
          { href: '/blog/automatiser-relances-clients', title: 'Automatiser ses relances clients avec l\'IA : le guide complet', cat: 'Automatisation' },
          { href: '/blog/agent-ia-devis-artisan', title: 'Agent IA pour devis : de la demande à la signature', cat: 'Automatisation' },
          { href: '/blog/reduire-no-shows-ia', title: 'Réduire les no-shows et absences avec l\'IA', cat: 'Automatisation' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Plus de devis signés. Zéro événement manqué.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos taux de signature de devis, vos relances manquées et votre charge administrative pour vous chiffrer ce que vous récupéreriez chaque saison.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #d97706);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
