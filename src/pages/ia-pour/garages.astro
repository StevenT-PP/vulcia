---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#f97316";

const tasks = [
  "Répond aux demandes de devis : type de véhicule, panne, kilométrage, urgence",
  "Gère la prise de rendez-vous entretien et réparation 24h/24",
  "Envoie les confirmations et rappels automatiques J-1",
  "Qualifie les pannes : immobilisé, roulable, urgence ou entretien planifiable",
  "Relance automatiquement les devis non signés à J+2 et J+5",
  "Informe sur les délais d'attente et disponibilité des pièces",
  "Répond aux questions sur les garanties constructeur et extensions",
  "Gère les avis Google et maintient le GBP actif avec des posts hebdomadaires",
];

const faqItems = [
  {
    q: "L'agent peut-il diagnostiquer une panne ?",
    a: "L'agent ne pose pas de diagnostic technique. Il recueille les symptômes décrits par le client (voyant allumé, bruit, comportement du véhicule) et les transmet au mécanicien avec une fiche structurée. Cela vous permet d'évaluer l'urgence et de préparer l'intervention avant même que le véhicule arrive.",
  },
  {
    q: "Compatible avec les logiciels de gestion garage (Autosoft, Winmotor, Digifleet) ?",
    a: "Oui, on s'intègre aux principaux logiciels de gestion garage pour synchroniser les plannings et la disponibilité des créneaux en temps réel. Le client voit uniquement vos vraies disponibilités.",
  },
  {
    q: "Comment gérer les urgences (panne sur route, véhicule immobilisé) ?",
    a: "L'agent détecte les mots-clés d'urgence (véhicule immobilisé, panne sur autoroute, etc.) et bascule vers une procédure d'urgence : numéro direct du garage, dépanneur partenaire si nécessaire. Il ne laisse jamais un client en galère sans orientation.",
  },
  {
    q: "L'agent peut-il envoyer des devis ?",
    a: "L'agent peut envoyer des devis types pour les interventions standardisées (vidange, plaquettes, courroie) avec les fourchettes de prix. Pour les interventions spécifiques, il collecte les infos et prévient le mécanicien pour un devis personnalisé.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés. On configure l'agent avec vos marques maîtrisées, vos tarifs de référence, vos créneaux disponibles et vos règles d'urgence. Vous validez sur 40 scénarios tests avant la mise en ligne.",
  },
];
---

<Layout
  title="Agent IA pour garages automobiles | Vulcia"
  description="Agent IA pour garage : prise de RDV entretien, qualification des pannes, devis automatiques et relances. -50% d'appels entrants, opérationnel en 7 jours. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Garages", "item": "https://vulcia.fr/ia-pour/garages" }
    ]
  })} />

  <Nav />

  <!-- HERO -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Garages</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour garages</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Votre garage prend des RDV<br/><span class="gradient-text">même quand vous êtes sous une voiture</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Devis, prise de rendez-vous, qualification des pannes et relances automatiques — l'agent IA gère les appels et messages pendant que vous travaillez en atelier.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">
              Audit gratuit &rarr;
            </a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">
              Calculer mon ROI
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "-50%", label: "d'appels entrants à gérer manuellement dès la 1ère semaine", color },
            { val: "+34%", label: "de devis signés grâce aux relances automatiques à J+2 et J+5", color: "#34d399" },
            { val: "0 RDV", label: "perdu la nuit ou le week-end — l'agent prend le relais", color: "#a78bfa" },
            { val: "7 jours", label: "pour être opérationnel, connecté à votre logiciel de planning", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- TACHES -->
  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre garage</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AVANT / APRES -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Avant / après pour un garage de 4 mécaniciens</h2>
      <div class="glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3">
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-[#8888aa] uppercase tracking-wider">Situation</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-red-400 uppercase tracking-wider text-center">Sans agent</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold uppercase tracking-wider text-center" style={`color: ${color};`}>Avec agent Vulcia</div>
          {[
            ["RDV hors horaires", "Messagerie non traitée → perdus", "Pris automatiquement, confirmés par SMS"],
            ["Qualification des pannes", "Appel + questions répétitives", "Fiche structurée envoyée au mécanicien"],
            ["Devis non signés", "Oubliés après 1 semaine", "Relance automatique J+2, J+5, J+10"],
            ["Interruptions atelier", "10-15 fois/jour pour appels", "< 3 fois/jour (urgences uniquement)"],
            ["Temps commercial/jour", "1h passée à répondre au téléphone", "10 min sur les cas complexes"],
          ].map(([sit, sans, avec]) => (
            <>
              <div class="p-4 border-b border-white/5 text-xs text-white">{sit}</div>
              <div class="p-4 border-b border-white/5 text-xs text-red-400 text-center">{sans}</div>
              <div class="p-4 border-b border-white/5 text-xs text-center font-medium" style={`color: ${color};`}>{avec}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ARTICLES LIES -->
  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/blog/automatiser-relances-clients', title: 'Automatiser ses relances clients avec l\'IA : le guide complet 2026', cat: 'Automatisation' },
          { href: '/blog/automatiser-prise-rdv', title: 'Comment automatiser sa prise de RDV avec un agent IA (guide complet)', cat: 'Automatisation' },
          { href: '/blog/prix-agent-ia-2026', title: 'Combien coûte un agent IA en 2026 ? Prix, packs et ROI expliqués', cat: 'Tarifs' },
          { href: '/blog/agent-ia-whatsapp', title: 'Agent IA sur WhatsApp Business : guide pratique 2026', cat: 'Automatisation' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Plus jamais un RDV perdu faute de décrocher</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos flux d'appels et messages, et on vous montre combien de clients vous perdez actuellement hors horaires.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #ea580c);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
