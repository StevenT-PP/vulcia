---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#34d399";

const tasks = [
  "Prise de RDV 24h/24 avec précision du motif (dos, cervicales, épaule, nourrisson, grossesse, sport)",
  "Rappels anti no-show J-2 et H-2h avec lien de confirmation ou d'annulation",
  "Gère la liste d'attente et notifie les patients dès qu'un créneau se libère",
  "Collecte les antécédents pertinents avant la première consultation",
  "Relance les patients non revenus depuis 3 mois pour un suivi ou une séance d'entretien",
  "Répond aux questions sur le remboursement mutuelle, le déroulement d'une séance, les contre-indications",
  "Informe les nouveaux patients sur le déroulement de la première consultation et les documents à apporter",
  "Notifie les patients des créneaux libérés en dernière minute",
];

const faqItems = [
  {
    q: "L'agent peut-il donner des avis sur une douleur ou un symptôme ?",
    a: "Non. L'agent ne peut jamais interpréter des symptômes, recommander un traitement ou évaluer si un patient doit venir en urgence. Pour toute question clinique, il redirige vers le praticien ou, en cas d'urgence médicale, vers le 15. L'agent reste strictement dans le champ administratif.",
  },
  {
    q: "Compatible avec Doctolib et les logiciels d'ostéopathie ?",
    a: "L'agent s'intègre avec Doctolib via API pour lire les disponibilités en temps réel et créer les RDV. Pour les ostéopathes sur Maiia, Ordoclic ou les logiciels spécialisés (Omnidoc, Pratique), une intégration via webhook ou export est disponible. Les praticiens sur agenda papier ou Google Calendar sont également pris en charge.",
  },
  {
    q: "Comment gérer les nourrissons et femmes enceintes ?",
    a: "L'agent est configuré avec des créneaux spécifiques par type de patient (nourrisson, grossesse, adulte, sportif). Les consultations nourrisson et grossesse requièrent des informations supplémentaires (âge du bébé, trimestre) collectées automatiquement. Le praticien peut définir le nombre de créneaux réservés à chaque profil.",
  },
  {
    q: "L'agent peut-il informer sur les remboursements mutuelle ?",
    a: "Oui, sur les informations générales. L'agent peut indiquer que l'ostéopathie est remboursée par la plupart des complémentaires santé (en général 2 à 4 séances par an), expliquer ce qu'est une facture de praticien agréé, et indiquer qu'il n'a pas accès aux détails du contrat du patient.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés. Configuration avec vos types de consultations, durées de séance, tarifs indicatifs et informations pratiques sur votre cabinet. L'agent est prêt à prendre des RDV et répondre aux questions dès la mise en ligne.",
  },
];
---

<Layout
  title="Agent IA pour ostéopathes — RDV automatiques et -55% de no-shows | IAForge"
  description="Agent IA pour ostéopathe : prise de RDV 24h/24, rappels no-show, liste d'attente, relances patients inactifs. Compatible Doctolib, Maiia. RGPD conforme. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://iaforge.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://iaforge.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Ostéopathes", "item": "https://iaforge.fr/ia-pour/osteopathes" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Ostéopathes</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour ostéopathes</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Votre agenda plein.<br/><span class="gradient-text">Votre liste d'attente gérée.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Prise de RDV 24h/24, rappels anti no-show, gestion de la liste d'attente et relances patients — pendant que vous pratiquez.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "-55%", label: "de no-shows grâce aux rappels J-2 et H-2h avec confirmation ou annulation", color },
            { val: "+40%", label: "de RDV hors horaires — patients qui prennent RDV le soir ou le week-end", color: "#38bdf8" },
            { val: "0 créneau", label: "perdu — liste d'attente active et notification immédiate en cas d'annulation", color: "#a78bfa" },
            { val: "7 jours", label: "pour être opérationnel, configuré à vos types de consultation et votre agenda", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre cabinet</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Gestion de la liste d'attente : zéro créneau perdu</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">Un ostéopathe avec liste d'attente perd en moyenne 2 à 3 créneaux par semaine faute de remplacement rapide. L'agent élimine cette perte.</p>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        {[
          { step: "Annulation reçue", label: "Créneau libéré", msg: "Un patient annule. Le créneau est immédiatement identifié comme disponible dans le système.", color },
          { step: "< 2 minutes", label: "Notification liste d'attente", msg: "Les 3 premiers patients sur liste d'attente reçoivent une notification avec le créneau disponible.", color: "#38bdf8" },
          { step: "Premier répondant", label: "RDV confirmé", msg: "Le premier patient à confirmer obtient le créneau. Les autres reçoivent un message d'information.", color: "#a78bfa" },
          { step: "Confirmation envoyée", label: "Praticien notifié", msg: "Vous recevez une notification du remplacement. Le créneau n'a jamais été vide.", color: "#fbbf24" },
        ].map(item => (
          <div class="glass rounded-2xl p-5">
            <div class="text-xs font-bold mb-1" style={`color: ${item.color};`}>{item.step}</div>
            <p class="text-white font-bold text-sm mb-2">{item.label}</p>
            <p class="text-[#8888aa] text-xs leading-relaxed">{item.msg}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/kinesitherapeutes', title: 'Agent IA pour kinésithérapeutes — RDV et séries automatisées', cat: 'Secteur' },
          { href: '/ia-pour/psychologues', title: 'Agent IA pour psychologues et thérapeutes', cat: 'Secteur' },
          { href: '/blog/reduire-no-shows-ia', title: 'Réduire les no-shows avec l\'IA : guide pratique', cat: 'Automatisation' },
          { href: '/blog/ia-pour-kinesitherapeute', title: 'IA pour kinésithérapeute : automatiser les RDV', cat: 'Santé' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Votre agenda toujours plein. Zéro créneau perdu.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse votre taux de no-shows, votre liste d'attente et vos créneaux vides pour vous chiffrer ce que vous récupéreriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #059669);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
