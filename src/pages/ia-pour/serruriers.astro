---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#f59e0b";

const tasks = [
  "Répond aux appels d'urgence (serrure bloquée, clé cassée, porte claquée) et évalue la situation à distance",
  "Collecte les informations pour le devis : type de serrure, niveau de sécurité souhaité, urgence ou intervention planifiée",
  "Programme les interventions et confirme les créneaux de passage avec rappel client la veille",
  "Informe sur les obligations légales (devis écrit obligatoire dès 150€, bon d'intervention à signer avant travaux)",
  "Répond aux questions sur les certifications des serrures : A2P niveaux 1/2/3, NF, normes anti-effraction",
  "Gère les demandes de remplacement de cylindres, pose de blindage et installation de serrures connectées",
  "Qualifie les demandes de clients professionnels : copropriétés, commerces, syndics, établissements recevant du public",
  "Relance automatiquement les devis non signés à J+2 et J+7 pour les projets de sécurisation planifiés",
];

const faqItems = [
  {
    q: "L'agent peut-il donner un devis précis par téléphone ou message ?",
    a: "L'agent peut fournir une fourchette tarifaire indicative selon le type d'intervention (ouverture porte standard, remplacement cylindre, pose de blindage), mais précise systématiquement que le devis exact — obligatoire et gratuit pour toute intervention dès 150€ — est remis par le technicien sur place. L'agent ne contractualise jamais un tarif sans intervention préalable.",
  },
  {
    q: "Comment l'agent gère-t-il les urgences la nuit ou le week-end ?",
    a: "L'agent est disponible 24h/24. Pour les urgences (porte bloquée, effraction), il collecte l'adresse et le problème, estime le temps d'intervention selon votre planning de garde, et vous notifie immédiatement. Il précise au client le supplément d'urgence nuit/week-end conformément à la réglementation, évitant toute mauvaise surprise.",
  },
  {
    q: "L'agent informe-t-il les clients sur leurs droits face aux serruriers peu scrupuleux ?",
    a: "Oui — et c'est un argument de confiance fort. L'agent rappelle que le devis écrit est obligatoire avant tout travail, que le client doit signer un bon d'intervention, que les prix affichés doivent inclure la TVA, et que tout litige peut être signalé à la DGCCRF. En vous positionnant comme serrurier transparent et certifié, vous vous différenciez des arnaques.",
  },
  {
    q: "L'agent peut-il gérer les demandes de syndics et copropriétés ?",
    a: "Oui. L'agent gère les demandes professionnelles avec un formulaire dédié : nom du syndic, adresse de l'immeuble, nature des travaux (remplacement de serrures sur parties communes, badgeage, interphonie), délai souhaité et interlocuteur. Il peut envoyer les devis par email au format PDF si vous utilisez un outil compatible.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "5 à 7 jours ouvrés pour un agent avec FAQ, gestion des urgences, prise de contact et devis. L'agent est configuré avec votre zone d'intervention, vos spécialités (résidentiel, professionnel, connecté) et vos tarifs indicatifs. 0€ d'installation, sans engagement.",
  },
];
---

<Layout
  title="Agent IA pour serruriers — Urgences qualifiées, devis réglementaires et clients rassurés | Vulcia"
  description="Agent IA pour serrurier : qualification des urgences 24h/24, information sur les obligations légales (devis obligatoire dès 150€), relance devis, gestion clients pro. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Serruriers", "item": "https://vulcia.fr/ia-pour/serruriers" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Serruriers</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour serruriers et dépanneurs</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Urgences qualifiées.<br/><span class="gradient-text">Clients rassurés avant votre arrivée.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Qualification des urgences 24h/24, information sur les droits des clients, devis réglementaires expliqués et relances automatiques — le serrurier de confiance face aux arnaques.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "+40%", label: "de devis signés grâce aux relances automatiques à J+2 et J+7 sur les projets planifiés", color },
            { val: "-55%", label: "de temps perdu à qualifier les demandes pendant les interventions", color: "#38bdf8" },
            { val: "+30%", label: "de confiance client grâce à la transparence sur la réglementation devis dès le premier contact", color: "#34d399" },
            { val: "5 jours", label: "pour être opérationnel avec vos spécialités, zone d'intervention et tarifs indicatifs", color: "#a78bfa" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre activité de serrurerie</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Urgence vs. intervention planifiée : deux parcours distincts</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">L'agent adapte sa réponse selon le niveau d'urgence pour maximiser la conversion et la satisfaction.</p>
      <div class="not-prose my-6 grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          {
            titre: "Urgence (porte bloquée, effraction)",
            steps: [
              "1. Confirmation de la situation (bloqué dehors, intérieur sécurisé ?)",
              "2. Vérification que la porte n'est pas simplement verrouillée de l'intérieur",
              "3. Estimation du délai d'intervention selon votre planning",
              "4. Information sur le supplément nuit/week-end",
              "5. Collecte de l'adresse exacte et du numéro de téléphone",
              "6. Notification immédiate à votre équipe",
            ],
            color,
          },
          {
            titre: "Projet planifié (blindage, serrure connectée)",
            steps: [
              "1. Qualification du projet (type de porte, niveau de sécurité souhaité)",
              "2. Information sur les certifications A2P et leur impact sur l'assurance",
              "3. Prise de RDV pour visite de diagnostic ou devis sur site",
              "4. Envoi de documentation sur les produits recommandés",
              "5. Confirmation du devis par email après intervention",
              "6. Relance automatique à J+2 et J+7 si pas de retour",
            ],
            color: "#38bdf8",
          },
        ].map(col => (
          <div class="glass rounded-2xl p-6">
            <p class="text-sm font-bold mb-4" style={`color: ${col.color};`}>{col.titre}</p>
            <div class="space-y-2">
              {col.steps.map(step => (
                <div class="flex items-start gap-2">
                  <div class="w-1.5 h-1.5 rounded-full flex-shrink-0 mt-2" style={`background: ${col.color};`}></div>
                  <p class="text-[#8888aa] text-xs leading-relaxed">{step}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/artisans', title: 'IA pour artisans BTP : devis automatisés et urgences gérées', cat: 'Secteur' },
          { href: '/ia-pour/plombiers', title: 'IA pour plombiers et chauffagistes', cat: 'Secteur' },
          { href: '/blog/agent-ia-devis-artisan', title: 'Agent IA pour devis artisan : guide complet', cat: 'Guide' },
          { href: '/blog/chatbot-site-web-2026', title: 'Chatbot IA pour site web : comment ça marche', cat: 'Guide' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#f59e0b] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Vous en intervention. L'agent à la permanence.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos demandes manquées pendant les interventions, vos devis non relancés et votre potentiel de clients professionnels pour vous chiffrer ce que vous récupéreriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #d97706);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 5 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
