---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#f59e0b";

const tasks = [
  "Répond aux demandes d'information sur les modèles disponibles, équipements et prix 24h/24",
  "Qualifie les prospects : neuf ou occasion, budget, reprise ou non, délai d'achat",
  "Programme les essais routiers et les rendez-vous de reprise avec les conseillers commerciaux",
  "Relance automatiquement les prospects ayant demandé un devis sans donner suite",
  "Informe sur les offres de financement disponibles (LOA, LLD, crédit classique) sans donner de conseil financier",
  "Gère les prises de RDV pour l'entretien et les rappels de révision périodique",
  "Notifie les clients à J-7 et J-1 avant un rendez-vous atelier",
  "Collecte les avis Google après chaque livraison de véhicule et chaque intervention atelier",
];

const faqItems = [
  {
    q: "L'agent peut-il accéder au stock de véhicules disponibles en temps réel ?",
    a: "Oui, si votre DMS (Dealer Management System) expose les données stock via une API ou un export automatisé. Les principaux DMS du marché (CDK, REY, IER Auto) le permettent. L'agent peut alors répondre en temps réel : \"Nous avons 3 [modèle] disponibles : une grise boîte auto à 28 000€ et deux bleues à partir de 25 500€.\"",
  },
  {
    q: "L'agent peut-il faire une estimation de reprise ?",
    a: "L'agent peut collecter les informations du véhicule à reprendre (marque, modèle, année, kilométrage, état général) et indiquer une fourchette indicative basée sur les cotes de marché (Argus, La Centrale). L'estimation précise reste faite par un conseiller — l'agent prépare le dossier.",
  },
  {
    q: "Comment gérer la qualification entre neuf et occasion, achat comptant et financement ?",
    a: "L'agent pose 3-4 questions de qualification dès le premier contact : budget total, préférence neuf/occasion, besoin de financement, délai d'achat. Cette qualification permet de diriger automatiquement vers le bon conseiller et de préparer l'entretien.",
  },
  {
    q: "L'agent peut-il communiquer sur les offres constructeur du moment ?",
    a: "Oui. Votre base de connaissance est mise à jour chaque mois avec les nouvelles offres (bonus, LOA attractives, séries limitées). L'agent présente les offres en cours et redirige vers le conseiller pour les détails et la simulation financière.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés pour un agent avec FAQ véhicules, prise de RDV essai et entretien. Pour l'intégration avec votre DMS (stock en temps réel), prévoir 14-21 jours selon votre logiciel.",
  },
];
---

<Layout
  title="Agent IA pour concessionnaires automobiles — Prospects qualifiés et RDV essai automatisés | Vulcia"
  description="Agent IA pour concession auto : qualification prospects, prise de RDV essai et atelier, relances devis et stock en temps réel — pendant que vos conseillers vendent. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Concessionnaires automobiles", "item": "https://vulcia.fr/ia-pour/concessionnaires" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Concessionnaires automobiles</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour concessions automobiles</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Prospects qualifiés.<br/><span class="gradient-text">Conseillers concentrés sur la vente.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Qualification neuf/occasion/financement, prise de RDV essai, relances devis et gestion atelier — l'agent traite le flux entrant 24h/24 pour que vos commerciaux ne voient que des acheteurs prêts.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "+35%", label: "de RDV essai programmés grâce à la prise de contact immédiate 24h/24", color },
            { val: "+25%", label: "de taux de closing sur les devis relancés à J+3 et J+7", color: "#34d399" },
            { val: "-50%", label: "du temps des conseillers sur les appels entrants non qualifiés", color: "#38bdf8" },
            { val: "14 jours", label: "pour intégrer votre stock DMS et afficher les véhicules disponibles", color: "#a78bfa" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre concession</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Qualification prospect : les 5 questions clés</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">En 2-3 minutes de conversation, l'agent sait si le prospect est prêt à acheter — et lequel de vos conseillers doit le rappeler.</p>
      <div class="not-prose my-6 space-y-3">
        {[
          { q: "Neuf ou occasion ?", logique: "Oriente vers le bon catalogue et le bon conseiller. Un acheteur d'occasion a des critères différents (kilométrage, garantie, âge du véhicule).", color },
          { q: "Quel est votre budget ?", logique: "Fourchette large ou précise — permet de présenter les véhicules pertinents et d'anticiper la discussion financement.", color: "#34d399" },
          { q: "Avez-vous un véhicule à reprendre ?", logique: "Une reprise implique un processus commercial différent : estimation, contre-visite, négociation globale. Prépare le conseiller en amont.", color: "#38bdf8" },
          { q: "Financement ou comptant ?", logique: "Oriente vers les offres LOA/LLD du moment si financement souhaité — et identifie si le prospect est éligible.", color: "#a78bfa" },
          { q: "Dans quel délai pensez-vous acheter ?", logique: "Distingue l'acheteur immédiat (RDV essai cette semaine) du projet à 6 mois (nurturing). Permet de prioriser les relances.", color: "#fbbf24" },
        ].map(item => (
          <div class="glass rounded-xl p-4 flex gap-4">
            <div class="flex-shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={item.color} stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <div>
              <p class="text-white font-semibold text-sm mb-1">"{item.q}"</p>
              <p class="text-[#8888aa] text-xs leading-relaxed">{item.logique}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Compatibilité avec les principaux DMS</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">L'intégration avec votre logiciel de gestion permet à l'agent de consulter le stock en temps réel et de créer des RDV directement.</p>
      <div class="not-prose my-6 glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-4">
          {["DMS", "Type d'intégration", "Données accessibles", "Délai"].map(h => (
            <div class="p-3 border-b border-white/5 text-xs font-bold text-[#8888aa] uppercase tracking-wider">{h}</div>
          ))}
          {[
            ["CDK Drive", "API native", "Stock VN/VO, prix, équipements, RDV atelier", "2-3 semaines"],
            ["REY (DL Sofware)", "API ou export", "Stock, commandes, clients", "2-3 semaines"],
            ["IER Auto", "Webhook", "Stock en temps réel, disponibilité essai", "2-3 semaines"],
            ["PBS Software", "API", "Stock, dossiers clients, atelier", "3-4 semaines"],
            ["Google Calendar", "API native", "Disponibilités conseillers pour essai", "2 jours"],
          ].map(([d, t, données, délai]) => (
            <>
              <div class="p-3 border-b border-white/5 text-xs text-white font-medium">{d}</div>
              <div class="p-3 border-b border-white/5 text-xs text-[#8888aa]">{t}</div>
              <div class="p-3 border-b border-white/5 text-xs text-[#8888aa]">{données}</div>
              <div class="p-3 border-b border-white/5 text-xs text-[#f59e0b]">{délai}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/blog/automatiser-relances-clients', title: 'Automatiser ses relances clients avec l\'IA', cat: 'Automatisation' },
          { href: '/blog/crm-ia-pme', title: 'CRM et IA pour PME : le duo gagnant', cat: 'CRM' },
          { href: '/ia-pour/garages', title: 'IA pour garages automobiles', cat: 'Secteur' },
          { href: '/blog/ia-integration-api', title: 'Intégrer son agent IA avec son logiciel métier', cat: 'Technique' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#f59e0b] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Vos conseillers sur le plancher. L'agent au téléphone.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos demandes entrantes, vos devis sans suite et vos RDV manqués pour vous chiffrer ce que vous récupéreriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #d97706);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
