---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#fbbf24";

const tasks = [
  "Reçoit les demandes de dépannage électrique 24h/24 et qualifie l'urgence",
  "Collecte les informations chantier : type de logement, puissance, accès, adresse",
  "Gère la prise de RDV pour les diagnostics et mise aux normes",
  "Envoie les confirmations et rappels automatiques J-1",
  "Relance les devis non signés à J+2, J+5 et J+10",
  "Répond aux questions sur les normes NF C 15-100, tableau électrique, CONSUEL",
  "Gère les demandes de mise aux normes pour vente immobilière",
  "Qualifie les projets de borne de recharge IRVE et photovoltaïque",
];

const faqItems = [
  {
    q: "L'agent peut-il gérer les coupures d'électricité d'urgence ?",
    a: "Oui. L'agent détecte les urgences (coupure totale, court-circuit, odeur de brûlé, risque électrocution) et suit votre protocole : contact astreinte, numéro d'urgence ou instruction de couper le disjoncteur général. Il ne laisse jamais un client sans solution de mise en sécurité immédiate.",
  },
  {
    q: "Peut-il traiter les demandes de certification CONSUEL ?",
    a: "L'agent explique la procédure CONSUEL, collecte les informations nécessaires (type d'installation, surface, date des travaux) et prépare la fiche pour votre technicien. Il relance automatiquement les clients qui n'ont pas encore programmé la visite de conformité.",
  },
  {
    q: "Compatible avec les logiciels de gestion (Batigest, EBP, Batappli) ?",
    a: "Oui. L'agent peut s'intégrer à votre agenda via API pour créer les interventions directement. Il collecte les informations de chaque demande sous forme de fiche structurée envoyée à votre équipe — le technicien arrive avec tout le contexte.",
  },
  {
    q: "L'agent peut-il qualifier les projets IRVE (bornes de recharge) ?",
    a: "C'est l'un des cas d'usage les plus rentables. L'agent qualifie le type de logement (maison/copropriété), la puissance disponible, le nombre de véhicules, l'éligibilité aux aides (TVA réduite, prime ADVENIR). Il prépare une fiche de pré-chiffrage complète.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés. On configure l'agent avec vos types d'interventions, vos zones géographiques, vos tarifs de base et vos protocoles d'urgence. Vous validez sur 40 scénarios avant la mise en ligne.",
  },
];
---

<Layout
  title="Agent IA pour électriciens — Urgences, devis et IRVE 24h/24 | Vulcia"
  description="Agent IA pour électricien : gestion des urgences 24h/24, qualification des chantiers, devis IRVE et photovoltaïque, relances automatiques. -60% de temps au téléphone. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Électriciens", "item": "https://vulcia.fr/ia-pour/electriciens" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Électriciens</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour électriciens</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Vos chantiers qualifiés<br/><span class="gradient-text">même quand vous câblez</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Urgences détectées, devis pré-remplis, relances automatiques — votre agent IA gère les demandes pendant que vous êtes sur chantier ou en intervention.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "-60%", label: "de temps passé au téléphone dès la première semaine", color },
            { val: "+34%", label: "de devis signés grâce aux relances automatiques J+2 et J+5", color: "#34d399" },
            { val: "0 urgence", label: "perdue la nuit ou le week-end — protocole de mise en sécurité automatique", color: "#a78bfa" },
            { val: "7 jours", label: "pour être opérationnel, configuré à vos interventions et zones", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre entreprise</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Les 3 types d'intervention qualifiés automatiquement</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">L'agent adapte la réponse selon l'urgence et le type de chantier.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {[
          { label: "Urgence électrique", desc: "Coupure totale, court-circuit, odeur de brûlé, prise qui chauffe, risque électrocution", action: "Mise en sécurité immédiate + contact astreinte selon protocole défini", color: "#f87171" },
          { label: "Dépannage planifiable", desc: "Prise hors service, interrupteur défaillant, disjoncteur qui saute régulièrement", action: "RDV proposé J+1 ou J+2 avec collecte des infos chantier complètes", color },
          { label: "Projet & mise aux normes", desc: "Mise aux normes tableau NF C 15-100, IRVE, photovoltaïque, rénovation complète", action: "Fiche de pré-qualification envoyée au technicien pour chiffrage précis", color: "#34d399" },
        ].map(item => (
          <div class="glass rounded-2xl p-5 border" style={`border-color: ${item.color}30;`}>
            <p class="font-bold text-sm mb-2" style={`color: ${item.color};`}>{item.label}</p>
            <p class="text-[#8888aa] text-xs leading-relaxed mb-3">{item.desc}</p>
            <p class="text-white text-xs font-semibold">{item.action}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">IRVE et photovoltaïque : le module de qualification projets</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">Ces deux marchés explosent. L'agent qualifie les prospects automatiquement pour que vous ne perdiez aucune opportunité.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          {
            titre: "Bornes de recharge IRVE",
            color: "#38bdf8",
            questions: [
              "Type de logement (maison, appartement, copropriété)",
              "Puissance du compteur disponible",
              "Nombre de véhicules électriques",
              "Éligibilité prime ADVENIR et TVA 5,5%",
              "Accès au parking et longueur du câblage",
            ],
          },
          {
            titre: "Installation photovoltaïque",
            color: color,
            questions: [
              "Surface de toiture disponible et orientation",
              "Consommation annuelle en kWh",
              "Type de raccordement (autoconsommation / revente)",
              "Éligibilité MaPrimeRénov' et TVA réduite",
              "Présence d'un système de stockage (batterie)",
            ],
          },
        ].map(item => (
          <div class="glass rounded-2xl p-6">
            <p class="font-bold text-base mb-4" style={`color: ${item.color};`}>{item.titre}</p>
            <div class="space-y-2">
              {item.questions.map(q => (
                <div class="flex items-start gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={item.color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
                  <p class="text-[#8888aa] text-xs">{q}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Avant / après pour une entreprise de 4 électriciens</h2>
      <div class="glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3">
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-[#8888aa] uppercase tracking-wider">Situation</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-red-400 uppercase tracking-wider text-center">Sans agent</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold uppercase tracking-wider text-center" style={`color: ${color};`}>Avec agent Vulcia</div>
          {[
            ["Demandes hors horaires", "Message sur répondeur — 40% sans rappel", "Réponse immédiate + qualification complète"],
            ["Qualification chantier", "20 min d'appel + va-et-vient", "Fiche structurée en 8 min de chat"],
            ["Devis non signés", "Oubliés après 1 semaine", "Relance auto J+2, J+5, J+10"],
            ["Projets IRVE", "Pré-qualification manuelle 30 min", "Fiche complète en 10 min automatique"],
            ["Interruptions chantier", "10-15 appels/jour sur le chef", "< 3 (urgences et cas complexes)"],
          ].map(([sit, sans, avec]) => (
            <>
              <div class="p-4 border-b border-white/5 text-xs text-white">{sit}</div>
              <div class="p-4 border-b border-white/5 text-xs text-red-400 text-center">{sans}</div>
              <div class="p-4 border-b border-white/5 text-xs text-center font-medium" style={`color: ${color};`}>{avec}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/artisans', title: 'Agent IA pour artisans et BTP — guide complet', cat: 'Secteur' },
          { href: '/ia-pour/plombiers', title: 'Agent IA pour plombiers et chauffagistes', cat: 'Secteur' },
          { href: '/blog/agent-ia-devis-artisan', title: 'Agent IA pour devis artisan : automatiser de la demande à la signature', cat: 'Automatisation' },
          { href: '/blog/automatiser-relances-clients', title: 'Automatiser ses relances clients avec l\'IA : le guide complet 2026', cat: 'Automatisation' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Plus jamais un chantier perdu faute de réponse</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos flux d'appels, vos urgences hors horaires et vos devis perdus pour vous chiffrer ce que vous perdez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #d97706);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
