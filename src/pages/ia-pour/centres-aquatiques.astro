---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#38bdf8";

const tasks = [
  "Répond aux questions sur les horaires de piscine, bassin disponible et tarifs 24h/24",
  "Informe sur le planning des cours de natation, aquagym, aquabike et bébés nageurs",
  "Inscrit les adhérents aux cours et activités et envoie les confirmations automatiquement",
  "Rappelle les séances à J-1 pour réduire les absences et optimiser le remplissage",
  "Gère les abonnements : renouvellements, suspension temporaire, changement de formule",
  "Informe sur les règles d'accès (bonnet obligatoire, niveaux requis par bassin, normes sécurité)",
  "Collecte les demandes de cours particuliers de natation et les transmet aux maîtres-nageurs",
  "Notifie les adhérents en cas de fermeture exceptionnelle, maintenance ou modification de planning",
];

const faqItems = [
  {
    q: "L'agent peut-il accéder aux inscriptions en temps réel pour éviter les surréservations ?",
    a: "Oui, si votre logiciel de gestion (Natation.com, Elloha, ou logiciel municipal) expose une API. L'agent vérifie les places disponibles avant de confirmer une inscription et met à jour le compteur en temps réel. Plus de doublons ni de surbooking sur les cours.",
  },
  {
    q: "Comment gérer les différents publics (adultes, enfants, bébés nageurs, séniors) ?",
    a: "L'agent est configuré pour chaque public avec les règles spécifiques : âge minimum pour les bébés nageurs (4-5 mois selon les cours), niveaux requis pour les cours adultes, conditions d'accompagnement pour les enfants. Il oriente chaque demande vers le bon cours selon le profil.",
  },
  {
    q: "L'agent peut-il informer sur les règles de sécurité et le règlement intérieur ?",
    a: "Oui, l'agent connaît votre règlement intérieur complet : port du bonnet obligatoire, type de maillot autorisé (pas de short de bain), règles par bassin (petit bain, grand bain, plongeoir), présence obligatoire d'un adulte pour les enfants, etc.",
  },
  {
    q: "Compatible avec les structures publiques (mairies, communautés de communes) ?",
    a: "Oui. Le déploiement respecte les exigences du secteur public : transparence sur l'IA (mention légale obligatoire depuis l'EU AI Act 2025), accessibilité RGAA, hébergement des données en France, conformité RGPD avec PIA documentée.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés pour un agent avec horaires, tarifs, planning et FAQ. Pour l'intégration avec votre logiciel de gestion (inscriptions en temps réel), prévoir 14-21 jours selon votre système.",
  },
];
---

<Layout
  title="Agent IA pour piscines et centres aquatiques | Vulcia"
  description="Agent IA pour piscine et centre aquatique : inscriptions aux cours, horaires, planning aquagym et notifications fermeture — réduction des appels de 50%. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Piscines & Centres aquatiques", "item": "https://vulcia.fr/ia-pour/centres-aquatiques" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Piscines & Centres aquatiques</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour piscines et centres aquatiques</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Cours remplis.<br/><span class="gradient-text">Maîtres-nageurs concentrés.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Horaires, planning cours, inscriptions, règlement intérieur et notifications fermeture — l'agent répond aux 80% de questions répétitives pour que votre équipe se concentre sur la sécurité et la pédagogie.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "-50%", label: "d'appels entrants pour les horaires, tarifs et questions de planning", color },
            { val: "+30%", label: "de taux de renouvellement d'abonnement grâce aux rappels automatiques", color: "#34d399" },
            { val: "-35%", label: "d'absences aux cours grâce aux rappels de séance J-1", color: "#fbbf24" },
            { val: "7 jours", label: "pour être opérationnel avec votre planning, tarifs et règlement intérieur", color: "#a78bfa" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre structure</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Les questions posées 50x par jour — toutes résolues par l'agent</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">Ce ne sont pas de mauvaises questions. Ce sont des questions répétitives qui consomment du temps humain pour rien.</p>
      <div class="not-prose my-6 grid grid-cols-1 md:grid-cols-2 gap-3">
        {[
          "\"À quelle heure ouvre la piscine le samedi matin ?\"",
          "\"Est-ce qu'il y a encore des places dans le cours aquagym du mardi 19h ?\"",
          "\"Mon enfant a 4 ans, il peut participer aux cours bébés nageurs ?\"",
          "\"Quel est le tarif abonnement mensuel adulte ?\"",
          "\"La piscine est-elle ouverte pendant les vacances scolaires ?\"",
          "\"Est-ce que le bonnet de bain est obligatoire pour les adultes aussi ?\"",
          "\"Comment je peux suspendre mon abonnement pendant mes vacances ?\"",
          "\"Y a-t-il un cours le lundi matin pour les seniors ?\"",
        ].map(q => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <p class="text-[#8888aa] text-sm italic">{q}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/salles-sport', title: 'IA pour salles de sport : inscriptions et rétention membres', cat: 'Secteur' },
          { href: '/ia-pour/studios-yoga', title: 'IA pour studios yoga et bien-être : cours toujours pleins', cat: 'Secteur' },
          { href: '/blog/agent-ia-secteur-public', title: 'Agent IA pour le secteur public et les collectivités', cat: 'Agents IA' },
          { href: '/blog/reduire-no-shows-ia', title: 'Réduire les absences avec l\'IA : méthode et résultats', cat: 'Automatisation' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#38bdf8] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Votre équipe dans l'eau. L'agent à l'accueil.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos appels entrants, vos absences aux cours et vos renouvellements d'abonnement manqués pour vous chiffrer ce que vous récupéreriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #0284c7);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
