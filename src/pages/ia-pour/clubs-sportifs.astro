---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#f97316";

const tasks = [
  "Répond aux questions sur les inscriptions, tarifs, niveaux et horaires d'entraînement 24h/24",
  "Qualifie les nouvelles inscriptions : âge, niveau, discipline souhaitée, disponibilités",
  "Traite les demandes d'essai gratuit et programme les séances d'évaluation",
  "Rappelle les séances d'entraînement et les matchs à venir aux membres",
  "Gère les renouvellements d'adhésion et rappelle les membres dont le statut expire",
  "Notifie les changements de planning, annulations d'entraînement et horaires spéciaux",
  "Informe sur les compétitions, tournois et événements du club",
  "Collecte les demandes de parrainage et de sponsoring entreprise",
];

const faqItems = [
  {
    q: "L'agent peut-il gérer les inscriptions pour différentes sections (football, tennis, natation) ?",
    a: "Oui. L'agent peut gérer plusieurs sections avec des processus d'inscription différents. Il oriente chaque prospect vers la bonne section selon l'âge, le niveau et la discipline souhaitée, et peut simultanément gérer les inscriptions foot U10, tennis adulte loisir et natation compétition — chacune avec ses propres critères.",
  },
  {
    q: "L'agent peut-il accéder au planning d'entraînement en temps réel ?",
    a: "Oui, si votre club utilise un outil de gestion (ClubPro, Sportigo, Kclub, ou Google Calendar). L'agent consulte les plannings et répond aux questions de disponibilité en temps réel. Pour les modifications de dernière minute (terrain indisponible, éducateur absent), il notifie automatiquement les membres concernés.",
  },
  {
    q: "Comment gérer les périodes de réinscription annuelle ?",
    a: "L'agent gère les campagnes de réinscription : rappel aux membres 2 mois avant l'échéance, relance à 1 mois, notification de clôture des inscriptions. Pour les nouvelles inscriptions en période creuse, l'agent peut déclencher des offres spéciales (essai gratuit, tarif réduit 1er mois).",
  },
  {
    q: "L'agent peut-il gérer les demandes de parrainage entreprise ?",
    a: "Oui. L'agent collecte les demandes de sponsoring (raison sociale, secteur d'activité, budget indicatif, objectifs de visibilité) et les transmet au bureau du club. Il peut aussi informer les entreprises sur les formules de partenariat disponibles.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés pour un agent avec FAQ, inscriptions et informations de base sur le club. Pour l'intégration avec votre logiciel de gestion de club et les notifications de planning en temps réel, prévoir 14 jours.",
  },
];
---

<Layout
  title="Agent IA pour clubs sportifs — Inscriptions, planning et membres automatisés | IAForge"
  description="Agent IA pour club sportif : inscriptions 24h/24, rappels d'entraînement, notifications changement de planning, renouvellements d'adhésion et demandes de sponsoring. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://iaforge.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://iaforge.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Clubs sportifs", "item": "https://iaforge.fr/ia-pour/clubs-sportifs" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Clubs sportifs</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour clubs sportifs</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Membres engagés.<br/><span class="gradient-text">Dirigeants concentrés sur le sport.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Inscriptions, rappels d'entraînement, notifications de planning, renouvellements d'adhésion — l'agent gère tout le flux administratif pour que vos bénévoles se concentrent sur la formation sportive.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "+40%", label: "de taux de conversion des demandes d'essai en inscriptions effectives", color },
            { val: "+25%", label: "de taux de renouvellement grâce aux rappels automatiques d'adhésion", color: "#34d399" },
            { val: "-60%", label: "du temps bénévole consacré à répondre aux emails et messages Facebook", color: "#38bdf8" },
            { val: "7 jours", label: "pour être opérationnel avec vos inscriptions, planning et FAQ club", color: "#a78bfa" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre club</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Calendrier de la saison sportive automatisé</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">De la réinscription de septembre à la clôture de saison en juin — l'agent gère chaque étape sans mobiliser vos bénévoles.</p>
      <div class="not-prose my-6 glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3">
          {["Période", "Action automatisée", "Bénéfice"].map(h => (
            <div class="p-3 border-b border-white/5 text-xs font-bold text-[#8888aa] uppercase tracking-wider">{h}</div>
          ))}
          {[
            ["Août-Septembre", "Campagne réinscriptions + inscriptions nouveaux membres", "+25% de membres réinscrits avant la reprise"],
            ["Octobre", "Rappels licences fédérales à renouveler", "0 membre qui joue sans licence"],
            ["Novembre-Décembre", "Demandes de sponsoring pour la saison", "+40% de partenaires entreprises contactés"],
            ["Janvier", "Inscriptions mi-saison (nouveaux arrivants)", "Zéro demande sans réponse"],
            ["Avril-Mai", "Rappels clôture de saison et assemblée générale", "+30% de présents à l'AG"],
            ["Juin", "Questionnaire satisfaction membres et parents", "Feedback structuré pour améliorer la saison suivante"],
          ].map(([p, a, b]) => (
            <>
              <div class="p-3 border-b border-white/5 text-xs text-white font-medium">{p}</div>
              <div class="p-3 border-b border-white/5 text-xs text-[#8888aa]">{a}</div>
              <div class="p-3 border-b border-white/5 text-xs text-[#f97316]">{b}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/salles-sport', title: 'IA pour salles de sport : inscriptions et rétention', cat: 'Secteur' },
          { href: '/ia-pour/studios-yoga', title: 'IA pour studios yoga et bien-être', cat: 'Secteur' },
          { href: '/blog/ia-pour-association', title: 'IA pour associations : gérer les membres et les bénévoles', cat: 'Guide' },
          { href: '/blog/agent-ia-multicanal', title: 'Agent IA multicanal : email, WhatsApp, chat et SMS', cat: 'Agents IA' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#f97316] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Vos bénévoles sur le terrain. L'agent à l'accueil.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos demandes d'inscription sans suite, vos abandons de membres et votre taux de renouvellement pour vous chiffrer ce que vous récupéreriez chaque saison.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #ea580c);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
