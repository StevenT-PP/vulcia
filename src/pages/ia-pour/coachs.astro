---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const tasks = [
  "Répond aux questions sur votre programme, vos prérequis et vos résultats",
  "Qualifie les candidats avant l'entretien de vente (motivation, budget, délai)",
  "Envoie le programme détaillé et les témoignages selon le profil du prospect",
  "Gère les inscriptions et envoie automatiquement les accès à la formation",
  "Envoie les supports pédagogiques et rappels de session automatiquement",
  "Relance les prospects qui n'ont pas finalisé leur inscription",
  "Répond aux questions des élèves en cours de formation (logistique, accès)",
  "Collecte les témoignages après la formation avec relance automatique",
];

const faqItems = [
  {
    q: "L'agent peut-il gérer les ventes de formations sans entretien téléphonique ?",
    a: "Pour les formations à prix bas ou moyen (< 500€), oui — l'agent qualifie, envoie les informations et dirige vers la page de paiement. Pour les programmes premium (coaching sur-mesure, mastermind, > 1 000€), l'agent filtre et qualifie avant de planifier votre entretien de vente, rendant celui-ci beaucoup plus efficace.",
  },
  {
    q: "Compatible avec ma plateforme de formation (Kajabi, Teachable, Podia…) ?",
    a: "Oui. On se connecte à votre plateforme via API ou Zapier pour déclencher les accès automatiquement après paiement, envoyer les modules progressivement, et tracker l'avancement de vos élèves.",
  },
  {
    q: "Peut-il créer un sentiment de communauté et d'accompagnement ?",
    a: "L'agent est configuré avec votre voix, vos expressions, votre énergie. Il répond comme vous le feriez — avec enthousiasme, empathie et précision. Vos élèves ont l'impression d'avoir accès à vous à toute heure, sans que vous soyez réellement disponible.",
  },
  {
    q: "Fonctionne-t-il pour les webinaires et les lancements ?",
    a: "Oui. Pendant un lancement ou un webinaire, l'agent gère les inscriptions, répond aux questions en temps réel dans le chat, relance les non-inscrits et traite les objections courantes (\"C'est trop cher\", \"Je n'ai pas le temps\") avec vos réponses habituelles.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours pour un solopreneur. On configure l'agent avec votre programme, vos FAQ, votre style de communication, vos tarifs et votre processus d'inscription. Vous validez sur 20 scénarios types, puis on met en ligne.",
  },
];
---

<Layout
  title="Agent IA pour coachs et formateurs | Vulcia"
  description="Agent IA pour coachs et formateurs : qualifiez vos prospects, automatisez les inscriptions, relancez pendant les lancements. +3 000€/mois de CA additionnel. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />

  <Nav />

  <!-- HERO -->
  <section class="pt-32 pb-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div style="position:absolute;width:600px;height:500px;top:-5%;left:-5%;background:radial-gradient(circle,rgba(251,191,36,0.1),transparent 70%);filter:blur(80px);"></div>
    </div>
    <div class="max-w-4xl mx-auto relative">
      <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-8">
        <a href="/" class="hover:text-white transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-white">Agent IA pour coachs</span>
      </nav>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block text-xs font-bold uppercase tracking-widest mb-4 px-3 py-1 rounded-full" style="color: #fbbf24; background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.2);">Coaching & Formation</span>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Vos formations se vendent<br/><span style="color: #fbbf24;">pendant que vous<br/>êtes en séance.</span>
          </h1>
          <p class="text-[#8888aa] leading-relaxed mb-8">
            Un agent IA qui qualifie vos prospects, envoie votre programme et gère les inscriptions — à votre place, à votre façon, 24h/24.
          </p>
          <div class="flex flex-wrap gap-3 mb-8">
            {[
              { v: "+3k€", l: "CA/mois moyen" },
              { v: "×3", l: "taux de conversion" },
              { v: "0h", l: "admin. inscriptions" },
            ].map(s => (
              <div class="glass rounded-xl px-4 py-3 text-center">
                <p class="text-2xl font-black text-white">{s.v}</p>
                <p class="text-xs text-[#8888aa]">{s.l}</p>
              </div>
            ))}
          </div>
          <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl text-white font-bold transition-all hover:opacity-90" style="background: linear-gradient(135deg, #fbbf24, #d97706);">
            Audit gratuit pour mon activité &rarr;
          </a>
        </div>
        <div class="glass rounded-2xl p-6">
          <p class="text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-4">Exemple : prospect qui hésite</p>
          <div class="space-y-3">
            {[
              { c: true, t: "Votre formation convient-elle à quelqu'un qui débute complètement ?" },
              { c: false, t: "Oui ! 80% de nos élèves n'avaient aucune expérience en lançant le programme. On part de zéro et on avance à votre rythme." },
              { c: true, t: "Et combien de temps ça prend par semaine ?" },
              { c: false, t: "Minimum 3h/semaine pour suivre les modules. La plupart des élèves y consacrent 5 à 6h et voient leurs premiers résultats en 3 semaines." },
              { c: true, t: "Ok je suis intéressé, c'est combien ?" },
              { c: false, t: "Le programme est à 497€. La prochaine session démarre le 1er juillet — 6 places restantes. Je vous envoie le programme complet ?" },
            ].map(msg => (
              <div class={`flex ${msg.c ? 'justify-end' : 'justify-start'}`}>
                <div class={`max-w-[80%] px-4 py-2.5 rounded-2xl text-xs leading-relaxed ${msg.c ? 'text-white' : 'text-[#ccccdd]'}`} style={msg.c ? 'background: rgba(251,191,36,0.2); border: 1px solid rgba(251,191,36,0.3);' : 'background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);'}>
                  {msg.t}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TÂCHES -->
  <section class="py-20 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-black text-white text-center mb-4">Ce que l'agent fait pour votre activité</h2>
      <p class="text-[#8888aa] text-center mb-12">Configuré à votre voix, avec votre programme, vos arguments.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <p class="text-[#8888aa] text-sm">{task}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AVANT / APRÈS -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-black text-white text-center mb-12">Coach solopreneur : avant et après</h2>
      <div class="glass rounded-2xl p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h3 class="text-white font-bold mb-5 flex items-center gap-2">
              <span class="w-6 h-6 rounded-full bg-red-500/20 flex items-center justify-center text-red-400 text-xs font-black">×</span>
              Sans agent IA
            </h3>
            <ul class="space-y-3 text-sm text-[#8888aa]">
              <li class="flex items-start gap-2"><span class="text-red-400">·</span> Répondre manuellement à 15-20 DMs par jour</li>
              <li class="flex items-start gap-2"><span class="text-red-400">·</span> Prospects perdus la nuit ou en séance</li>
              <li class="flex items-start gap-2"><span class="text-red-400">·</span> Inscriptions gérées manuellement = erreurs</li>
              <li class="flex items-start gap-2"><span class="text-red-400">·</span> Pas de relance systématique des hésitants</li>
            </ul>
          </div>
          <div>
            <h3 class="text-white font-bold mb-5 flex items-center gap-2">
              <span class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-black" style="background: rgba(251,191,36,0.2); color: #fbbf24;">✓</span>
              Avec agent IA Vulcia
            </h3>
            <ul class="space-y-3 text-sm text-[#8888aa]">
              <li class="flex items-start gap-2"><span style="color: #fbbf24;">·</span> 100% des messages traités sous 30 secondes</li>
              <li class="flex items-start gap-2"><span style="color: #fbbf24;">·</span> Prospects qualifiés et nourris en votre absence</li>
              <li class="flex items-start gap-2"><span style="color: #fbbf24;">·</span> Inscriptions automatiques + accès envoyés</li>
              <li class="flex items-start gap-2"><span style="color: #fbbf24;">·</span> Relance J+2 et J+5 sur les hésitants</li>
            </ul>
          </div>
        </div>
        <div class="mt-8 pt-6 border-t border-white/10 text-center">
          <p class="text-[#8888aa] text-sm mb-2">CA additionnel moyen sur les 3 premiers mois (inscriptions récupérées)</p>
          <span class="text-3xl font-black" style="color: #fbbf24;">+ 3 000 €/mois</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-black text-white text-center mb-12">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqItems.map(f => (
          <details class="glass rounded-xl group">
            <summary class="p-5 cursor-pointer flex items-center justify-between text-white font-semibold text-sm list-none">
              {f.q}
              <span class="ml-4 flex-shrink-0 transition-transform group-open:rotate-45 text-lg" style="color: #fbbf24;">+</span>
            </summary>
            <p class="px-5 pb-5 text-[#8888aa] text-sm leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Votre prochain élève vous attend déjà</h2>
      <p class="text-[#8888aa] mb-8">Audit gratuit de 30 minutes. On configure un scénario de test avec votre programme et on vous montre comment l'agent converti à votre place.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold text-base transition-all hover:opacity-90" style="background: linear-gradient(135deg, #fbbf24, #d97706);">
        Audit gratuit pour mon activité &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">Réponse sous 24h · Compatible Kajabi, Teachable, Podia · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  details summary::-webkit-details-marker { display: none; }
</style>
