---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#38bdf8";

const tasks = [
  "Répond aux demandes de devis voyage 24h/24 : destination, dates, budget, type de voyage",
  "Qualifie les prospects : voyage de noces, famille, groupe, aventure, luxe",
  "Envoie les devis personnalisés et relance les prospects non répondants à J+2 et J+5",
  "Répond aux questions sur les formalités : visa, vaccins, sécurité destination",
  "Gère les demandes de modification et d'annulation avant départ",
  "Envoie les rappels pré-départ : check-list, documents, enregistrement",
  "Collecte les retours clients post-voyage pour les avis et l'upsell",
  "Gère les demandes de voyage d'affaires et de groupes scolaires",
];

const faqItems = [
  {
    q: "L'agent peut-il répondre aux questions sur les visas et formalités ?",
    a: "Oui. L'agent est configuré avec les informations de formalités pour les destinations que vous proposez : visa requis ou non pour passeport français, durée de validité requise, vaccins recommandés, niveau d'alerte du Quai d'Orsay. Pour les cas complexes (double nationalité, situations spécifiques), il dirige vers votre équipe.",
  },
  {
    q: "Comment l'agent gère-t-il les demandes de devis voyages sur-mesure ?",
    a: "L'agent collecte les informations clés : destination souhaitée, dates, nombre de voyageurs (adultes/enfants), budget indicatif, type d'hébergement, activités souhaitées. Il envoie cette fiche à votre équipe qui prépare le devis. Pour les voyages standards (packages existants), il peut envoyer directement les tarifs et disponibilités.",
  },
  {
    q: "Compatible avec les GDS et logiciels de réservation (Amadeus, Galileo, TourCom) ?",
    a: "L'agent peut se connecter à votre extranet en lecture pour vérifier les disponibilités et tarifs standards. Pour les réservations fermes, c'est votre équipe qui valide — l'agent prépare le dossier. Une intégration API complète est disponible sur le pack Pro.",
  },
  {
    q: "L'agent peut-il gérer les urgences pendant un voyage en cours ?",
    a: "Pour les voyages en cours, l'agent peut recevoir les demandes d'assistance, collecter les informations (lieu, problème, numéro de dossier) et déclencher votre protocole d'assistance (numéro d'astreinte, assurance voyage). Il ne gère pas seul une urgence médicale ou sécuritaire — il escalade immédiatement.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés pour un agent standard (devis, FAQ destinations, relances). 14 jours pour une intégration avec votre extranet ou votre logiciel de réservation. Vous validez sur 40 scénarios avant la mise en ligne.",
  },
];
---

<Layout
  title="Agent IA pour agences de voyage — Devis, formalités et relances automatisés | IAForge"
  description="Agent IA pour agence de voyage : devis 24h/24, réponses formalités visa et vaccins, relances automatiques, rappels pré-départ. +40% de devis traités. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://iaforge.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://iaforge.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Agences de voyage", "item": "https://iaforge.fr/ia-pour/agences-voyage" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Agences de voyage</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour agences de voyage</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Vos devis qualifiés<br/><span class="gradient-text">même à minuit.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Demandes de devis traitées 24h/24, formalités répondues automatiquement, relances et rappels pré-départ — pendant que vous vendez des rêves.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "+40%", label: "de devis traités sans augmenter les effectifs", color },
            { val: "-60%", label: "de temps passé sur les questions formalités répétitives", color: "#34d399" },
            { val: "+28%", label: "de taux de signature grâce aux relances automatiques J+2 et J+5", color: "#a78bfa" },
            { val: "7 jours", label: "pour être opérationnel, configuré à vos destinations et produits", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre agence</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Le tunnel de conversion devis voyage automatisé</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">Un prospect qui demande un devis à 22h ne sera plus jamais perdu faute de réponse rapide.</p>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        {[
          { step: "Instant", label: "Réception", desc: "L'agent collecte destination, dates, voyageurs, budget — fiche complète en 5 min", color },
          { step: "J+0", label: "Transmission", desc: "Fiche de qualification envoyée à votre équipe + accusé de réception au prospect", color: "#34d399" },
          { step: "J+2", label: "Relance #1", desc: "Si pas de devis envoyé par votre équipe : rappel interne. Si pas de réponse prospect : suivi chaleureux", color: "#a78bfa" },
          { step: "J+5", label: "Relance #2", desc: "Dernière relance prospect avec angle différent (question sur la destination, offre flash si dispo)", color: "#f59e0b" },
        ].map(item => (
          <div class="glass rounded-2xl p-5">
            <div class="text-xs font-bold mb-1" style={`color: ${item.color};`}>{item.step}</div>
            <p class="text-white font-bold text-sm mb-2">{item.label}</p>
            <p class="text-[#8888aa] text-xs leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Avant / après pour une agence de 4 conseillers</h2>
      <div class="glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3">
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-[#8888aa] uppercase tracking-wider">Situation</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-red-400 uppercase tracking-wider text-center">Sans agent</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold uppercase tracking-wider text-center" style={`color: ${color};`}>Avec agent IAForge</div>
          {[
            ["Demandes hors horaires", "Email sans réponse avant 9h le lendemain", "Réponse immédiate + fiche de qualification"],
            ["Questions visa / vaccins (30%/appels)", "15 min de recherche + réponse manuelle", "FAQ automatique par destination"],
            ["Relances devis non répondus", "Oubliées après 1 semaine occupée", "Séquence automatique J+2 et J+5"],
            ["Rappels pré-départ", "Email manuel J-7 par conseiller", "Séquence automatique J-15, J-7, J-2"],
            ["Retours post-voyage", "Rarement collectés", "Demande automatique J+7 + push avis Google"],
          ].map(([sit, sans, avec]) => (
            <>
              <div class="p-4 border-b border-white/5 text-xs text-white">{sit}</div>
              <div class="p-4 border-b border-white/5 text-xs text-red-400 text-center">{sans}</div>
              <div class="p-4 border-b border-white/5 text-xs text-center font-medium" style={`color: ${color};`}>{avec}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/hotels', title: 'Agent IA pour hôtels — réservations directes et avis automatisés', cat: 'Secteur' },
          { href: '/blog/automatiser-relances-clients', title: 'Automatiser ses relances clients avec l\'IA : le guide complet', cat: 'Automatisation' },
          { href: '/blog/crm-ia-pme', title: 'CRM et IA pour PME : automatiser son suivi commercial', cat: 'Automatisation' },
          { href: '/blog/seo-local-ia-pme', title: 'SEO local et IA pour PME : dominer Google Maps en 2026', cat: 'SEO Local' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Plus jamais un devis voyage sans réponse</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos demandes non converties, vos questions répétitives et vos relances manquées pour vous chiffrer ce que vous récupéreriez.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #0284c7);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
