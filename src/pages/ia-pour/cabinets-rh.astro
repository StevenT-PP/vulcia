---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#a78bfa";

const tasks = [
  "Qualifie les candidatures entrantes : poste visé, expérience, mobilité, prétentions salariales",
  "Programme les entretiens de présélection et envoie les convocations automatiquement",
  "Relance les candidats non répondants à J+3 et J+7 après envoi de l'offre",
  "Informe les candidats non retenus avec des messages personnalisés et respectueux",
  "Collecte les documents RH : CV, lettre de motivation, diplômes, références",
  "Gère le suivi client : avancement des missions, nombre de profils présentés, retours",
  "Rappelle les entretiens aux candidats J-1 et H-2h pour réduire les no-shows",
  "Répond aux questions FAQ des candidats : salaires moyens, marché, procédure de candidature",
];

const faqItems = [
  {
    q: "L'agent peut-il évaluer les compétences des candidats ?",
    a: "Non. L'évaluation des compétences, la présélection qualitative et le jugement sur l'adéquation culture/candidat restent humains. L'agent collecte les informations factuelles (parcours, prétentions, disponibilité, mobilité) et constitue la fiche de présentation que votre consultant utilise pour sa propre évaluation.",
  },
  {
    q: "Compatible avec les ATS (Applicant Tracking Systems) ?",
    a: "L'agent s'intègre avec les principaux ATS : Greenhouse, Lever, Workable, Recruitee, Talentsoft. Pour les cabinets utilisant Excel ou des outils propriétaires, une intégration via export CSV ou webhook est disponible. Les candidats ne savent pas si c'est l'ATS ou l'agent qui leur répond.",
  },
  {
    q: "Comment gérer les candidatures spontanées vs les offres d'emploi précises ?",
    a: "Pour les offres précises, l'agent collecte les informations de qualification selon la fiche de poste. Pour les candidatures spontanées, il identifie le type de poste visé, le secteur et le niveau d'expérience, et alerte le consultant concerné. Les profils hors cible reçoivent une réponse courtoise immédiate.",
  },
  {
    q: "L'agent respecte-t-il le droit à l'information des candidats (RGPD) ?",
    a: "Oui. L'agent informe les candidats du traitement de leurs données dès le premier contact (base légale, durée de conservation, droits d'accès et d'effacement). Les données ne sont pas conservées au-delà de 2 ans sans recontact, conformément aux recommandations CNIL pour les cabinets de recrutement.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés pour un agent de qualification et suivi candidats. On configure l'agent avec vos secteurs d'activité, types de postes, procédure de candidature et ton de communication. Pour les intégrations ATS, prévoir 14 jours.",
  },
];
---

<Layout
  title="Agent IA pour cabinets RH et recrutement — Qualification candidats et suivi missions | Vulcia"
  description="Agent IA pour cabinet RH : qualification des candidatures 24h/24, programmation des entretiens, relances, suivi clients — compatible Greenhouse, Lever, Workable. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Cabinets RH", "item": "https://vulcia.fr/ia-pour/cabinets-rh" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Cabinets RH</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour cabinets RH et recrutement</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Vos candidats qualifiés.<br/><span class="gradient-text">Vos consultants concentrés.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Qualification des candidatures 24h/24, programmation d'entretiens, relances et suivi client — pendant que vos consultants font ce qu'ils font le mieux : évaluer et placer.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "×3", label: "de candidatures qualifiées traitées sans augmenter l'équipe de consultants", color },
            { val: "-60%", label: "de temps sur la qualification initiale — fiche complète avant tout entretien", color: "#34d399" },
            { val: "< 5 min", label: "de délai de réponse à chaque candidature, contre 24 à 72h en moyenne", color: "#38bdf8" },
            { val: "7 jours", label: "pour être opérationnel, configuré à vos secteurs et procédures", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre cabinet</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">La fiche candidat que reçoit votre consultant</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">Chaque candidat qualifié arrive avec une fiche structurée. Le consultant ouvre l'entretien en sachant déjà l'essentiel.</p>
      <div class="glass rounded-2xl p-6">
        <div class="grid grid-cols-2 gap-6">
          {[
            { section: "Profil candidat", items: ["Intitulé exact du poste visé", "Années d'expérience et secteurs couverts", "Prétentions salariales (fixe + variable)", "Disponibilité et délai de préavis"] },
            { section: "Contraintes et préférences", items: ["Mobilité géographique (oui/non, villes acceptées)", "Télétravail souhaité (partiel, total, aucun)", "Type de contrat (CDI, CDD, mission)", "Raison du changement (départ voluntaire, licenciement, fin de mission)"] },
          ].map(col => (
            <div>
              <p class="text-xs font-bold uppercase tracking-wider mb-3" style={`color: ${color};`}>{col.section}</p>
              <div class="space-y-2">
                {col.items.map(item => (
                  <div class="flex items-start gap-2">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-1"><polyline points="20 6 9 17 4 12"/></svg>
                    <p class="text-[#8888aa] text-xs">{item}</p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Avant / après pour un cabinet de recrutement (3 consultants)</h2>
      <div class="glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3">
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-[#8888aa] uppercase tracking-wider">Situation</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-red-400 uppercase tracking-wider text-center">Sans agent</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold uppercase tracking-wider text-center" style={`color: ${color};`}>Avec agent Vulcia</div>
          {[
            ["Réponse aux candidatures", "Délai 24 à 72h, taux de réponse 60%", "Réponse < 5 min, taux de réponse 100%"],
            ["Qualification initiale", "Appel 20 min pour chaque candidat", "Fiche complète en 10 min avant tout appel"],
            ["Gestion des candidatures hors cible", "Email de refus oublié ou tardif", "Réponse courtoise et personnalisée immédiate"],
            ["Suivi client (état de la mission)", "Appel hebdomadaire du consultant", "Mise à jour automatique : nombre de profils, retours"],
            ["No-shows aux entretiens", "12 à 20% de no-shows", "-60% grâce aux rappels J-1 et H-2h"],
          ].map(([sit, sans, avec]) => (
            <>
              <div class="p-4 border-b border-white/5 text-xs text-white">{sit}</div>
              <div class="p-4 border-b border-white/5 text-xs text-red-400 text-center">{sans}</div>
              <div class="p-4 border-b border-white/5 text-xs text-center font-medium" style={`color: ${color};`}>{avec}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/blog/ia-recrutement-rh', title: 'IA pour le recrutement RH : automatiser sans déshumaniser', cat: 'Guide' },
          { href: '/blog/ia-b2b-prospection', title: 'IA et prospection B2B : qualifier 3× plus de leads', cat: 'Automatisation' },
          { href: '/blog/automatiser-onboarding-client', title: 'Automatiser l\'onboarding client avec l\'IA', cat: 'Automatisation' },
          { href: '/blog/crm-ia-pme', title: 'CRM et IA pour PME : automatiser son suivi commercial', cat: 'Automatisation' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Vos consultants placent. L'agent qualifie.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse votre volume de candidatures, votre délai de traitement et votre taux de no-shows pour vous chiffrer ce que vous récupéreriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #7c3aed);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
