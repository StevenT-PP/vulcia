---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#34d399";

const tasks = [
  "Répond aux demandes de renseignements 24h/24 (tarifs, disponibilités, types de prestations)",
  "Qualifie les nouvelles demandes : surface, fréquence, besoin ménage / garde d'enfants / aide senior",
  "Programme les premières interventions et envoie les confirmations automatiquement",
  "Relance les prospects qui ont demandé un devis sans donner suite après 48h et 7 jours",
  "Envoie les rappels d'intervention la veille et le matin même pour limiter les désistements",
  "Collecte les retours clients après chaque intervention et alerte si insatisfaction détectée",
  "Informe sur les aides financières disponibles (CESU, crédit d'impôt, APA, PCH)",
  "Gère les demandes de remplacement en cas d'absence d'un intervenant",
];

const faqItems = [
  {
    q: "L'agent peut-il vérifier les disponibilités de mes intervenants ?",
    a: "Oui, si vous utilisez un logiciel de planning exposant une API ou un calendrier partagé (Google Calendar, Outlook). L'agent consulte les disponibilités en temps réel et propose des créneaux directement au client. Pour les structures utilisant des feuilles de calcul, on peut intégrer Google Sheets comme source de données.",
  },
  {
    q: "Compatible avec les logiciels de services à domicile (Ximi, Arche-MC², Ogust) ?",
    a: "La plupart de ces logiciels disposent d'une API ou permettent des exports automatisés. L'intégration permet à l'agent d'accéder aux plannings, de créer des interventions et de consulter les dossiers clients. Délai : 2-3 semaines selon votre logiciel.",
  },
  {
    q: "Comment l'agent gère-t-il les informations sensibles sur les bénéficiaires âgés ?",
    a: "L'agent ne stocke jamais d'informations médicales ni de données sensibles sur les bénéficiaires. Il collecte uniquement les informations nécessaires à la planification (nom, adresse, type de prestation, fréquence). Les données sont hébergées en France, conformes RGPD.",
  },
  {
    q: "L'agent peut-il expliquer le crédit d'impôt et le CESU ?",
    a: "Oui. L'agent connaît les dispositifs en vigueur : crédit d'impôt de 50% sur les dépenses de services à la personne (plafond 12 000€/an), fonctionnement du CESU préfinancé, APA et PCH pour les seniors et personnes handicapées. Il informe les prospects et oriente vers les démarches.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés pour un agent de base avec FAQ, tarifs, types de prestations et prise de demandes. Pour l'intégration avec votre logiciel de planning (disponibilités en temps réel), prévoir 14-21 jours selon votre système.",
  },
];
---

<Layout
  title="Agent IA pour services à domicile — Ménage, garde d'enfants et aide senior automatisés | Vulcia"
  description="Agent IA pour services à domicile : qualification des demandes, planning intervenants, rappels interventions et informations CESU/crédit d'impôt — sans mobiliser votre coordinateur. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Services à domicile", "item": "https://vulcia.fr/ia-pour/services-domicile" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Services à domicile</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour services à domicile</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Chaque demande traitée.<br/><span class="gradient-text">Chaque intervenant coordonné.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Ménage, garde d'enfants, aide aux seniors — l'agent qualifie les demandes, programme les interventions et informe sur les aides disponibles, pendant que vos coordinateurs gèrent l'humain.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "-60%", label: "d'appels entrants pour les demandes de renseignements et de tarifs", color },
            { val: "+35%", label: "de taux de conversion des prospects en clients actifs", color: "#fbbf24" },
            { val: "-40%", label: "de désistements d'intervention grâce aux rappels automatiques J-1", color: "#38bdf8" },
            { val: "7 jours", label: "pour être opérationnel avec vos tarifs, prestations et informations CESU", color: "#a78bfa" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre structure</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Les aides financières que l'agent explique</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">L'agent informe sur les dispositifs en vigueur — une question souvent posée qui mobilise votre équipe pour rien.</p>
      <div class="not-prose my-6 glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-4">
          {["Dispositif", "Bénéficiaires", "Avantage", "Démarche"].map(h => (
            <div class="p-3 border-b border-white/5 text-xs font-bold text-[#8888aa] uppercase tracking-wider">{h}</div>
          ))}
          {[
            ["Crédit d'impôt 50%", "Tous ménages imposables ou non", "50% des dépenses remboursées (plafond 12 000€)", "Déclaration de revenus annuelle"],
            ["CESU préfinancé", "Salariés d'entreprises partenaires", "Financement partiel ou total par l'employeur", "Via comité d'entreprise ou RH"],
            ["APA (Allocation Personnalisée Autonomie)", "Seniors 60+ en perte d'autonomie (GIR 1-4)", "Prise en charge partielle selon ressources", "Dossier Conseil Départemental"],
            ["PCH (Prestation de Compensation du Handicap)", "Personnes handicapées de moins de 60 ans", "Prise en charge selon plan de compensation", "Dossier MDPH"],
          ].map(([d, b, a, dem]) => (
            <>
              <div class="p-3 border-b border-white/5 text-xs text-white font-medium">{d}</div>
              <div class="p-3 border-b border-white/5 text-xs text-[#8888aa]">{b}</div>
              <div class="p-3 border-b border-white/5 text-xs text-[#8888aa]">{a}</div>
              <div class="p-3 border-b border-white/5 text-xs text-[#34d399]">{dem}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Séquence de conversion d'un nouveau prospect</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">Du premier contact à la première intervention — automatisé sans perdre la relation humaine.</p>
      <div class="not-prose my-6 space-y-3">
        {[
          { step: "Contact entrant", timing: "Immédiat (J0)", desc: "L'agent répond en moins de 2 minutes, identifie le type de besoin (ménage, garde, aide senior), collecte la zone géographique et la fréquence souhaitée.", color },
          { step: "Envoi devis indicatif", timing: "J0 — automatique", desc: "L'agent envoie une fourchette de tarifs personnalisée selon le besoin, informe sur les aides disponibles et les conditions pour en bénéficier.", color: "#38bdf8" },
          { step: "Relance si pas de réponse", timing: "J2 et J7", desc: "Si le prospect n'a pas redonné signe de vie, l'agent relance avec un message bienveillant et propose de répondre à d'éventuelles questions.", color: "#fbbf24" },
          { step: "Programmation 1ère intervention", timing: "Dès accord", desc: "L'agent collecte les informations pratiques (adresse, accès, consignes), confirme le créneau et envoie une confirmation par email et/ou SMS.", color: "#a78bfa" },
          { step: "Rappel J-1 et retour J+1", timing: "J-1 et J+1", desc: "Rappel la veille pour confirmer l'intervention. Le lendemain, l'agent demande un retour sur la satisfaction et remonte les alertes si nécessaire.", color: "#f87171" },
        ].map(item => (
          <div class="glass rounded-xl p-5 flex gap-4 items-start">
            <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold" style={`background: ${item.color}20; color: ${item.color}; border: 1px solid ${item.color}40;`}>{item.step.charAt(0)}</div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-1">
                <p class="text-white font-semibold text-sm">{item.step}</p>
                <span class="text-xs px-2 py-0.5 rounded-full" style={`color: ${item.color}; background: ${item.color}15; border: 1px solid ${item.color}30;`}>{item.timing}</span>
              </div>
              <p class="text-[#8888aa] text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/blog/automatiser-relances-clients', title: 'Automatiser ses relances clients avec l\'IA', cat: 'Automatisation' },
          { href: '/blog/mesurer-roi-agent-ia', title: 'Mesurer le ROI d\'un agent IA : les métriques qui comptent', cat: 'ROI' },
          { href: '/ia-pour/coachs', title: 'IA pour coachs et formateurs', cat: 'Secteur' },
          { href: '/blog/agent-ia-multicanal', title: 'Agent IA multicanal : email, WhatsApp, chat et SMS', cat: 'Agents IA' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#34d399] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Votre équipe sur le terrain. L'agent au téléphone.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos demandes entrantes, vos désistements et votre taux de conversion pour vous chiffrer ce que vous récupéreriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #059669);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
