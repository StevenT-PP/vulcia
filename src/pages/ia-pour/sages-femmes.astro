---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#f87171";

const tasks = [
  "Prise de RDV 24h/24 selon le motif (suivi grossesse, préparation accouchement, post-partum, gynécologie)",
  "Rappels anti no-show J-2 et H-2h avec confirmation ou annulation",
  "Collecte les informations de grossesse avant la consultation : terme, antécédents, suivi précédent",
  "Informe sur le suivi de grossesse mensuel : quand venir, quels examens à apporter",
  "Rappelle les échéances du suivi : consultations du 4ème, 6ème, 8ème mois, préparation accouchement",
  "Répond aux questions sur le remboursement Sécurité Sociale et mutuelle",
  "Gère les séances de préparation à la naissance : planning, inscriptions, rappels",
  "Assure le suivi post-partum : rappels consultations J+8, 4ème et 8ème semaine",
];

const faqItems = [
  {
    q: "L'agent peut-il répondre aux questions médicales sur la grossesse ?",
    a: "Non. L'agent ne peut jamais évaluer des symptômes, interpréter des résultats ou donner un avis sur une situation clinique. Pour toute question médicale — saignement, douleur, anomalie — il redirige vers la sage-femme, le maternité ou le 15 selon l'urgence déclarée. L'agent reste strictement dans le champ administratif et organisationnel.",
  },
  {
    q: "Compatible avec Doctolib ?",
    a: "Oui, l'agent s'intègre avec Doctolib via API. Il lit les disponibilités en temps réel et peut créer les RDV directement. Pour les sages-femmes sur Maiia, Clickdoc ou les logiciels de maternité, une intégration via webhook est disponible.",
  },
  {
    q: "Comment gérer les urgences obstétricales ?",
    a: "L'agent est configuré avec un protocole d'urgence obstétricale : détection des signaux d'alarme (contractions rapprochées avant terme, perte de liquide, saignement, mouvement foetal réduit) → redirection immédiate vers la maternité ou le 15-SAMU. L'agent ne triage pas médicalement — il redirige vers les bons interlocuteurs.",
  },
  {
    q: "L'agent peut-il gérer les rémunérations Sécurité Sociale ?",
    a: "L'agent peut informer sur les grandes lignes de la prise en charge : le suivi de grossesse est pris en charge à 100% par l'Assurance Maladie à partir de la déclaration de grossesse (5ème mois), les séances de préparation à la naissance sont remboursées à 100%. Pour les détails du remboursement mutuelle, il renvoie vers l'assureur.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés. Configuration avec vos types de consultations (suivi grossesse, préparation, post-partum, gynécologie), vos créneaux disponibles et les informations pratiques de votre cabinet. RGPD conforme, données hébergées en France.",
  },
];
---

<Layout
  title="Agent IA pour sages-femmes — RDV grossesse et post-partum automatisés | IAForge"
  description="Agent IA pour sage-femme : prise de RDV 24h/24 par motif (grossesse, préparation accouchement, post-partum), rappels, collecte antécédents. RGPD. Compatible Doctolib. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://iaforge.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://iaforge.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Sages-femmes", "item": "https://iaforge.fr/ia-pour/sages-femmes" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Sages-femmes</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour sages-femmes</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Vos patientes suivies.<br/><span class="gradient-text">Chaque étape accompagnée.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Prise de RDV 24h/24, rappels du suivi mensuel de grossesse, préparation à la naissance et post-partum — pendant que vous accompagnez vos patientes.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "-55%", label: "de no-shows grâce aux rappels J-2 et H-2h avec confirmation ou annulation", color },
            { val: "0 échéance", label: "de suivi grossesse manquée — rappels automatiques du 4ème au 9ème mois", color: "#f59e0b" },
            { val: "+40%", label: "de RDV pris hors horaires — patientes qui réservent le soir ou le week-end", color: "#a78bfa" },
            { val: "7 jours", label: "pour être opérationnel, configuré à vos types de suivi et votre agenda", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre cabinet</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Le calendrier de suivi automatisé de grossesse</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">7 consultations obligatoires en cours de grossesse. L'agent rappelle automatiquement chaque échéance.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { mois: "1er trimestre", label: "Déclaration grossesse", detail: "Rappel de la déclaration à l'Assurance Maladie avant la fin du 3ème mois. Documents à préparer.", color },
          { mois: "4ème mois", label: "1ère consultation obligatoire", detail: "Rappel J-7 avec liste des examens à apporter : bilan sanguin, groupe sanguin, sérologies.", color: "#f59e0b" },
          { mois: "6ème mois", label: "Début préparation naissance", detail: "Proposition d'inscription aux séances de préparation à la naissance (8 séances remboursées).", color: "#a78bfa" },
          { mois: "Post-partum", label: "Visites J+8, S+4, S+8", detail: "Séquence de rappels automatique après la naissance : visite J+8, consultation 4ème et 8ème semaine.", color: "#34d399" },
        ].map(item => (
          <div class="glass rounded-2xl p-5">
            <div class="text-xs font-bold mb-1" style={`color: ${item.color};`}>{item.mois}</div>
            <p class="text-white font-bold text-sm mb-2">{item.label}</p>
            <p class="text-[#8888aa] text-xs leading-relaxed">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/medecins', title: 'Agent IA pour médecins généralistes', cat: 'Secteur' },
          { href: '/ia-pour/kinesitherapeutes', title: 'Agent IA pour kinésithérapeutes', cat: 'Secteur' },
          { href: '/blog/ia-medecin-generaliste', title: 'IA pour médecin généraliste : automatiser sans déshumaniser', cat: 'Guide' },
          { href: '/blog/reduire-no-shows-ia', title: 'Réduire les no-shows avec l\'IA : guide pratique', cat: 'Automatisation' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Chaque patiente suivie. Chaque échéance respectée.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos créneaux disponibles, votre taux de no-shows et vos rappels de suivi pour vous chiffrer ce que vous récupéreriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #dc2626);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours · RGPD conforme</p>
    </div>
  </section>

  <Footer />
</Layout>
