---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#38bdf8";

const tasks = [
  "Qualifie les demandes de devis : type de contrat (auto, habitation, santé, pro), profil assuré, budget",
  "Envoie les devis et relance les prospects non répondants à J+3 et J+7",
  "Répond aux questions générales sur les garanties : franchises, plafonds, exclusions standard",
  "Collecte les pièces pour les contrats : relevé d'informations, justificatif de domicile, attestations",
  "Rappelle les dates de renouvellement de contrat à 3 mois, 1 mois et 7 jours avant l'échéance",
  "Gère les premières déclarations de sinistre : collecte des informations et transmission au gestionnaire",
  "Accompagne les clients sur les résiliations par la loi Hamon ou Lemoine",
  "Informe sur les garanties optionnelles et extensions de couverture disponibles",
];

const faqItems = [
  {
    q: "L'agent peut-il donner des conseils personnalisés sur les garanties ?",
    a: "Non. Le conseil en assurance est réglementé par la DDA (Directive Distribution Assurance) et réservé aux professionnels habilités ORIAS. L'agent informe sur les caractéristiques générales des contrats et redirige vers votre conseiller pour tout conseil personnalisé sur la situation du client.",
  },
  {
    q: "Peut-il gérer les sinistres de bout en bout ?",
    a: "L'agent collecte les informations initiales (date, nature du sinistre, circonstances, coordonnées des tiers le cas échéant) et transmet au gestionnaire. L'instruction du sinistre, l'évaluation des préjudices et la décision d'indemnisation restent humains.",
  },
  {
    q: "Compatible avec les CRM et logiciels assurance ?",
    a: "L'agent s'intègre avec Salesforce Financial Services Cloud, Selligent, IBA et Aptic. Pour les courtiers utilisant Whitebook ou des plateformes propriétaires, une intégration personnalisée via API est disponible.",
  },
  {
    q: "L'agent respecte-t-il les obligations DDA d'information précontractuelle ?",
    a: "L'agent peut transmettre automatiquement les documents d'information précontractuelle (IPID, notice d'information). Il ne peut pas tenir lieu de devoir de conseil — la signature du recueil de besoins et du devoir de conseil restent humains et sous la responsabilité du courtier.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés pour un agent de qualification et relance de devis. Pour les intégrations CRM et logiciels de gestion, compter 14 jours. Configuration avec vos produits, zones de couverture et grilles tarifaires indicatives.",
  },
];
---

<Layout
  title="Agent IA pour courtiers en assurance — Qualification devis et relances automatisées | Vulcia"
  description="Agent IA pour courtier en assurance : qualification des demandes de devis, relances prospects, rappels de renouvellement, gestion des premières déclarations de sinistre. Conforme DDA. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Assurances", "item": "https://vulcia.fr/ia-pour/assurances" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Assurances</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour courtiers en assurance</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Vos devis relancés.<br/><span class="gradient-text">Vos renouvellements sécurisés.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Qualification des demandes 24h/24, relances prospects automatiques, rappels de renouvellement — sans jamais remplacer votre devoir de conseil.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "+40%", label: "de devis traités grâce à la qualification 24h/24 et aux relances automatiques", color },
            { val: "0 renouvellement", label: "raté — rappels automatiques à 3 mois, 1 mois et 7 jours avant échéance", color: "#f59e0b" },
            { val: "-55%", label: "de temps de qualification — fiche prospect complète avant tout entretien", color: "#a78bfa" },
            { val: "7 jours", label: "pour être opérationnel, configuré à vos produits et procédures", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre cabinet de courtage</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">La frontière DDA : ce que l'agent fait et ne fait pas</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">La Directive Distribution Assurance encadre strictement le conseil en assurance. L'agent est configuré pour rester dans les limites réglementaires.</p>
      <div class="glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3">
          <div class="p-4 border-b border-white/5 text-xs font-bold text-[#8888aa] uppercase tracking-wider">Tâche</div>
          <div class="p-4 border-b border-white/5 text-xs font-bold uppercase tracking-wider text-center" style={`color: ${color};`}>Agent IA peut faire</div>
          <div class="p-4 border-b border-white/5 text-xs font-bold text-red-400 uppercase tracking-wider text-center">Courtier uniquement</div>
          {[
            ["Information sur les garanties", "Expliquer le fonctionnement général (franchise, plafond, exclusion standard)", "Recommander la couverture adaptée à la situation du client"],
            ["Collecte d'informations", "Poser les questions de qualification (profil, véhicule, logement)", "Analyser les besoins et établir le recueil des besoins DDA"],
            ["Devis", "Envoyer les devis préparés par le courtier", "Élaborer l'offre et signer le devoir de conseil"],
            ["Renouvellement", "Rappeler l'échéance et collecter la confirmation", "Négocier les conditions et modifier les garanties"],
            ["Sinistres", "Collecter les informations initiales et transmettre", "Instruire le dossier, évaluer le préjudice, décider"],
          ].map(([tache, peut, non]) => (
            <>
              <div class="p-3 border-b border-white/5 text-xs text-white">{tache}</div>
              <div class="p-3 border-b border-white/5 text-xs text-center" style={`color: ${color};`}>{peut}</div>
              <div class="p-3 border-b border-white/5 text-xs text-red-400 text-center">{non}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Séquence de renouvellement : zéro contrat perdu par oubli</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">Le renouvellement est le moment où le concurrent peut débaucher votre client. L'agent anticipe pour vous.</p>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        {[
          { step: "J-90", label: "Alerte préventive", msg: "\"Votre contrat [type] arrive à échéance le [date]. Souhaitez-vous revoir vos garanties ou conserver les mêmes conditions ?\"", color },
          { step: "J-30", label: "Confirmation ou révision", msg: "\"Votre renouvellement approche. Si vous souhaitez ajuster votre couverture, votre conseiller est disponible — sinon le contrat est reconduit automatiquement.\"", color: "#f59e0b" },
          { step: "J-7", label: "Dernier rappel", msg: "\"Dernière semaine avant le renouvellement de votre contrat. Besoin de modifier quelque chose ? Votre conseiller peut vous rappeler aujourd'hui.\"", color: "#a78bfa" },
          { step: "J+0", label: "Confirmation de reconduction", msg: "\"Votre contrat [type] a été renouvelé pour une nouvelle année. Retrouvez votre attestation dans votre espace client ou par email.\"", color: "#34d399" },
        ].map(item => (
          <div class="glass rounded-2xl p-5">
            <div class="text-xs font-bold mb-1" style={`color: ${item.color};`}>{item.step}</div>
            <p class="text-white font-bold text-sm mb-2">{item.label}</p>
            <p class="text-[#8888aa] text-xs leading-relaxed italic">{item.msg}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/avocats', title: 'Agent IA pour avocats — dossiers qualifiés avant le premier RDV', cat: 'Secteur' },
          { href: '/ia-pour/notaires', title: 'Agent IA pour notaires — collecte de pièces et prise de RDV', cat: 'Secteur' },
          { href: '/blog/automatiser-relances-clients', title: 'Automatiser ses relances clients avec l\'IA : le guide complet', cat: 'Automatisation' },
          { href: '/blog/crm-ia-pme', title: 'CRM et IA pour PME : automatiser son suivi commercial', cat: 'Automatisation' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Plus de devis signés. Zéro renouvellement oublié.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos taux de conversion de devis, vos renouvellements perdus et vos pics d'activité pour vous chiffrer ce que vous récupéreriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #0284c7);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
