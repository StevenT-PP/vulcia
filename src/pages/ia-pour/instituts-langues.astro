---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#38bdf8";

const tasks = [
  "Répond aux questions sur les cours disponibles, niveaux, horaires et tarifs 24h/24",
  "Qualifie les prospects : langue souhaitée, niveau actuel (test de positionnement), objectif (pro, voyage, examen)",
  "Programme les tests de positionnement et les rendez-vous de conseil pédagogique",
  "Relance les prospects ayant demandé des informations sans s'inscrire",
  "Envoie les rappels de cours et les informations logistiques aux apprenants",
  "Informe sur les certifications reconnues (TOEIC, DELF, DALF, HSK, DELE) et les modalités de passage",
  "Gère les demandes de formation professionnelle : éligibilité CPF, OPCO, prises en charge employeur",
  "Notifie les apprenants des nouvelles sessions, stages intensifs et promotions",
];

const faqItems = [
  {
    q: "L'agent peut-il effectuer un test de niveau en ligne ?",
    a: "L'agent peut envoyer un lien vers votre test de positionnement en ligne (ou l'intégrer directement dans la conversation si vous utilisez un outil adapté). Il recueille le niveau estimé et l'objectif de l'apprenant pour orienter vers le bon cours dès le premier contact.",
  },
  {
    q: "L'agent peut-il expliquer l'éligibilité CPF et les financements ?",
    a: "Oui. L'agent connaît les principales règles de financement : éligibilité CPF selon les certifications (TOEIC, BRIGHT, Linguaskill), financement OPCO pour les salariés, prise en charge plan de formation employeur, Transition Pro. Il informe et oriente vers les démarches — la demande finale reste gérée par votre équipe administrative.",
  },
  {
    q: "L'agent peut-il présenter vos offres de cours sur-mesure pour les entreprises ?",
    a: "Oui. Pour les demandes B2B (formation d'une équipe, cours en intra-entreprise), l'agent collecte les informations clés : nombre de personnes, niveaux, objectif, langue, rythme souhaité, budget. Il programme ensuite un rendez-vous avec votre responsable des formations professionnelles.",
  },
  {
    q: "L'agent peut-il répondre en plusieurs langues selon le prospect ?",
    a: "Oui. L'agent peut détecter la langue du prospect et lui répondre directement en anglais, espagnol, ou autre langue configurée. Cela est particulièrement utile pour les prospects anglophones ou hispanophones qui cherchent des cours de français.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés pour un agent avec FAQ, informations sur les cours et prise de RDV. Pour l'intégration avec votre LMS (Moodle, Teachizy) et la gestion des financements CPF, prévoir 14 jours.",
  },
];
---

<Layout
  title="Agent IA pour écoles et instituts de langues | Vulcia"
  description="Agent IA pour école de langues : qualification prospects, information CPF et OPCO, prise de RDV test de niveau, rappels de cours et informations certifications (TOEIC, DELF) — Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Écoles & Instituts de langues", "item": "https://vulcia.fr/ia-pour/instituts-langues" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Écoles & Instituts de langues</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour écoles et instituts de langues</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Prospects qualifiés.<br/><span class="gradient-text">CPF et certifications expliqués.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Qualification des niveaux, orientation vers les cours, informations CPF et OPCO, rappels de cours et informations certifications — l'agent gère le flux commercial pour que vos formateurs enseignent.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "+40%", label: "de taux de conversion des prospects grâce à la réponse immédiate et à la qualification", color },
            { val: "+30%", label: "de dossiers CPF aboutis grâce à l'accompagnement dans la démarche de financement", color: "#34d399" },
            { val: "-50%", label: "du temps administratif consacré aux questions répétitives sur les niveaux et tarifs", color: "#fbbf24" },
            { val: "7 jours", label: "pour être opérationnel avec vos cours, certifications et processus d'inscription", color: "#a78bfa" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre école</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Certifications disponibles : ce que l'agent explique</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">40% des questions portent sur les certifications et leur reconnaissance — l'agent les maîtrise toutes.</p>
      <div class="not-prose my-6 glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-4">
          {["Certification", "Langue", "Reconnaissance", "CPF éligible"].map(h => (
            <div class="p-3 border-b border-white/5 text-xs font-bold text-[#8888aa] uppercase tracking-wider">{h}</div>
          ))}
          {[
            ["TOEIC Listening & Reading", "Anglais", "Internationale, très demandée en entreprise", "Oui"],
            ["TOEFL iBT", "Anglais", "Universités internationales, études à l'étranger", "Non"],
            ["IELTS", "Anglais", "Immigration, études UK/Australie/Canada", "Non"],
            ["DELF / DALF", "Français langue étrangère", "Mondiale, délivrée par le Ministère de l'Éducation", "Selon organisme"],
            ["DELE", "Espagnol", "Reconnue par le Ministerio de Educación d'Espagne", "Oui"],
            ["HSK", "Chinois mandarin", "Standard national chinois", "Oui"],
            ["BRIGHT Language Certification", "Anglais", "Reconnue France, éligible CPF", "Oui"],
          ].map(([c, l, r, cpf]) => (
            <>
              <div class="p-3 border-b border-white/5 text-xs text-white font-medium">{c}</div>
              <div class="p-3 border-b border-white/5 text-xs text-[#8888aa]">{l}</div>
              <div class="p-3 border-b border-white/5 text-xs text-[#8888aa]">{r}</div>
              <div class="p-3 border-b border-white/5 text-xs font-semibold" style={`color: ${cpf === 'Oui' ? '#34d399' : '#8888aa'};`}>{cpf}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/ecoles-privees', title: 'IA pour écoles privées : préinscriptions et portes ouvertes', cat: 'Secteur' },
          { href: '/ia-pour/coachs', title: 'IA pour coachs et formateurs en ligne', cat: 'Secteur' },
          { href: '/blog/ia-pour-formation-professionnelle', title: 'IA pour organisme de formation professionnelle', cat: 'Guide' },
          { href: '/blog/ia-integration-api', title: 'Intégrer son agent IA avec son LMS ou CRM', cat: 'Technique' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#38bdf8] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Vos formateurs en cours. L'agent à l'inscription.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos prospects perdus, vos dossiers CPF abandonnés et vos questions répétitives pour vous chiffrer ce que vous récupéreriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #0284c7);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
