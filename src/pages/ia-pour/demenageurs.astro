---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#38bdf8";

const tasks = [
  "Qualifie les demandes de déménagement : dates, volume estimé, distance, étages, ascenseur, accessibilité",
  "Collecte les informations pour le devis sur place : mobilier spécifique (piano, coffre-fort, œuvres d'art, aquarium)",
  "Programme les visites de pré-déménagement pour les volumes importants et les déménagements longue distance",
  "Répond aux questions sur les assurances (responsabilité civile, assurance valeur déclarée, objets de valeur)",
  "Informe sur les obligations légales du déménageur : lettre de voiture, bon d'enlèvement, inventaire contradictoire",
  "Gère les demandes de garde-meubles temporaires et informe sur les durées et tarifs de stockage",
  "Envoie les checklists de préparation automatisées à J-30, J-15, J-7 et J-1 avant le déménagement",
  "Collecte les avis clients post-déménagement pour alimenter Google, les comparateurs et les plateformes de notation",
];

const faqItems = [
  {
    q: "L'agent peut-il fournir un devis de déménagement par message ?",
    a: "L'agent peut fournir une fourchette indicative basée sur le volume (studio, F2, F3, maison), la distance et les étages. Pour tout déménagement, le devis précis — gratuit et obligatoire — est établi après visite à domicile ou via formulaire de déclaration de mobilier. L'agent programme cette visite et collecte les informations préalables pour que le technicien arrive préparé.",
  },
  {
    q: "L'agent peut-il gérer les demandes de déménagements d'entreprise ?",
    a: "Oui. L'agent propose un formulaire dédié aux déménagements professionnels : nombre de postes de travail, matériel informatique, archives, délai de remise en service. Il peut qualifier les projets de déménagement d'entreprise, d'entrepôt ou de cabinet médical avec leurs contraintes spécifiques (équipements sensibles, données confidentielles à sécuriser).",
  },
  {
    q: "Comment l'agent gère-t-il les réclamations après le déménagement ?",
    a: "L'agent collecte la réclamation, demande les photos des dommages et rappelle au client le délai légal de réserves (10 jours après la livraison selon l'article L.133-3 du Code de commerce). Il vous transmet immédiatement le dossier pour traitement. Pour les réclamations urgentes, il peut initier le processus avec votre assurance responsabilité civile professionnelle.",
  },
  {
    q: "L'agent peut-il gérer les demandes de location de camionnette ou de monte-meubles ?",
    a: "Oui, si vous proposez ces services. L'agent informe sur la disponibilité (selon un planning que vous mettez à jour), les tarifs, les permis requis et les conditions de location. Pour les monte-meubles, il collecte les informations nécessaires (hauteur d'étage, dimensions des ouvertures, nombre de meubles) pour établir le devis.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés pour un agent avec FAQ, qualification des demandes et prise de RDV visite. Pour l'envoi automatique des checklists de préparation et les rappels personnalisés à J-30/J-15/J-7, prévoir 10 à 14 jours selon votre outil de gestion. 0€ d'installation, sans engagement.",
  },
];
---

<Layout
  title="Agent IA pour déménageurs | Vulcia"
  description="Agent IA pour déménageur : qualification des demandes, checklist préparation automatisée (J-30/J-15/J-7), informations assurances, gestion garde-meubles et collecte d'avis. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Déménageurs", "item": "https://vulcia.fr/ia-pour/demenageurs" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Déménageurs</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour déménageurs et transporteurs</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Devis qualifiés.<br/><span class="gradient-text">Clients préparés le jour J.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Qualification des demandes 24h/24, checklists de préparation envoyées automatiquement, informations assurances et collecte d'avis post-déménagement — sans y consacrer du temps.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "+35%", label: "de devis signés grâce à la qualification immédiate et aux relances automatiques", color },
            { val: "-50%", label: "d'appels téléphoniques pour les questions de préparation et d'assurance", color: "#34d399" },
            { val: "+60%", label: "d'avis Google collectés grâce à la demande automatique 48h après le déménagement", color: "#fbbf24" },
            { val: "7 jours", label: "pour être opérationnel avec votre zone, vos tarifs et vos checklists personnalisées", color: "#a78bfa" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre entreprise de déménagement</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Séquence de préparation automatisée</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">L'agent envoie les bonnes informations au bon moment — sans que vous y pensiez.</p>
      <div class="not-prose my-6 space-y-3">
        {[
          {
            delai: "J-30",
            titre: "Confirmation et début de préparation",
            actions: ["Confirmation du devis et des détails de la prestation", "Envoi de la checklist cartons et matériel nécessaire", "Rappel de prévenir le bailleur, EDF, GDF, La Poste", "Information sur votre assurance et la valeur déclarée"],
            color,
          },
          {
            delai: "J-15",
            titre: "Avancement et points de vigilance",
            actions: ["Rappel de commencer l'emballage des objets non utilisés quotidiennement", "Information sur les objets à déclarer spécifiquement (bijoux, tableaux, électronique)", "Rappel de vider et décongeler le réfrigérateur/congélateur 48h avant"],
            color: "#34d399",
          },
          {
            delai: "J-7",
            titre: "Derniers préparatifs",
            actions: ["Confirmation des détails logistiques : heure de départ, stationnement départ et arrivée", "Rappel de regrouper les documents importants à transporter soi-même", "Information pratique sur le déroulement de la journée avec votre équipe"],
            color: "#fbbf24",
          },
          {
            delai: "J-1",
            titre: "Rappel final et confirmation équipe",
            actions: ["Confirmation de l'heure d'arrivée de l'équipe", "Nom du chef d'équipe et numéro de contact du jour", "Derniers conseils : conserver les objets de valeur avec soi, préparer un café pour l'équipe"],
            color: "#a78bfa",
          },
          {
            delai: "J+2",
            titre: "Suivi post-déménagement",
            actions: ["Vérification que tout s'est bien passé", "Demande d'avis Google avec lien direct", "Invitation à laisser un témoignage pour les comparateurs"],
            color: "#f87171",
          },
        ].map(step => (
          <div class="glass rounded-2xl p-5 flex gap-5 items-start">
            <div class="text-center flex-shrink-0">
              <div class="text-lg font-black" style={`color: ${step.color};`}>{step.delai}</div>
              <div class="text-xs text-[#8888aa] mt-0.5 whitespace-nowrap">{step.titre}</div>
            </div>
            <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 gap-1.5">
              {step.actions.map(action => (
                <div class="flex items-start gap-1.5">
                  <div class="w-1 h-1 rounded-full flex-shrink-0 mt-2" style={`background: ${step.color};`}></div>
                  <p class="text-[#8888aa] text-xs">{action}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/artisans', title: 'IA pour artisans BTP : devis automatisés et urgences gérées', cat: 'Secteur' },
          { href: '/ia-pour/services-domicile', title: 'IA pour services à domicile', cat: 'Secteur' },
          { href: '/blog/ia-avis-google-automatique', title: 'Avis Google automatiques avec l\'IA', cat: 'SEO Local' },
          { href: '/blog/agent-ia-devis-artisan', title: 'Agent IA pour devis artisan : guide complet', cat: 'Guide' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#38bdf8] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Votre équipe sur le camion. L'agent avec vos clients.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos demandes non qualifiées, vos devis non relancés et votre potentiel d'avis Google pour vous chiffrer ce que vous récupéreriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #0284c7);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
