---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#34d399";

const tasks = [
  "Répond aux demandes d'inscription 24h/24 : permis B, conduite accompagnée, moto, code",
  "Qualifie les prospects : expérience de conduite, objectif de délai, financement CPF",
  "Gère la prise de RDV pour les leçons et examens",
  "Rappelle les élèves J-2 avant chaque leçon pour réduire les annulations",
  "Informe sur les tarifs, les forfaits et l'éligibilité au CPF",
  "Notifie les élèves quand une date d'examen est disponible",
  "Relance les prospects qui n'ont pas finalisé leur inscription",
  "Répond aux questions sur le code de la route et les procédures d'examen",
];

const faqItems = [
  {
    q: "L'agent peut-il gérer les dossiers CPF pour les permis de conduire ?",
    a: "L'agent explique l'éligibilité CPF pour le permis B (formation dans un établissement agréé), guide les prospects dans la démarche sur Mon Compte Formation et répond aux questions fréquentes sur les montants. Il ne crée pas les dossiers à la place de l'élève, mais accompagne la démarche et relance ceux qui n'ont pas finalisé.",
  },
  {
    q: "Comment l'agent gère-t-il les disponibilités d'examen ?",
    a: "L'agent peut être configuré pour notifier automatiquement les élèves prêts à passer l'examen dès qu'une date se libère dans votre agenda. Il envoie une notification WhatsApp ou SMS, récupère la confirmation, et bloque le créneau. Fini les places d'examen qui partent faute d'avoir appelé à temps.",
  },
  {
    q: "Compatible avec les logiciels auto-école (iCar, TitanDrive, auto-école.net) ?",
    a: "L'agent s'intègre à votre agenda en lecture (disponibilités) pour proposer des créneaux de leçons. Pour les logiciels de suivi de progression élève (heures réalisées, résultats code), l'agent n'y accède pas — il gère uniquement le relationnel et l'administratif.",
  },
  {
    q: "L'agent peut-il vendre des forfaits de conduite en ligne ?",
    a: "L'agent présente vos forfaits (20h, 30h, pack code + conduite), explique ce qui est inclus, et oriente vers votre processus d'inscription (formulaire en ligne, paiement). Il peut relancer les prospects intéressés qui n'ont pas finalisé sous 48h.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés. On configure l'agent avec vos forfaits, vos enseignants, vos horaires, vos conditions CPF et vos protocoles d'examen. Vous validez sur les scénarios clés avant la mise en ligne.",
  },
];
---

<Layout
  title="Agent IA pour auto-école | Vulcia"
  description="Agent IA pour auto-école : inscriptions 24h/24, information CPF, gestion des leçons et examens, rappels élèves. -50% d'appels entrants. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Auto-écoles", "item": "https://vulcia.fr/ia-pour/auto-ecoles" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Auto-écoles</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour auto-écoles</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Vos inscriptions gérées.<br/><span class="gradient-text">Vos élèves accompagnés.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Inscriptions 24h/24, information CPF, rappels de leçons et notification des dates d'examen — votre agent IA s'occupe du relationnel pendant que vous enseignez.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "-50%", label: "d'appels entrants grâce aux réponses automatiques 24h/24", color },
            { val: "+40%", label: "d'inscriptions finalisées grâce aux relances automatiques", color: "#f59e0b" },
            { val: "0 place", label: "d'examen perdue — notification automatique des disponibilités", color: "#a78bfa" },
            { val: "7 jours", label: "pour être opérationnel, configuré à vos forfaits et enseignants", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre auto-école</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Le tunnel d'inscription automatisé</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">De la première question à l'inscription finalisée, sans intervention humaine.</p>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        {[
          { step: "1", label: "Premier contact", desc: "Prospect intéressé sur site ou Google Maps → agent répond immédiatement", color },
          { step: "2", label: "Qualification", desc: "Type de permis, expérience, délai souhaité, financement CPF ou perso", color: "#38bdf8" },
          { step: "3", label: "Devis et infos", desc: "Forfaits envoyés avec détail CPF, tarifs, conditions. Lien d'inscription.", color: "#a78bfa" },
          { step: "4", label: "Relance J+2", desc: "Si pas d'inscription finalisée : relance personnalisée avec réponse aux objections fréquentes", color: "#f59e0b" },
        ].map(item => (
          <div class="glass rounded-2xl p-5">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-black text-white" style={`background: ${item.color};`}>{item.step}</span>
              <p class="text-white font-bold text-sm">{item.label}</p>
            </div>
            <p class="text-[#8888aa] text-xs leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Avant / après pour une auto-école de 4 moniteurs</h2>
      <div class="glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3">
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-[#8888aa] uppercase tracking-wider">Situation</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-red-400 uppercase tracking-wider text-center">Sans agent</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold uppercase tracking-wider text-center" style={`color: ${color};`}>Avec agent Vulcia</div>
          {[
            ["Demandes d'information hors horaires", "Messagerie, 40% sans rappel", "Réponse immédiate 24h/24"],
            ["Questions sur le CPF", "15 min d'explication par appel", "FAQ automatique + guide étape par étape"],
            ["Inscriptions non finalisées", "Oubliées après 1 semaine", "Relance auto J+2, J+5, J+10"],
            ["Annulations de leçon de dernière minute", "Moniteur prévenu à la dernière seconde", "Rappel J-2 + confirmation J-1"],
            ["Places d'examen disponibles", "Appel manuel à chaque élève prêt", "Notification automatique à la liste d'attente"],
          ].map(([sit, sans, avec]) => (
            <>
              <div class="p-4 border-b border-white/5 text-xs text-white">{sit}</div>
              <div class="p-4 border-b border-white/5 text-xs text-red-400 text-center">{sans}</div>
              <div class="p-4 border-b border-white/5 text-xs text-center font-medium" style={`color: ${color};`}>{avec}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/coachs', title: 'Agent IA pour coachs et formateurs — inscriptions automatiques', cat: 'Secteur' },
          { href: '/blog/ia-pour-formation-professionnelle', title: 'IA pour organisme de formation : automatiser sans perdre Qualiopi', cat: 'Guide' },
          { href: '/blog/automatiser-relances-clients', title: 'Automatiser ses relances clients avec l\'IA : le guide complet', cat: 'Automatisation' },
          { href: '/blog/no-code-automatisation-ia', title: 'No-code et IA : automatiser son business sans développeur', cat: 'Technique' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Concentrez-vous sur la conduite, pas sur l'administratif</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos flux d'appels, vos inscriptions abandonnées et vos annulations pour vous chiffrer ce que vous perdez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #059669);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
