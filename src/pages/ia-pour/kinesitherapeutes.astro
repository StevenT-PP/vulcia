---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#34d399";

const tasks = [
  "Prend les rendez-vous consultation, bilan et série de séances 24h/24",
  "Planifie automatiquement les séries complètes (ex : 15 séances, 2×/semaine)",
  "Envoie les confirmations et rappels anti no-show à J-2 et J-1",
  "Permet l'annulation par SMS et libère le créneau immédiatement",
  "Répond aux FAQ : ordonnance, tenue, remboursement CPAM, mutuelle, parking",
  "Informe sur les spécialités traitées : sport, post-op, neurologie, pédiatrie",
  "Gère les demandes de bilans bilan initial et de suivi longue durée",
  "Collecte les informations patient avant la première consultation",
];

const faqItems = [
  {
    q: "Compatible avec Doctolib, Maiia ou Ordoclic ?",
    a: "Oui. On s'intègre aux principaux agendas santé : Doctolib, Maiia, Ordoclic, Therapiste, Cliniciel. L'agent voit vos vraies disponibilités en temps réel et crée les RDV directement dans votre logiciel — aucune double saisie.",
  },
  {
    q: "L'agent peut-il gérer les séries de séances (post-op, rééducation longue) ?",
    a: "C'est l'une des fonctions les plus demandées. L'agent peut proposer un planning de série complet — par exemple 'mardi et jeudi à 14h pendant 8 semaines' — avec une confirmation globale et des rappels automatiques avant chaque séance.",
  },
  {
    q: "Comment sont gérées les données de santé des patients ?",
    a: "On utilise Mistral AI hébergé à Paris pour tous les cabinets de santé. Aucune donnée ne quitte le territoire français. L'agent traite les créneaux et les coordonnées de contact — pas les diagnostics, prescriptions ou données médicales. Conformité CNIL et HDS garantie.",
  },
  {
    q: "Peut-il réduire les no-shows ?",
    a: "C'est l'impact le plus immédiat. Nos clients constatent en moyenne -50 à -60% de no-shows grâce aux rappels automatiques J-2 par SMS et J-1 par WhatsApp. Le patient peut annuler d'un simple message et le créneau est immédiatement remis en disponibilité pour un autre patient.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés. On configure l'agent avec vos spécialités, vos types de séances, vos horaires et vos protocoles. Vous validez les réponses sur 40 scénarios avant la mise en ligne — aucun patient ne voit une réponse non validée.",
  },
];
---

<Layout
  title="Agent IA pour kinésithérapeutes | Vulcia"
  description="Agent IA pour cabinet kiné : prise de RDV 24h/24, planification de séries, rappels anti no-show, FAQ automatique. RGPD, hébergé en France. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Kinésithérapeutes", "item": "https://vulcia.fr/ia-pour/kinesitherapeutes" }
    ]
  })} />

  <Nav />

  <!-- HERO -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Kinésithérapeutes</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour kinésithérapeutes</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Votre cabinet kiné<br/><span class="gradient-text">remplit ses créneaux sans décrocher</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            RDV automatiques, planification de séries, rappels anti no-show et FAQ patients — votre agent IA gère le planning pendant que vous êtes en séance.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">
              Audit gratuit &rarr;
            </a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">
              Calculer mon ROI
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "-55%", label: "de no-shows grâce aux rappels automatiques J-2 et J-1", color },
            { val: "-1h30", label: "de gestion du planning par jour et par praticien", color: "#38bdf8" },
            { val: "0 appel", label: "manqué hors horaires — les demandes sont traitées en 60 secondes", color: "#a78bfa" },
            { val: "7 jours", label: "pour être opérationnel, connecté à Doctolib, Maiia ou Ordoclic", color: "#fbbf24" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- TACHES -->
  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre cabinet</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AVANT / APRES -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Avant / après pour un cabinet de 2 kinésithérapeutes</h2>
      <div class="glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3">
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-[#8888aa] uppercase tracking-wider">Situation</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold text-red-400 uppercase tracking-wider text-center">Sans agent</div>
          <div class="p-4 border-b border-white/5 text-xs font-semibold uppercase tracking-wider text-center" style={`color: ${color};`}>Avec agent Vulcia</div>
          {[
            ["Gestion planning / jour", "1h30 au téléphone", "20 min (cas complexes uniquement)"],
            ["No-shows / semaine", "12 à 18 créneaux perdus", "5 à 8 créneaux perdus (-55%)"],
            ["Planification série séances", "Appel + allers-retours", "Série confirmée en 1 échange"],
            ["Demandes hors horaires", "Messagerie non consultée", "RDV pris automatiquement"],
            ["FAQ patients (ordo, remb.)", "50x/semaine, réponse manuelle", "0 — traitement automatique 24h/24"],
          ].map(([sit, sans, avec]) => (
            <>
              <div class="p-4 border-b border-white/5 text-xs text-white">{sit}</div>
              <div class="p-4 border-b border-white/5 text-xs text-red-400 text-center">{sans}</div>
              <div class="p-4 border-b border-white/5 text-xs text-center font-medium" style={`color: ${color};`}>{avec}</div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- RGPD -->
  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto glass rounded-2xl p-8">
      <div class="flex items-start gap-5">
        <div class="text-3xl flex-shrink-0">🔒</div>
        <div>
          <h2 class="text-xl font-black text-white mb-3">Données de santé : hébergement France</h2>
          <p class="text-[#8888aa] text-sm leading-relaxed mb-4">
            Les cabinets de kinésithérapie sont soumis aux obligations RGPD sur les données de santé. Vulcia utilise exclusivement <strong class="text-white">Mistral AI hébergé à Paris</strong> pour tous les déploiements en cabinet de santé. Vos données et celles de vos patients ne quittent jamais le territoire français.
          </p>
          <ul class="space-y-2">
            {[
              "Pas de stockage de diagnostics, prescriptions ou données médicales",
              "Conformité CNIL et HDS (Hébergement Données de Santé)",
              "Chiffrement de bout en bout sur tous les canaux",
              "DPA (Data Processing Agreement) fourni avec chaque contrat",
            ].map(item => (
              <li class="flex items-center gap-2 text-sm text-[#8888aa]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ARTICLES LIES -->
  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/blog/ia-pour-kinesitherapeute', title: 'IA pour kinésithérapeute : automatiser les RDV et réduire les no-shows', cat: 'Santé' },
          { href: '/blog/automatiser-prise-rdv', title: 'Comment automatiser sa prise de RDV avec un agent IA (guide complet)', cat: 'Automatisation' },
          { href: '/blog/automatiser-relances-clients', title: 'Automatiser ses relances clients avec l\'IA : le guide complet 2026', cat: 'Automatisation' },
          { href: '/blog/prix-agent-ia-2026', title: 'Combien coûte un agent IA en 2026 ? Prix, packs et ROI expliqués', cat: 'Tarifs' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#a78bfa] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Concentrez-vous sur vos patients, pas sur votre planning</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos no-shows, vos pics d'appels et le temps perdu sur la gestion administrative pour vous chiffrer le gain exact.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #059669);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · Données hébergées en France · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
