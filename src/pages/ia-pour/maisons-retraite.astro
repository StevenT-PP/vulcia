---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const color = "#34d399";

const tasks = [
  "Répond aux questions des familles sur les prestations, les niveaux de dépendance accueillis et les tarifs",
  "Programme les visites de la résidence pour les familles en recherche d'hébergement",
  "Informe sur les démarches administratives : APA, ASH, aides au logement, MDPH",
  "Envoie les rappels d'événements aux familles : anniversaires, animations, portes ouvertes",
  "Répond aux questions sur les activités proposées (ateliers, sorties, animations) et le programme hebdomadaire",
  "Informe les familles sur les procédures de visite et les horaires d'accueil",
  "Collecte les préinscriptions sur liste d'attente et tient les familles informées de l'avancement",
  "Gère les demandes de renseignements d'urgence et les oriente vers les équipes soignantes",
];

const faqItems = [
  {
    q: "L'agent peut-il répondre sur l'état de santé des résidents ?",
    a: "Absolument pas. L'agent n'a accès à aucune donnée de santé et ne communique jamais sur l'état d'un résident. Ces informations relèvent du secret médical et doivent être communiquées uniquement par l'équipe soignante ou médicale. L'agent redirige systématiquement toute question de santé vers l'infirmière référente ou le médecin coordonnateur.",
  },
  {
    q: "L'agent peut-il expliquer les aides financières disponibles ?",
    a: "Oui. L'agent informe sur les dispositifs en vigueur : APA (Allocation Personnalisée d'Autonomie) selon le GIR, ASH (Aide Sociale à l'Hébergement) pour les familles dans le besoin, APL/ALS pour les résidents en résidence autonomie, déduction fiscale pour hébergement en EHPAD. Il explique les démarches générales et oriente vers le service social de la résidence pour les cas individuels.",
  },
  {
    q: "Comment gérer les familles en situation de détresse lors d'une demande d'admission ?",
    a: "L'agent est configuré pour détecter les signaux de détresse émotionnelle dans les messages (urgence médicale, déclin rapide d'un parent, situation de crise) et escalader immédiatement vers un membre de votre équipe d'accueil. En dehors des heures d'ouverture, il fournit les numéros d'urgence pertinents selon la situation.",
  },
  {
    q: "L'agent est-il conforme aux exigences RGPD pour les données de santé ?",
    a: "L'agent ne stocke et ne traite aucune donnée de santé. Il gère uniquement des informations administratives et logistiques (demandes de visite, questions tarifaires, informations sur les activités). Pour les résidences recevant des données personnelles via l'agent (nom, téléphone), l'hébergement est en France et la configuration inclut une PIA documentée.",
  },
  {
    q: "En combien de temps est-il opérationnel ?",
    a: "7 jours ouvrés pour un agent avec FAQ, informations sur la résidence, les prestations et la prise de RDV de visite. Pour les rappels personnalisés aux familles et les intégrations avec votre logiciel de gestion, prévoir 14 jours.",
  },
];
---

<Layout
  title="Agent IA pour maisons de retraite et EHPAD — Familles informées, admissions facilitées | Vulcia"
  description="Agent IA pour EHPAD et résidence senior : FAQ familles, visites programmées, informations APA et ASH, rappels d'événements — strictement administratif, sans accès aux données de santé. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://vulcia.fr" },
      { "@type": "ListItem", "position": 2, "name": "Agent IA par secteur", "item": "https://vulcia.fr/ia-pour" },
      { "@type": "ListItem", "position": 3, "name": "Maisons de retraite & EHPAD", "item": "https://vulcia.fr/ia-pour/maisons-retraite" }
    ]
  })} />

  <Nav />

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <nav class="flex items-center gap-2 text-xs text-[#8888aa] mb-6">
            <a href="/" class="hover:text-white transition-colors">Accueil</a>
            <span>/</span>
            <a href="/ia-pour" class="hover:text-white transition-colors">Agent IA par secteur</a>
            <span>/</span>
            <span style={`color: ${color};`}>Maisons de retraite & EHPAD</span>
          </nav>
          <p class="text-xs font-bold uppercase tracking-widest mb-4" style={`color: ${color};`}>IA pour maisons de retraite et EHPAD</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Familles informées.<br/><span class="gradient-text">Équipes concentrées sur les résidents.</span>
          </h1>
          <p class="text-[#8888aa] text-lg leading-relaxed mb-8">
            Visites programmées, aides financières expliquées, animations communiquées, admissions gérées — l'agent répond aux familles 24h/24 sans jamais toucher aux données de santé.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary inline-flex items-center gap-2">Audit gratuit &rarr;</a>
            <a href="/calculateur-roi" class="px-6 py-3 rounded-xl glass text-white text-sm font-semibold hover:bg-white/10 transition-all">Calculer mon ROI</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "-50%", label: "d'appels de familles pour des questions sur les activités, tarifs et démarches", color },
            { val: "+35%", label: "de visites programmées grâce à la prise de RDV immédiate 24h/24", color: "#38bdf8" },
            { val: "+40%", label: "de participation aux animations grâce aux rappels automatiques aux familles", color: "#fbbf24" },
            { val: "7 jours", label: "pour être opérationnel avec vos prestations, tarifs et informations APA/ASH", color: "#a78bfa" },
          ].map(s => (
            <div class="glass rounded-2xl p-5 text-center">
              <div class="text-3xl font-black mb-2" style={`color: ${s.color};`}>{s.val}</div>
              <p class="text-[#8888aa] text-xs leading-relaxed">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ce que l'agent fait pour votre résidence</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {tasks.map(task => (
          <div class="glass rounded-xl p-4 flex items-start gap-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-[#8888aa] text-sm">{task}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-3">Ce que l'agent ne fera jamais</h2>
      <p class="text-[#8888aa] text-center text-sm mb-10">Les données de santé sont hors périmètre, sans exception. La frontière est non-négociable.</p>
      <div class="not-prose my-6 grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          {
            titre: "Périmètre de l'agent",
            items: ["Horaires, tarifs, prestations et activités", "Prise de RDV de visite pour les familles en recherche", "Informations sur les aides financières (APA, ASH)", "Programme des animations et événements", "Liste d'attente et avancement des dossiers d'admission", "Procédures de visite et conditions d'accueil"],
            color,
          },
          {
            titre: "Hors périmètre — équipes uniquement",
            items: ["État de santé ou évolution médicale du résident", "Informations issues du dossier soignant", "Décisions médicales ou thérapeutiques", "Situations d'urgence médicale → protocole humain immédiat", "Informations financières individuelles du résident", "Tout ce qui relève du secret médical ou de la confidence"],
            color: "#f87171",
          },
        ].map(col => (
          <div class="glass rounded-2xl p-6">
            <p class="text-sm font-bold mb-4" style={`color: ${col.color};`}>{col.titre}</p>
            <div class="space-y-2">
              {col.items.map(item => (
                <div class="flex items-start gap-2">
                  <div class="w-1.5 h-1.5 rounded-full flex-shrink-0 mt-2" style={`background: ${col.color};`}></div>
                  <p class="text-[#8888aa] text-xs leading-relaxed">{item}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Questions fréquentes</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer text-white font-semibold text-sm flex items-center justify-between">
              {item.q}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 ml-4 group-open:rotate-180 transition-transform"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-1">
              <p class="text-[#9090b0] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-white text-center mb-10">Ressources complémentaires</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { href: '/ia-pour/cliniques', title: 'IA pour cliniques et centres médicaux', cat: 'Secteur' },
          { href: '/blog/ia-securite-rgpd-pme', title: 'IA et RGPD : ce que les PME doivent savoir', cat: 'RGPD' },
          { href: '/blog/agent-ia-secteur-public', title: 'Agent IA pour le secteur public', cat: 'Agents IA' },
          { href: '/ia-pour/sages-femmes', title: 'IA pour sages-femmes : suivi grossesse automatisé', cat: 'Secteur' },
        ].map(a => (
          <a href={a.href} class="glass rounded-xl p-5 hover:bg-white/[0.06] transition-all group">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full mb-3 inline-block" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{a.cat}</span>
            <p class="text-white text-sm font-semibold leading-snug group-hover:text-[#34d399] transition-colors">{a.title} &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Votre équipe auprès des résidents. L'agent auprès des familles.</h2>
      <p class="text-[#8888aa] mb-8 leading-relaxed">Audit gratuit 30 min. On analyse vos demandes de familles, vos visites manquées et vos dossiers d'admission abandonnés pour vous chiffrer ce que vous récupéreriez chaque mois.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90" style={`background: linear-gradient(135deg, ${color}, #059669);`}>
        Demander l'audit gratuit &rarr;
      </a>
      <p class="text-xs text-[#8888aa] mt-4">0€ d'installation · Sans engagement · RGPD conforme · Opérationnel en 7 jours</p>
    </div>
  </section>

  <Footer />
</Layout>
