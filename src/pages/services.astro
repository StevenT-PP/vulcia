---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Nos Services IA & SEO | IAForge - Agents IA, Automatisation, Web"
  description="IAForge déploie des agents IA sur-mesure, une stratégie SEO automatisée et des sites haute performance pour les PME françaises. Audit gratuit en 30 minutes."
>
  <Nav />

  <section class="pt-32 pb-24 px-6">
    <div class="max-w-7xl mx-auto">

      <div class="text-center mb-20">
        <p class="text-xs font-semibold uppercase tracking-widest text-[#7c5cfc] mb-4">Ce que nous faisons</p>
        <h1 class="text-5xl md:text-6xl font-black text-white mb-6">
          L'IA qui <span class="gradient-text">travaille pour vous</span>
        </h1>
        <p class="text-[#8888aa] max-w-xl mx-auto">Trois disciplines maitrisees, une seule promesse : plus de temps, plus d'argent, moins de friction.</p>
      </div>

      <!-- Agents IA -->
      <div id="agents" class="mb-32">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center mb-12">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[#7c5cfc] mb-4">Service 01</p>
            <h2 class="text-4xl font-black text-white mb-6">Agents IA sur-mesure</h2>
            <p class="text-[#8888aa] leading-relaxed mb-6">
              Un agent IA n'est pas un chatbot basique. C'est un employe numerique qui comprend votre metier, s'integre a vos outils et prend des decisions autonomes - 24h/24, sans erreur, sans conge.
            </p>
            <p class="text-[#8888aa] leading-relaxed mb-8">
              On construit sur GPT-4o, Claude 3.5 et Mistral selon les contraintes : cout, latence, confidentialite des donnees. Pas un seul modele impose a tout le monde.
            </p>
            <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-white text-sm font-bold transition-all hover:opacity-90" style="background: linear-gradient(135deg, #7c5cfc, #5b3fdb);">
              Discuter de mon projet &rarr;
            </a>
          </div>
          <div class="grid grid-cols-2 gap-4">
            {[
              { title: 'Agent RDV & Accueil', desc: 'Qualification, prise de rendez-vous, reponses FAQ - automatique.', icon: '📅' },
              { title: 'Agent Prospection', desc: 'LinkedIn + email en automatique. 20-40 leads qualifies/mois.', icon: '🎯' },
              { title: 'Agent Support Client', desc: '80% des tickets resolus sans intervention humaine.', icon: '💬' },
              { title: 'Agent Contenu', desc: '30 articles SEO/mois, posts social, newsletters - a la voix de votre marque.', icon: '✍️' },
            ].map(card => (
              <div class="glass rounded-xl p-5">
                <div class="text-2xl mb-3">{card.icon}</div>
                <h3 class="text-white font-semibold text-sm mb-2">{card.title}</h3>
                <p class="text-[#8888aa] text-xs leading-relaxed">{card.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- SEO -->
      <div id="seo" class="mb-32">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center mb-12">
          <div class="order-2 md:order-1">
            <div class="glass rounded-2xl p-8">
              <div class="space-y-4">
                {[
                  { label: 'Audit technique', value: 'Complet', color: '#34d399' },
                  { label: 'Articles/mois (Growth)', value: '8 articles', color: '#38bdf8' },
                  { label: 'Schema markup', value: 'JSON-LD full', color: '#7c5cfc' },
                  { label: 'Google Business', value: 'Optimise', color: '#a78bfa' },
                  { label: 'Core Web Vitals', value: '98-100/100', color: '#fbbf24' },
                ].map(item => (
                  <div class="flex items-center justify-between py-3 border-b border-white/5 last:border-0">
                    <span class="text-[#8888aa] text-sm">{item.label}</span>
                    <span class="text-sm font-bold" style={`color: ${item.color};`}>{item.value}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
          <div class="order-1 md:order-2">
            <p class="text-xs font-semibold uppercase tracking-widest text-[#38bdf8] mb-4">Service 02</p>
            <h2 class="text-4xl font-black text-white mb-6">SEO & Contenu IA</h2>
            <p class="text-[#8888aa] leading-relaxed mb-6">
              Une strategie SEO entierement pilotee par l'IA. Nous produisons, optimisons et publions votre contenu chaque mois, sans que vous ayez a lever le petit doigt.
            </p>
            <ul class="space-y-3 mb-8">
              {[
                'Audit technique complet (crawl, Core Web Vitals, schema)',
                'Recherche semantique et maillage interne optimise',
                'Production de contenu a la voix de votre marque',
                'Google Business Profile optimise et actif',
                'Suivi de positions et rapport mensuel',
              ].map(item => (
                <li class="flex items-center gap-3 text-sm text-[#8888aa]">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="2.5" class="flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
            <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-white text-sm font-bold transition-all hover:opacity-90" style="background: linear-gradient(135deg, #38bdf8, #0ea5e9);">
              Audit SEO gratuit &rarr;
            </a>
          </div>
        </div>
      </div>

      <!-- Sites web -->
      <div id="sites" class="mb-32">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[#a78bfa] mb-4">Service 03</p>
            <h2 class="text-4xl font-black text-white mb-6">Sites web haute performance</h2>
            <p class="text-[#8888aa] leading-relaxed mb-6">
              Un site beau ne suffit pas. Il doit etre rapide, trouver sur Google et convertir ses visiteurs en clients. On construit avec Astro, le framework qui donne naturellement 98-100 en PageSpeed.
            </p>
            <div class="grid grid-cols-3 gap-4 mb-8">
              {[
                { metric: '98-100', label: 'PageSpeed' },
                { metric: '< 3 sem', label: 'Livraison' },
                { metric: 'SSL + CDN', label: 'Securite' },
              ].map(m => (
                <div class="glass rounded-xl p-4 text-center">
                  <div class="text-xl font-black text-white mb-1">{m.metric}</div>
                  <div class="text-xs text-[#8888aa]">{m.label}</div>
                </div>
              ))}
            </div>
            <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-white text-sm font-bold transition-all hover:opacity-90" style="background: linear-gradient(135deg, #a78bfa, #7c5cfc);">
              Voir un exemple &rarr;
            </a>
          </div>
          <div class="glass rounded-2xl p-6">
            <div class="mb-4 flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
              <div class="flex-1 glass rounded px-4 py-1 text-xs text-[#8888aa] ml-2">iaforge.fr</div>
            </div>
            <div class="space-y-3">
              <div class="h-24 rounded-lg" style="background: linear-gradient(135deg, rgba(124,92,252,0.15), rgba(56,189,248,0.08));"></div>
              <div class="grid grid-cols-3 gap-2">
                <div class="h-12 rounded-lg glass"></div>
                <div class="h-12 rounded-lg glass"></div>
                <div class="h-12 rounded-lg glass"></div>
              </div>
              <div class="h-8 rounded-lg glass w-2/3"></div>
              <div class="h-6 rounded-lg glass w-full"></div>
              <div class="h-6 rounded-lg glass w-4/5"></div>
              <div class="flex gap-2 mt-4">
                <div class="h-10 rounded-lg flex-1" style="background: linear-gradient(135deg, #7c5cfc, #5b3fdb);"></div>
                <div class="h-10 rounded-lg w-24 glass"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6" style="background: var(--bg-2);">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-4xl font-black text-white mb-6">Pret a commencer ?</h2>
      <p class="text-[#8888aa] mb-8">On commence par 30 minutes d'audit gratuit. Ensemble, on identifie ce qui vous fera gagner le plus de temps et d'argent.</p>
      <a href="/contact" class="inline-block px-10 py-4 rounded-xl text-white font-bold transition-all hover:opacity-90 hover:scale-[1.02]" style="background: linear-gradient(135deg, #7c5cfc, #5b3fdb); box-shadow: 0 0 40px rgba(124,92,252,0.3);">
        Audit gratuit &rarr;
      </a>
    </div>
  </section>

  <Footer />
</Layout>
