---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const useCases = [
  { sector: 'Médecins & Dentistes', tasks: ['Prise de rendez-vous 24h/24', 'Rappels automatiques J-1', 'Réponses aux questions tarifaires', 'Gestion des annulations'], gain: '14h récupérées/semaine', icon: '🏥', link: '/ia-pour/medecins' },
  { sector: 'Avocats & Comptables', tasks: ['Qualification des dossiers avant RDV', 'Collecte de pièces justificatives', 'FAQ procédures et délais', 'Prise de rendez-vous téléphonique'], gain: '22h d\'admin économisées/semaine', icon: '⚖️', link: '/ia-pour/avocats' },
  { sector: 'Artisans & BTP', tasks: ['Formulaire devis intelligent', 'Détection des urgences', 'Planification des interventions', 'Relance des devis non signés'], gain: '-60% de temps au téléphone', icon: '🔧', link: '/ia-pour/artisans' },
  { sector: 'Restaurants & Hôtels', tasks: ['Réservations de table automatiques', 'FAQ menu, allergènes, horaires', 'Réponses aux avis Google', 'Promotions ciblées clients réguliers'], gain: '+40% de réservations confirmées', icon: '🍽️', link: '/ia-pour/restaurants' },
  { sector: 'E-commerce', tasks: ['Support client 24h/24 sans humain', 'Suivi commandes en temps réel', 'Relance paniers abandonnés', 'Recommandations produits personnalisées'], gain: '+31% de taux de conversion', icon: '🛒', link: '/ia-pour/ecommerce' },
  { sector: 'Coachs & Formateurs', tasks: ['Qualification des candidats', 'Inscription automatique aux formations', 'Envoi des supports et accès', 'Suivi de progression'], gain: '+3 000€/mois de CA additionnel', icon: '📚', link: '/ia-pour/coachs' },
];

const faqItems = [
  {
    q: "Qu'est-ce qu'un agent IA exactement ?",
    a: "Un agent IA est un programme capable de comprendre les messages en langage naturel et d'agir en conséquence de manière autonome. Contrairement à un chatbot à règles fixes, il comprend le contexte, pose des questions de clarification et prend des décisions — comme réserver un rendez-vous, envoyer un devis ou escalader une demande complexe à un humain."
  },
  {
    q: "Quelle différence avec ChatGPT ou Claude ?",
    a: "ChatGPT et Claude sont des modèles IA génériques. Un agent IA Vulcia est configuré spécifiquement pour votre activité : il connaît vos horaires, vos tarifs, vos questions fréquentes, votre vocabulaire. Il est connecté à vos outils (agenda, email, CRM). Il ne répond pas à n'importe quoi — il répond à ce que font vos clients, comme vous le feriez."
  },
  {
    q: "Sur quels canaux fonctionne l'agent ?",
    a: "Par défaut, l'agent est intégré à votre site web via un widget chat. Il peut aussi être déployé sur WhatsApp Business, par email, ou via des webhooks vers votre CRM. La configuration dépend de votre pack et de vos besoins."
  },
  {
    q: "Que se passe-t-il quand l'agent ne sait pas répondre ?",
    a: "L'agent est configuré pour reconnaître ses limites. Quand une demande dépasse son périmètre (cas complexe, litige, demande inhabituelle), il escalade vers vous : il notifie par email ou SMS et indique à votre client qu'un humain va prendre le relais. Vous gardez le contrôle total."
  },
  {
    q: "Mes données clients sont-elles sécurisées ?",
    a: "Vos données vous appartiennent entièrement. Pour les secteurs sensibles (santé, juridique, comptabilité), nous utilisons Mistral AI hébergé à Paris — vos données ne quittent pas le territoire français et respectent le RGPD. Pour les autres secteurs, GPT-4o ou Claude Sonnet selon vos préférences."
  },
  {
    q: "Combien de temps pour déployer l'agent ?",
    a: "7 jours pour le Pack Solo sur votre site existant. 3 semaines pour les packs incluant un nouveau site. Ce délai inclut la configuration, les tests avec vous, les ajustements et la mise en ligne."
  },
];
---

<Layout
  title="Agent IA pour entreprise — Configuré pour votre métier | Vulcia"
  description="Déployez un agent IA sur votre site en 7 jours. Répond à vos clients 24h/24, prend les rendez-vous, qualifie les prospects — configuré pour votre secteur d'activité. Dès 149€/mois."
>
  <script type="application/ld+json" slot="head">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })}</script>
  <script type="application/ld+json" slot="head">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Agent IA sur-mesure pour PME",
    "provider": { "@type": "Organization", "name": "Vulcia", "url": "https://vulcia.fr" },
    "description": "Déploiement d'agents IA configurés pour votre secteur d'activité. Prise de rendez-vous, qualification de prospects, support client 24h/24.",
    "areaServed": "FR",
    "offers": {
      "@type": "Offer",
      "price": "149",
      "priceCurrency": "EUR",
      "priceSpecification": { "@type": "RecurringPaymentFrequency", "frequency": "Monthly" }
    }
  })}</script>
  <Nav />

  <!-- HERO -->
  <section class="pt-32 pb-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div style="position:absolute;width:600px;height:600px;top:-10%;left:5%;background:radial-gradient(circle,rgba(124,92,252,0.15),transparent 70%);filter:blur(80px);"></div>
    </div>
    <div class="max-w-4xl mx-auto text-center relative">
      <p class="text-xs font-bold uppercase tracking-widest text-[#7c5cfc] mb-4">Agent IA sur-mesure</p>
      <h1 class="text-5xl md:text-6xl font-black text-white leading-[1.05] mb-6">
        Un agent IA qui travaille<br/><span class="gradient-text">pour votre métier — pas pour tous.</span>
      </h1>
      <p class="text-xl text-[#9090b0] max-w-2xl mx-auto mb-4 leading-relaxed">
        Votre client envoie un message. L'agent lit, comprend, et répond en 3 secondes — avec votre vocabulaire, vos horaires, vos tarifs. Il prend le rendez-vous, qualifie le prospect ou escalade vers vous si besoin.
      </p>
      <p class="text-base text-[#9090b0] max-w-xl mx-auto mb-10">
        Configurable en 7 jours. Disponible 24h/24. Dès 149€/mois sans engagement.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl text-white font-bold text-base transition-all hover:opacity-90" style="background: linear-gradient(135deg, #7c5cfc, #5b3fdb); box-shadow: 0 0 40px rgba(124,92,252,0.3);">
          Voir ce que ça donne pour mon métier →
        </a>
        <a href="/offres" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl text-white font-semibold text-base glass hover:bg-white/10 transition-all">
          Voir les tarifs →
        </a>
      </div>
    </div>
  </section>

  <!-- CE QU'EST UN AGENT IA -->
  <section class="py-20 px-6" style="background: var(--bg-2);">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#7c5cfc] mb-3">Comprendre</p>
        <h2 class="text-4xl font-black text-white mb-4">Qu'est-ce qu'un agent IA, concrètement ?</h2>
        <p class="text-[#9090b0] max-w-2xl mx-auto">Un chatbot classique suit un arbre de décision figé. Un agent IA comprend le langage naturel, s'adapte au contexte et agit — comme un employé, mais sans jamais s'arrêter.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
        {[
          {
            title: 'Chatbot classique',
            tag: '❌ Limité',
            tagColor: 'rgba(239,68,68,0.15)',
            tagText: '#f87171',
            border: 'rgba(239,68,68,0.15)',
            items: ['Répond selon des règles fixes', 'Bloque sur les questions imprévues', 'Ne comprend pas les variantes ("rdv" vs "rendez-vous")', 'Ne prend aucune décision autonome', 'Script à réécrire pour chaque changement'],
            iconColor: '#f87171',
          },
          {
            title: 'ChatGPT / Claude générique',
            tag: '⚠️ Partiel',
            tagColor: 'rgba(251,191,36,0.15)',
            tagText: '#fbbf24',
            border: 'rgba(251,191,36,0.15)',
            items: ['Comprend le langage naturel', 'Répond à tout — même hors sujet', 'Non connecté à votre agenda ou CRM', 'Aucune connaissance de votre activité', 'Requiert une supervision permanente'],
            iconColor: '#fbbf24',
          },
          {
            title: 'Agent IA Vulcia',
            tag: '✅ Complet',
            tagColor: 'rgba(52,211,153,0.15)',
            tagText: '#34d399',
            border: 'rgba(52,211,153,0.3)',
            items: ['Comprend le langage naturel et le contexte', 'Configuré pour VOTRE activité uniquement', 'Connecté à votre agenda, email ou CRM', 'Prend des décisions : réserve, qualifie, escalade', 'Rapport mensuel de toutes les interactions'],
            iconColor: '#34d399',
          },
        ].map(col => (
          <div class="glass rounded-2xl p-6" style={`border-color: ${col.border};`}>
            <div class="flex items-center justify-between mb-5">
              <h3 class="text-white font-bold text-sm">{col.title}</h3>
              <span class="px-2 py-1 rounded-full text-[10px] font-bold" style={`background: ${col.tagColor}; color: ${col.tagText};`}>{col.tag}</span>
            </div>
            <ul class="space-y-2.5">
              {col.items.map(item => (
                <li class="flex items-start gap-2.5 text-xs text-[#9090b0] leading-relaxed">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke={col.iconColor} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CAS D'USAGE PAR SECTEUR -->
  <section class="py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#7c5cfc] mb-3">Par secteur</p>
        <h2 class="text-4xl font-black text-white mb-4">Ce que votre agent IA fait concrètement</h2>
        <p class="text-[#9090b0] max-w-xl mx-auto">Chaque agent est configuré pour les tâches spécifiques à votre activité — pas un clone générique.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {useCases.map(uc => (
          <div class="glass rounded-2xl p-6 flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-2xl">{uc.icon}</span>
              <h3 class="text-white font-black text-sm">{uc.sector}</h3>
            </div>
            <ul class="space-y-2 mb-5 flex-1">
              {uc.tasks.map(t => (
                <li class="flex items-start gap-2 text-xs text-[#9090b0]">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#7c5cfc" stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {t}
                </li>
              ))}
            </ul>
            <div class="rounded-lg px-3 py-2 text-xs font-semibold text-[#34d399] mt-auto" style="background: rgba(52,211,153,0.08); border: 1px solid rgba(52,211,153,0.15);">
              {uc.gain}
            </div>
            <a href={uc.link} class="mt-3 text-xs font-semibold text-[#7c5cfc] hover:text-white transition-colors flex items-center gap-1">
              Guide complet &rarr;
            </a>
          </div>
        ))}
      </div>

      <div class="mt-8 text-center">
        <a href="/contact" class="inline-flex items-center gap-2 text-sm font-bold text-[#7c5cfc] hover:text-white transition-colors">
          Voir un exemple pour mon secteur →
        </a>
      </div>
    </div>
  </section>

  <!-- COMMENT ÇA MARCHE -->
  <section class="py-20 px-6" style="background: var(--bg-2);">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#7c5cfc] mb-3">Déploiement</p>
        <h2 class="text-4xl font-black text-white mb-4">Comment on configure votre agent en 7 jours</h2>
      </div>

      <div class="space-y-4">
        {[
          { n: '01', title: 'Audit de votre activité (Jour 1-2)', desc: 'On analyse vos processus, vos questions fréquentes, votre vocabulaire, vos outils. On définit le périmètre exact de l\'agent : ce qu\'il gère, ce qu\'il escalade.', color: '#7c5cfc' },
          { n: '02', title: 'Configuration et formation (Jour 3-5)', desc: 'On programme l\'agent avec vos paramètres : horaires, tarifs, produits ou services, scripts de réponse, cas limites. On l\'entraîne avec des cas réels de votre activité.', color: '#9b72fc' },
          { n: '03', title: 'Tests et validation avec vous (Jour 6)', desc: 'On vous montre l\'agent en action. Vous testez, vous corrigez, vous validez chaque comportement. Zéro mise en ligne sans votre accord.', color: '#38bdf8' },
          { n: '04', title: 'Mise en ligne et suivi (Jour 7+)', desc: 'L\'agent est déployé sur votre site. Vous recevez l\'accès au tableau de bord. Le premier rapport mensuel arrive dans 30 jours avec toutes les interactions enregistrées.', color: '#34d399' },
        ].map(step => (
          <div class="glass rounded-xl p-6 flex gap-5 items-start">
            <div class="text-2xl font-black flex-shrink-0" style={`color: ${step.color};`}>{step.n}</div>
            <div>
              <h3 class="text-white font-bold mb-1">{step.title}</h3>
              <p class="text-[#9090b0] text-sm leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MODÈLES IA UTILISÉS -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-xs font-bold uppercase tracking-widest text-[#7c5cfc] mb-3">Technologie</p>
        <h2 class="text-4xl font-black text-white mb-4">Les modèles IA derrière vos agents</h2>
        <p class="text-[#9090b0] max-w-xl mx-auto">On choisit le modèle en fonction de vos contraintes — pas celui qu'on a le plus envie de vendre.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {[
          {
            name: 'GPT-4o',
            maker: 'OpenAI',
            color: '#10a37f',
            best: 'Meilleur pour la conversation naturelle et les tâches complexes.',
            use: 'E-commerce, coaching, support client multilingue',
            note: 'Données hébergées aux États-Unis — non recommandé pour les données médicales ou juridiques',
          },
          {
            name: 'Claude Sonnet',
            maker: 'Anthropic',
            color: '#d97706',
            best: 'Excellent pour le raisonnement long et les documents complexes.',
            use: 'Avocats, comptables, analyse de dossiers',
            note: 'Données hébergées aux États-Unis ou EU selon configuration',
          },
          {
            name: 'Mistral Large',
            maker: 'Mistral AI · Paris',
            color: '#7c3aed',
            best: 'Modèle français, hébergé en France, performances équivalentes aux leaders.',
            use: 'Santé, juridique, RH, toute activité avec données sensibles',
            note: '100% RGPD · Données sur le territoire français · Recommandé pour les secteurs réglementés',
          },
        ].map(m => (
          <div class="glass rounded-2xl p-6 flex flex-col" style={`border-color: ${m.color}25;`}>
            <div class="flex items-center justify-between mb-4">
              <div>
                <div class="text-white font-black">{m.name}</div>
                <div class="text-xs" style={`color: ${m.color};`}>{m.maker}</div>
              </div>
              <div class="w-3 h-3 rounded-full flex-shrink-0" style={`background: ${m.color};`}></div>
            </div>
            <p class="text-sm text-[#c0c0e0] mb-3 leading-relaxed">{m.best}</p>
            <p class="text-xs text-[#7c5cfc] font-semibold mb-3">Idéal pour : {m.use}</p>
            <p class="text-xs text-[#8888aa] leading-relaxed mt-auto">{m.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-6" style="background: var(--bg-2);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-black text-white text-center mb-10">Questions sur les agents IA</h2>
      <div class="space-y-2">
        {faqItems.map(faq => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-5 cursor-pointer text-white font-semibold text-sm flex items-center justify-between list-none">
              <span>{faq.q}</span>
              <svg class="w-4 h-4 text-[#8888aa] transition-transform duration-300 group-open:rotate-180 flex-shrink-0 ml-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="px-6 pb-5 pt-2">
              <p class="text-[#8888aa] text-sm leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="glass rounded-3xl p-12 md:p-16 text-center relative overflow-hidden">
        <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, rgba(124,92,252,0.1), transparent 70%);"></div>
        <div class="relative">
          <h2 class="text-4xl font-black text-white mb-4">Prêt à voir ce qu'un agent peut faire pour vous ?</h2>
          <p class="text-[#9090b0] max-w-lg mx-auto mb-8">30 minutes d'audit gratuit. On analyse votre activité et on vous montre concrètement ce que ferait votre agent — avec un chiffrage honnête de ce que ça vous rapporterait.</p>
          <a href="/contact" class="inline-flex items-center gap-2 px-10 py-4 rounded-xl text-white font-bold text-base transition-all hover:opacity-90" style="background: linear-gradient(135deg, #7c5cfc, #5b3fdb); box-shadow: 0 0 40px rgba(124,92,252,0.3);">
            Réserver mon audit gratuit →
          </a>
          <p class="text-xs text-[#8888aa] mt-5">Gratuit · Sans engagement · Réponse sous 24h</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  details summary::-webkit-details-marker { display: none; }
  details[open] summary { color: #a78bfa; }

  .gradient-text {
    background: linear-gradient(135deg, #7c5cfc, #38bdf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .glass {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(12px);
  }
</style>
