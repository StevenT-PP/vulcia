---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "En combien de temps mon site apparaît sur Google ?", "acceptedAnswer": { "@type": "Answer", "text": "Les premiers résultats arrivent en 4 à 8 semaines. Une position stable en première page prend 3 à 6 mois selon la concurrence sur vos mots-clés. Le contenu SEO publié dès le premier mois génère du trafic progressivement et de façon durable." } },
    { "@type": "Question", "name": "Quelle différence entre le SEO local et le SEO national ?", "acceptedAnswer": { "@type": "Answer", "text": "Le SEO local cible les recherches géolocalisées (ex : 'plombier Lyon', 'dentiste Paris 15'). Le SEO national vise des mots-clés sans zone géographique. On combine les deux selon votre activité — une PME locale a tout intérêt à dominer sa zone avant d'aller plus loin." } },
    { "@type": "Question", "name": "Est-ce que le SEO fonctionne encore en 2026 avec les IA ?", "acceptedAnswer": { "@type": "Answer", "text": "Plus que jamais. Google utilise l'IA pour comprendre le contenu, mais le trafic organique reste la source la plus rentable à long terme. On optimise aussi pour les réponses IA (Google AI Overviews, Perplexity, ChatGPT) — c'est le SEO de demain." } },
    { "@type": "Question", "name": "Que se passe-t-il si j'arrête le service SEO ?", "acceptedAnswer": { "@type": "Answer", "text": "Vos positions Google ne disparaissent pas du jour au lendemain — contrairement à Google Ads. Les articles publiés restent indexés et continuent de générer du trafic pendant des mois. Vous partez avec tout votre contenu." } },
    { "@type": "Question", "name": "Produisez-vous les textes ou dois-je les écrire ?", "acceptedAnswer": { "@type": "Answer", "text": "On s'occupe de tout : recherche de mots-clés, rédaction, publication et optimisation. Vous relisez et validez. Vous n'avez pas à écrire une seule ligne si vous ne le souhaitez pas." } }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Référencement SEO pour PME",
  "provider": { "@type": "Organization", "name": "Vulcia", "url": "https://vulcia.fr" },
  "description": "Référencement Google sur-mesure pour PME françaises. SEO local, SEO national, contenu optimisé, schema markup. Résultats en 3 mois.",
  "areaServed": { "@type": "Country", "name": "France" },
  "offers": { "@type": "AggregateOffer", "priceCurrency": "EUR", "lowPrice": "349", "highPrice": "1490", "offerCount": "3", "description": "Abonnement mensuel sans engagement" }
};
---

<Layout
  title="Référencement SEO Google pour PME françaises | Vulcia"
  description="Votre site en 1ère page Google en 3 mois. SEO local, national et IA-ready. Contenu optimisé, schema markup, audit gratuit. Dès 349€/mois sans engagement."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />

  <Nav />

  <!-- Hero -->
  <section class="pt-32 pb-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div style="position:absolute;width:700px;height:700px;top:-10%;right:0%;background:radial-gradient(circle,rgba(52,211,153,0.12),transparent 70%);filter:blur(80px);"></div>
      <div style="position:absolute;width:400px;height:400px;bottom:-10%;left:5%;background:radial-gradient(circle,rgba(124,92,252,0.1),transparent 70%);filter:blur(80px);"></div>
    </div>
    <div class="max-w-4xl mx-auto text-center relative">
      <p class="text-xs font-bold uppercase tracking-widest text-[#34d399] mb-4">Référencement SEO</p>
      <h1 class="text-5xl md:text-6xl font-black text-white leading-[1.05] mb-6">
        Vos clients vous trouvent<br />
        <span style="background: linear-gradient(135deg, #34d399, #38bdf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">sur Google. Pas vos concurrents.</span>
      </h1>
      <p class="text-xl text-[#9090b0] max-w-2xl mx-auto mb-10 leading-relaxed">SEO technique, contenu optimisé, SEO local et visibilité sur les IA (Perplexity, ChatGPT). Résultats durables — sans payer Google Ads à l'infini.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl text-white font-bold text-base transition-all hover:opacity-90" style="background: linear-gradient(135deg, #34d399, #38bdf8); box-shadow: 0 0 40px rgba(52,211,153,0.25);">Audit SEO gratuit →</a>
        <a href="/tarifs" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl text-white font-semibold text-base glass hover:bg-white/10 transition-all">Voir les tarifs →</a>
      </div>
    </div>
  </section>

  <!-- Les 4 leviers -->
  <section class="py-20 px-6" style="background: var(--bg-2);">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#34d399] mb-3">Notre méthode</p>
        <h2 class="text-4xl font-black text-white mb-4">Les 4 leviers qui font remonter votre site</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { n: '01', color: '#38bdf8', title: 'SEO technique', desc: 'La fondation. Vitesse de chargement, structure des URLs, balises, schema markup, sitemap. Googlebot doit pouvoir crawler et comprendre votre site sans obstacle.', items: ['Core Web Vitals optimisés', 'Schema JSON-LD (FAQPage, LocalBusiness…)', 'Canonical + redirections 301', 'Sitemap XML dynamique'] },
          { n: '02', color: '#7c5cfc', title: 'Contenu SEO', desc: 'La masse. Articles de blog, pages secteur, guides pratiques — ciblant les mots-clés que vos clients tapent réellement sur Google.', items: ['Recherche de mots-clés longue traîne', '4 à 8 articles par mois', 'Pages "IA pour [secteur]"', 'Maillage interne optimisé'] },
          { n: '03', color: '#34d399', title: 'SEO local', desc: "Dominez votre ville et votre secteur d'activité. Google Business Profile, citations locales, avis clients et pages géolocalisées.", items: ['Optimisation Google Business Profile', 'Citations NAP cohérentes', 'Pages villes sur-mesure', 'Stratégie avis Google'] },
          { n: '04', color: '#f59e0b', title: 'SEO pour les IA', desc: 'Le SEO de demain. Optimisez votre contenu pour être cité par ChatGPT, Perplexity et Google AI Overviews — la nouvelle source de trafic organique.', items: ['llms.txt optimisé', 'Passages extractibles', 'Autorité thématique forte', 'Structured data complètes'] },
        ].map(l => (
          <div class="glass rounded-2xl p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-2xl font-black" style={`color: ${l.color};`}>{l.n}</span>
              <h3 class="text-white font-black">{l.title}</h3>
            </div>
            <p class="text-[#9090b0] text-sm leading-relaxed mb-4">{l.desc}</p>
            <ul class="space-y-1.5">
              {l.items.map(item => (
                <li class="flex items-center gap-2 text-xs text-[#9090b0]">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke={l.color} stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline résultats -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#34d399] mb-3">Résultats</p>
        <h2 class="text-4xl font-black text-white mb-4">Ce que vous pouvez attendre, mois par mois</h2>
      </div>
      <div class="space-y-4">
        {[
          { label: 'Mois 1', color: '#38bdf8', title: 'Fondations posées', desc: 'Audit SEO complet, corrections techniques, Google Search Console configuré, sitemap soumis. Les premiers articles sont publiés et indexés.' },
          { label: 'Mois 2–3', color: '#7c5cfc', title: 'Trafic qui monte', desc: 'Les articles commencent à remonter sur des requêtes longue traîne. Premières positions sur les mots-clés sectoriels. Le GSC montre des impressions croissantes.' },
          { label: 'Mois 4–6', color: '#34d399', title: 'Première page Google', desc: 'Positionnement stable sur vos mots-clés cibles. Trafic organique mensuel en croissance constante. Premiers leads entrants depuis Google.' },
          { label: 'Mois 6+', color: '#f59e0b', title: 'Effet boule de neige', desc: 'Le contenu existant génère du trafic sans effort supplémentaire. Chaque nouvel article amplifie les précédents. Le ROI du SEO dépasse celui de Google Ads.' },
        ].map(r => (
          <div class="glass rounded-xl p-6 flex gap-5 items-start">
            <div class="flex-shrink-0 text-xs font-bold px-3 py-1.5 rounded-full" style={`background: ${r.color}18; color: ${r.color};`}>{r.label}</div>
            <div>
              <h3 class="text-white font-bold mb-1">{r.title}</h3>
              <p class="text-[#9090b0] text-sm leading-relaxed">{r.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SEO vs Ads -->
  <section class="py-20 px-6" style="background: var(--bg-2);">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-black text-white mb-3">SEO ou Google Ads ?</h2>
        <p class="text-[#9090b0]">Les deux ont leur place. Voici quand choisir lequel.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="glass rounded-2xl p-6" style="border-color: rgba(52,211,153,0.2);">
          <h3 class="text-white font-black mb-4">SEO <span class="text-xs font-normal text-[#34d399]">Vulcia</span></h3>
          <ul class="space-y-2.5">
            {['Trafic gratuit après 3-6 mois', 'Résultats durables (même si vous arrêtez)', 'Crédibilité — les gens font confiance aux résultats naturels', 'Cumule avec le temps', 'ROI qui explose à 12 mois'].map(f => (
              <li class="flex items-start gap-2 text-sm text-[#9090b0]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
        <div class="glass rounded-2xl p-6" style="border-color: rgba(251,191,36,0.15);">
          <h3 class="text-white font-black mb-4">Google Ads</h3>
          <ul class="space-y-2.5">
            {["Résultats immédiats", "Trafic s'arrête dès qu'on coupe le budget", "Coûteux sur la durée (CPC croissant)", "Méfiance des utilisateurs envers les annonces", "Adapté aux lancements ou promotions"].map(f => (
              <li class="flex items-start gap-2 text-sm text-[#9090b0]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2.5" class="flex-shrink-0 mt-0.5"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-black text-white text-center mb-10">Questions sur le référencement</h2>
      <div class="space-y-2">
        {[
          { q: 'En combien de temps mon site apparaît sur Google ?', a: "Les premiers résultats arrivent en 4 à 8 semaines. Une position stable en première page prend 3 à 6 mois selon la concurrence sur vos mots-clés." },
          { q: 'Quelle différence entre le SEO local et le SEO national ?', a: "Le SEO local cible les recherches géolocalisées (ex : 'plombier Lyon'). Le SEO national vise des mots-clés sans zone géographique. On combine les deux selon votre activité." },
          { q: 'Est-ce que le SEO fonctionne encore en 2026 avec les IA ?', a: "Plus que jamais. Google utilise l'IA pour comprendre le contenu, mais le trafic organique reste la source la plus rentable à long terme. On optimise aussi pour ChatGPT, Perplexity et Google AI Overviews." },
          { q: "Que se passe-t-il si j'arrête le service SEO ?", a: "Vos positions Google ne disparaissent pas du jour au lendemain. Les articles publiés restent indexés et continuent de générer du trafic pendant des mois." },
          { q: 'Produisez-vous les textes ou dois-je les écrire ?', a: "On s'occupe de tout : recherche de mots-clés, rédaction, publication et optimisation. Vous relisez et validez." },
        ].map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-5 cursor-pointer text-white font-semibold text-sm flex items-center justify-between list-none">
              <span>{item.q}</span>
              <svg class="w-4 h-4 text-[#8888aa] transition-transform duration-300 group-open:rotate-180 flex-shrink-0 ml-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </summary>
            <div class="px-6 pb-5 pt-2">
              <p class="text-[#8888aa] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-20 px-6" style="background: var(--bg-2);">
    <div class="max-w-4xl mx-auto">
      <div class="glass rounded-3xl p-12 md:p-16 text-center relative overflow-hidden">
        <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, rgba(52,211,153,0.08), transparent 70%);"></div>
        <div class="relative">
          <h2 class="text-4xl font-black text-white mb-4">Audit SEO gratuit de votre site</h2>
          <p class="text-[#9090b0] max-w-lg mx-auto mb-8">On analyse votre site, vos concurrents et vos mots-clés cibles. On vous dit où vous en êtes et ce qui bloque votre visibilité Google — gratuitement, en 30 minutes.</p>
          <a href="/contact" class="inline-flex items-center gap-2 px-10 py-4 rounded-xl text-white font-bold text-base transition-all hover:opacity-90" style="background: linear-gradient(135deg, #34d399, #38bdf8); box-shadow: 0 0 40px rgba(52,211,153,0.25);">Demander mon audit SEO →</a>
          <p class="text-xs text-[#8888aa] mt-5">Gratuit · Sans engagement · Réponse sous 24h</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  details summary::-webkit-details-marker { display: none; }
  details[open] summary { color: #34d399; }
</style>
