  .label-tag { display: inline-block; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #7c5cfc; }

  /* Buttons */
  .btn-primary { display: inline-flex; padding: 0.875rem 2rem; border-radius: 0.75rem; color: white; font-weight: 700; font-size: 0.9rem; background: linear-gradient(135deg, #7c5cfc, #5b3fdb); box-shadow: 0 0 40px rgba(124,92,252,0.3); transition: all 0.2s; }
  .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 0 60px rgba(124,92,252,0.45); }
  .btn-ghost { display: inline-flex; padding: 0.875rem 1.75rem; border-radius: 0.75rem; color: white; font-weight: 600; font-size: 0.9rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); transition: all 0.2s; }
  .btn-ghost:hover { background: rgba(255,255,255,0.1); }

  /* Sector tabs */
  .sector-tab { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: #8888aa; border-radius: 9999px; padding: 0.5rem 1rem; font-size: 0.8rem; font-weight: 600; transition: all 0.2s; cursor: pointer; }
  .sector-tab:hover { background: rgba(124,92,252,0.1); border-color: rgba(124,92,252,0.3); color: white; }
  .sector-tab.sector-active { background: linear-gradient(135deg, #7c5cfc, #5b3fdb); border-color: transparent; color: white; box-shadow: 0 0 20px rgba(124,92,252,0.3); }

  /* Service cards */
  .service-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); transition: border-color 0.3s, background 0.3s; }
  .service-card:hover { background: rgba(255,255,255,0.05); border-color: rgba(124,92,252,0.2); }
  .glow-hover { position: absolute; inset: 0; opacity: 0; background: radial-gradient(circle at 30% 40%, color-mix(in srgb, var(--gc) 8%, transparent), transparent 60%); transition: opacity 0.4s; pointer-events: none; z-index: 0; }
  .service-card:hover .glow-hover { opacity: 1; }

  /* Icon chip */
  .icon-chip { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; background: color-mix(in srgb, var(--c) 10%, transparent); border: 1px solid color-mix(in srgb, var(--c) 20%, transparent); }

  /* Typing dots */
  .typing-dot { animation: typingBounce 1s infinite ease-in-out; }
  @keyframes typingBounce { 0%,100% { transform: translateY(0); opacity: 0.4; } 50% { transform: translateY(-3px); opacity: 1; } }

  /* SEO bars */
  .seo-bar { width: 0; transition: width 1.2s ease-out; }

  /* FAQ */
  details summary::-webkit-details-marker { display: none; }
  details[open] summary { color: #a78bfa; }

  @media (prefers-reduced-motion: reduce) {
    .blob, .typing-dot { animation: none; }
    .pulse-dot::before { animation: none; }
    * { transition-duration: 0.01ms !important; }
  }
</style>

<script>
  // Scroll reveals
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        (e.target as HTMLElement).style.opacity = '1';
        (e.target as HTMLElement).style.transform = 'translateY(0)';
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.reveal, .reveal-right').forEach(el => {
    (el as HTMLElement).style.opacity = '0';
    (el as HTMLElement).style.transform = 'translateY(24px)';
    io.observe(el);
  });

  // SEO bars
  const barIO = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.width = '80%';
        barIO.unobserve(e.target);
      }
    });
  }, { threshold: 0.2 });
  document.querySelectorAll('.seo-bar').forEach(b => barIO.observe(b));

  // ROI bars
  const roiIO = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.transition = 'width 1.2s ease-out 0.3s';
        (e.target as HTMLElement).style.width = '80%';
        roiIO.unobserve(e.target);
      }
    });
  }, { threshold: 0.2 });
  document.querySelectorAll('.roi-bar').forEach(b => roiIO.observe(b));

  // Process cards stagger
  document.querySelectorAll('.process-card').forEach((el, i) => {
    (el as HTMLElement).style.opacity = '0';
    (el as HTMLElement).style.transform = 'translateY(20px)';
    const cardIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          setTimeout(() => {
            (e.target as HTMLElement).style.transition = `opacity 0.5s ease ${i * 100}ms, transform 0.5s ease ${i * 100}ms`;
            (e.target as HTMLElement).style.opacity = '1';
            (e.target as HTMLElement).style.transform = 'translateY(0)';
          }, i * 80);
          cardIO.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    cardIO.observe(el);
  });

  // Sector tabs
  const tabs = document.querySelectorAll<HTMLElement>('.sector-tab');
  const panels = document.querySelectorAll<HTMLElement>('.sector-panel');

  tabs.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      tabs.forEach(b => b.classList.remove('sector-active'));
      panels.forEach(p => p.classList.add('hidden'));
      btn.classList.add('sector-active');
      panels[i].classList.remove('hidden');
    });
  });
</script>
