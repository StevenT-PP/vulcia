---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const sectors = [
  {
    emoji: '🏥', name: 'Médecin / Dentiste',
    subtitle: 'Vos rendez-vous se remplissent seuls. Vos patients ne patientent plus.',
    gains: [
      'Réserve les RDV directement dans votre agenda en ligne',
      'Répond aux messages à toute heure, même le week-end à 23h',
      'Envoie des rappels automatiques — les oublis de RDV disparaissent',
      'Explique les tarifs, les actes, ce qui est remboursé par la Sécu',
      'Gère les annulations et propose les créneaux libres immédiatement',
    ],
    result: '14h récupérées par semaine', resultSub: 'Gain estimé pour ce type de cabinet', resultEmoji: '⏰',
    conv: [
      { c: true, t: "Bonjour, j'aurais besoin d'un RDV pour un détartrage. Je suis libre jeudi après-midi ou vendredi matin." },
      { c: false, t: "Bonjour ! J'ai un créneau jeudi 26 juin à 15h ou vendredi 27 juin à 9h30. Laquelle vous convient ?" },
      { c: true, t: "Vendredi 9h30, c'est parfait !" },
      { c: false, t: "✅ RDV confirmé vendredi 27 juin à 9h30 avec Dr. Martin. Vous recevrez un SMS de rappel la veille. À vendredi !" },
    ],
  },
  {
    emoji: '🍽️', name: 'Restaurant / Hôtel',
    subtitle: 'Votre salle est toujours pleine. Sans décrocher le téléphone.',
    gains: [
      'Gère les réservations de table 24h/24, 7j/7, en quelques secondes',
      'Répond aux questions sur le menu, les allergènes, les horaires',
      'Envoie une confirmation automatique + rappel la veille',
      'Répond aux avis Google pour améliorer votre réputation en ligne',
      'Envoie vos promotions du soir aux clients réguliers par SMS',
    ],
    result: '+40% de réservations confirmées', resultSub: 'Potentiel estimé pour ce secteur', resultEmoji: '📅',
    conv: [
      { c: true, t: "Bonsoir, vous avez de la place vendredi soir pour 4 personnes vers 20h ?" },
      { c: false, t: "Bonsoir ! Oui, une table est disponible vendredi 27/06 à 20h pour 4 personnes. Je réserve à votre nom ?" },
      { c: true, t: "Oui s'il vous plaît, au nom de Martin" },
      { c: false, t: "✅ C'est noté ! Vendredi 27 juin, 20h, 4 personnes — M. Martin. Nous vous attendons avec plaisir !" },
    ],
  },
  {
    emoji: '🔧', name: 'Artisan / BTP',
    subtitle: 'Votre téléphone ne sonne plus en plein milieu d\'un chantier.',
    gains: [
      'Collecte toutes les infos nécessaires pour établir un devis automatique',
      'Identifie et priorise les urgences (fuite, panne électrique, sinistre…)',
      'Prend les RDV d\'intervention et envoie une confirmation par SMS',
      'Répond aux questions sur vos tarifs, délais et zones d\'intervention',
      'Relance les devis non signés sans que vous y pensiez',
    ],
    result: '-60% de temps passé à gérer les appels', resultSub: 'Potentiel estimé pour ce secteur', resultEmoji: '📞',
    conv: [
      { c: true, t: "Mon robinet fuit depuis ce matin, c'est urgent. Vous pouvez intervenir ?" },
      { c: false, t: "Bonjour ! Quelle est votre adresse et quel type de fuite (robinet, tuyau, joint) ?" },
      { c: true, t: "12 rue des Fleurs Lyon 6, joint du robinet de l'évier" },
      { c: false, t: "✅ Un plombier peut intervenir aujourd'hui entre 14h et 17h. Devis estimé : 60–80€. SMS de confirmation envoyé !" },
    ],
  },
  {
    emoji: '🛒', name: 'E-commerce',
    subtitle: 'Votre service client tourne seul. Vos ventes grimpent.',
    gains: [
      'Répond instantanément aux questions produits, délais et retours',
      'Recommande des produits personnalisés selon le profil du client',
      'Relance automatiquement les paniers abandonnés',
      'Gère le SAV et les réclamations sans intervention humaine',
      'Génère les fiches produits optimisées pour Google automatiquement',
    ],
    result: '+31% de taux de conversion', resultSub: 'Potentiel estimé pour ce secteur', resultEmoji: '📈',
    conv: [
      { c: true, t: "J'ai commandé il y a 5 jours et je n'ai toujours rien reçu. Commande #8472." },
      { c: false, t: "Bonjour ! Commande #8472 expédiée le 21/06 — livraison prévue demain avant 18h. Un bon de 10% vous est offert pour ce délai." },
      { c: true, t: "Ah ok, merci c'est rassurant !" },
      { c: false, t: "Avec plaisir ! Votre bon est valable 30 jours. Bonne réception !" },
    ],
  },
  {
    emoji: '🏠', name: 'Immobilier',
    subtitle: 'Vos leads ne refroidissent plus. Vos visites se remplissent seules.',
    gains: [
      'Qualifie chaque acheteur ou vendeur potentiel en moins de 5 minutes',
      'Programme les visites directement dans votre agenda',
      'Envoie automatiquement les biens correspondant aux critères du client',
      'Répond aux questions sur les biens (surface, DPE, quartier, prix)',
      'Suit les dossiers de A à Z jusqu\'à la promesse de vente',
    ],
    result: '+40% de leads convertis en visites', resultSub: 'Potentiel estimé pour ce secteur', resultEmoji: '🎯',
    conv: [
      { c: true, t: "Bonjour, je cherche un T3 à Lyon, budget 280 000€ max, proche des transports." },
      { c: false, t: "Bonjour ! J'ai 3 biens correspondant à vos critères. Je vous envoie les fiches. Disponible pour une visite cette semaine ?" },
      { c: true, t: "Oui, jeudi ou vendredi" },
      { c: false, t: "✅ Visite programmée jeudi 26/06 à 10h — 47 rue Garibaldi, Lyon 7e. Fiche complète et plan d'accès envoyés par email." },
    ],
  },
  {
    emoji: '⚖️', name: 'Avocat / Comptable',
    subtitle: 'Vos dossiers sont triés avant même que vous arriviez au bureau.',
    gains: [
      'Qualifie chaque cas avant le premier RDV — 20 minutes économisées par dossier',
      'Collecte automatiquement toutes les pièces justificatives nécessaires',
      'Explique les procédures et délais aux clients qui attendent une réponse',
      'Prend les rendez-vous et envoie le questionnaire préalable',
      'Archive et classe les documents clients sans intervention humaine',
    ],
    result: '22h d\'administration économisées par semaine', resultSub: 'Potentiel estimé pour ce secteur', resultEmoji: '📂',
    conv: [
      { c: true, t: "Bonjour, mon propriétaire refuse de me rendre ma caution depuis 3 mois. C'est 1 200€." },
      { c: false, t: "C'est un litige locatif classique. Avez-vous un état des lieux de sortie et des preuves de paiement de loyers ?" },
      { c: true, t: "Oui, j'ai tout ça" },
      { c: false, t: "Parfait. Un avocat vous rappelle sous 24h. Je vous envoie le questionnaire préalable — il réduira votre consultation de 30 minutes." },
    ],
  },
  {
    emoji: '📚', name: 'Coach / Formateur',
    subtitle: 'Vos formations se vendent pendant que vous êtes en séance.',
    gains: [
      'Qualifie les candidats à votre programme avant tout entretien',
      'Répond aux questions sur le contenu, les prérequis et les résultats attendus',
      'Gère les inscriptions et envoie les accès automatiquement',
      'Envoie les supports pédagogiques et rappels de session',
      'Suit la progression de vos élèves et envoie des relances de motivation',
    ],
    result: '+3 000€/mois de chiffre d\'affaires additionnel', resultSub: 'Potentiel estimé pour ce secteur', resultEmoji: '💰',
    conv: [
      { c: true, t: "Votre formation \"Lancer son business\" convient-elle à un débutant complet ?" },
      { c: false, t: "Bonjour ! Oui, 80% de nos élèves n'avaient jamais lancé d'activité avant notre programme. Je vous envoie le programme détaillé ?" },
      { c: true, t: "Oui et comment je m'inscris ?" },
      { c: false, t: "✅ Programme envoyé ! Prochaine session : 1er juillet, 20 places disponibles. Lien d'inscription valable 48h." },
    ],
  },
];
---

<Layout
  title="IAForge — Agent IA pour votre métier | Opérationnel en 7 jours"
  description="IAForge déploie des agents IA sur-mesure, une stratégie SEO automatisée et des sites haute performance pour les PME françaises. Audit gratuit en 30 minutes."
>
  <script type="application/ld+json" slot="head">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Je ne connais rien à l'IA. Est-ce que ça marche quand même pour moi ?",
        "acceptedAnswer": { "@type": "Answer", "text": "Oui. C'est précisément pour ça qu'on existe. Vous n'avez pas besoin de comprendre comment fonctionne l'IA — vous voyez ce qu'elle fait et les résultats qu'elle génère. On s'occupe de tout. Vous vous concentrez sur votre métier." }
      },
      {
        "@type": "Question",
        "name": "Combien de temps avant de voir des résultats concrets ?",
        "acceptedAnswer": { "@type": "Answer", "text": "Votre assistant IA est opérationnel en 7 à 14 jours. Le référencement Google prend 2 à 4 mois pour remonter sur les premières pages. Mais le contenu est publié dès le premier mois et votre assistant travaille dès le premier jour." }
      },
      {
        "@type": "Question",
        "name": "Quelle est la durée d'engagement ?",
        "acceptedAnswer": { "@type": "Answer", "text": "Aucun engagement long terme imposé. Vous résiliez chaque mois si vous le souhaitez. On préfère vous garder parce qu'on délivre des résultats, pas parce qu'un contrat vous y oblige." }
      },
      {
        "@type": "Question",
        "name": "Mes données clients sont-elles sécurisées ?",
        "acceptedAnswer": { "@type": "Answer", "text": "Vos données vous appartiennent entièrement. Pour les secteurs sensibles (santé, juridique, comptabilité), on travaille avec Mistral AI — hébergé en France — pour que vos données ne quittent pas le territoire européen." }
      },
      {
        "@type": "Question",
        "name": "Combien coûte un agent IA avec IAForge ?",
        "acceptedAnswer": { "@type": "Answer", "text": "Le Pack Solo commence à 149€/mois pour 1 agent IA sur votre site existant. Le Pack Essentiel (site + 2 agents + SEO) est à 349€/mois. Le Pack Croissance (complet) est à 790€/mois. 0€ de frais d'installation sur tous les packs. Sans engagement de durée." }
      },
      {
        "@type": "Question",
        "name": "Est-ce que ça marche pour une très petite entreprise ?",
        "acceptedAnswer": { "@type": "Answer", "text": "Oui, et souvent encore mieux. Les TPE et artisans sont ceux qui gagnent le plus de temps proportionnellement — parce qu'ils font tout seuls. Un assistant virtuel à 149€/mois peut remplacer des heures de gestion administrative quotidienne." }
      }
    ]
  })}</script>
  <Nav />

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center overflow-hidden pt-24 pb-16 px-6">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="grid-bg"></div>
      <div class="vignette"></div>
    </div>

    <div class="relative max-w-7xl mx-auto w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <div>
          <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full glass mb-8 reveal">
            <span class="pulse-dot"></span>
            <span class="text-xs text-[#8888aa] font-medium">Agence IA · France entière · Opérationnel en 7 jours</span>
          </div>

          <h1 class="text-[clamp(2.4rem,5vw,4.5rem)] font-black leading-[1.05] tracking-tight mb-6 reveal">
            <span class="text-white">Un assistant IA qui répond,</span><br/>
            <span class="gradient-text">qualifie et réserve pour vous.</span><br/>
            <span class="text-white">24h/24. Configuré en 7 jours.</span>
          </h1>

          <p class="text-lg text-[#9090b0] leading-relaxed mb-4 max-w-lg reveal">
            Votre client écrit sur votre site. L'agent répond en 3 secondes, pose les bonnes questions, prend le rendez-vous ou qualifie la demande — avec votre vocabulaire, vos horaires, vos tarifs. Pas un chatbot générique.
          </p>
          <div class="space-y-2 mb-8 max-w-lg reveal">
            {[
              'Disponible 24h/24 — y compris le dimanche à 23h',
              'Configuré pour votre secteur, pas copié-collé',
              'Dès 149€/mois · 0€ d\'installation · Garanti 90 jours',
            ].map(item => (
              <div class="flex items-center gap-2.5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#7c5cfc" stroke-width="2.5" class="flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-sm text-[#c0c0e0]">{item}</span>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mb-10 reveal">
            <a href="/contact" class="btn-primary flex items-center justify-center gap-2 group">
              Audit gratuit — 30 min
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-1 transition-transform duration-200"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#secteurs" class="btn-ghost flex items-center justify-center gap-2">
              Voir pour mon métier
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
            </a>
          </div>

          <div class="flex flex-wrap gap-6 reveal">
            {[
              { v: '149€', l: 'Prix d\'entrée / mois' },
              { v: '0€', l: 'Frais d\'installation' },
              { v: '90j', l: 'Résultat garanti' },
            ].map(m => (
              <div>
                <div class="text-2xl font-black text-white">{m.v}</div>
                <div class="text-xs text-[#8888aa] mt-0.5">{m.l}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Mockup hero -->
        <div class="relative reveal-right hidden lg:block">
          <div class="absolute inset-0 rounded-3xl opacity-30" style="background: radial-gradient(circle at 50% 50%, #7c5cfc, transparent 70%); filter: blur(40px);"></div>

          <div class="relative rounded-2xl overflow-hidden border border-white/10" style="background: #0d0d1a;">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5" style="background: rgba(255,255,255,0.03);">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full" style="background:#ff5f57;"></div>
                <div class="w-3 h-3 rounded-full" style="background:#febc2e;"></div>
                <div class="w-3 h-3 rounded-full" style="background:#28c840;"></div>
              </div>
              <div class="flex-1 mx-4 px-3 py-1 rounded text-xs text-[#8888aa]" style="background: rgba(255,255,255,0.04);">
                agent.iaforge.fr — Tableau de bord
              </div>
            </div>

            <div class="p-5">
              <div class="flex items-center justify-between mb-5">
                <div>
                  <div class="text-white font-bold text-sm">Agent RDV — Cabinet Dr. Martin</div>
                  <div class="text-xs text-[#8888aa]">Actif depuis 14 jours</div>
                </div>
                <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold text-[#34d399]" style="background: rgba(52,211,153,0.1); border: 1px solid rgba(52,211,153,0.2);">
                  <div class="w-1.5 h-1.5 rounded-full bg-[#34d399] animate-pulse"></div>
                  En ligne
                </div>
              </div>

              <div class="grid grid-cols-3 gap-3 mb-5">
                {[
                  { v: '142', l: 'Demandes traitées', c: '#7c5cfc' },
                  { v: '38', l: 'RDV confirmés', c: '#38bdf8' },
                  { v: '14h', l: 'Temps économisé', c: '#34d399' },
                ].map(s => (
                  <div class="rounded-xl p-3 text-center" style={`background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);`}>
                    <div class="text-lg font-black mb-0.5" style={`color: ${s.c};`}>{s.v}</div>
                    <div class="text-[10px] text-[#8888aa] leading-tight">{s.l}</div>
                  </div>
                ))}
              </div>

              <div class="rounded-xl p-4 space-y-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                <div class="text-xs text-[#8888aa] mb-2 font-semibold uppercase tracking-wider">Conversation en temps réel</div>

                <div class="flex gap-2 items-start">
                  <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center text-xs" style="background: rgba(255,255,255,0.08);">👤</div>
                  <div class="rounded-xl rounded-tl-sm px-3 py-2 text-xs text-[#c0c0e0] max-w-[80%]" style="background: rgba(255,255,255,0.06);">
                    Bonjour, je voudrais prendre un RDV pour un détartrage, disponible jeudi ou vendredi matin
                  </div>
                </div>

                <div class="flex gap-2 items-start justify-end">
                  <div class="rounded-xl rounded-tr-sm px-3 py-2 text-xs text-white max-w-[80%]" style="background: linear-gradient(135deg, rgba(124,92,252,0.4), rgba(56,189,248,0.3)); border: 1px solid rgba(124,92,252,0.3);">
                    Bonjour ! Je peux vous proposer jeudi 26 juin à 9h30 ou vendredi 27 juin à 10h00. Une préférence ?
                  </div>
                  <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-bold" style="background: linear-gradient(135deg, #7c5cfc, #38bdf8);">IA</div>
                </div>

                <div class="flex gap-2 items-start">
                  <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center text-xs" style="background: rgba(255,255,255,0.08);">👤</div>
                  <div class="rounded-xl rounded-tl-sm px-3 py-2 text-xs text-[#c0c0e0]" style="background: rgba(255,255,255,0.06);">
                    Jeudi 9h30 c'est parfait !
                  </div>
                </div>

                <div class="flex gap-2 items-start justify-end">
                  <div class="rounded-xl rounded-tr-sm px-3 py-2 text-xs text-white" style="background: linear-gradient(135deg, rgba(124,92,252,0.4), rgba(56,189,248,0.3)); border: 1px solid rgba(124,92,252,0.3);">
                    ✅ RDV confirmé ! Jeudi 26 juin à 9h30 avec Dr. Martin. Un SMS de rappel la veille.
                  </div>
                  <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center text-xs font-bold" style="background: linear-gradient(135deg, #7c5cfc, #38bdf8);">IA</div>
                </div>

                <div class="flex items-center gap-2 text-[10px] text-[#8888aa]">
                  <div class="flex gap-1">
                    <div class="w-1.5 h-1.5 rounded-full bg-[#7c5cfc] typing-dot" style="animation-delay:0ms"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-[#7c5cfc] typing-dot" style="animation-delay:160ms"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-[#7c5cfc] typing-dot" style="animation-delay:320ms"></div>
                  </div>
                  Agent traite 3 nouvelles demandes…
                </div>
              </div>
            </div>
          </div>

          <div class="absolute -bottom-4 -left-4 glass rounded-xl px-4 py-3 flex items-center gap-3 border border-white/10">
            <div class="text-2xl">⚡</div>
            <div>
              <div class="text-white font-bold text-sm">Réponse en 3 secondes</div>
              <div class="text-[#8888aa] text-xs">vs 4h en moyenne par email</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       BARRE DE CONFIANCE
  ══════════════════════════════════════ -->
  <div class="border-y border-white/5 py-5 px-6" style="background: rgba(255,255,255,0.015);">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-3">
        <span class="text-[10px] text-[#555570] uppercase tracking-widest font-semibold flex-shrink-0">Propulsé par</span>
        {[
          { label: 'GPT-4o', color: '#10a37f' },
          { label: 'Claude Sonnet', color: '#d97706' },
          { label: 'Mistral Large', color: '#7c3aed' },
          { label: 'Gemini Pro', color: '#4285f4' },
          { label: 'Données FR', color: '#002395' },
          { label: 'Cloudflare', color: '#f38020' },
        ].map(t => (
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background: ${t.color};`}></span>
            <span class="text-sm font-semibold text-[#8888aa]">{t.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════
       SECTEURS — tabs interactifs
  ══════════════════════════════════════ -->
  <section id="secteurs" class="py-24 px-6" style="background: var(--bg-2);">
    <div class="max-w-7xl mx-auto">

      <div class="text-center mb-12 reveal">
        <p class="label-tag mb-3">Pour tous les métiers</p>
        <h2 class="text-4xl md:text-5xl font-black text-white">Concrètement, votre agent IA<br/><span class="gradient-text">fait quoi ?</span></h2>
        <p class="text-[#9090b0] mt-4 max-w-2xl mx-auto text-base">Un client envoie un message sur votre site. L'agent lit sa demande, comprend ce qu'il veut, et répond en quelques secondes — comme vous le feriez, mais sans que vous soyez là. Il peut prendre un rendez-vous, envoyer un devis, répondre à une question ou qualifier un prospect. Configuré pour votre vocabulaire, vos horaires, votre façon de travailler. Choisissez votre métier pour voir :</p>
      </div>

      <!-- Tabs -->
      <div class="flex flex-wrap justify-center gap-2 mb-10" id="sector-tabs">
        {sectors.map((s, i) => (
          <button
            class:list={['sector-tab', i === 0 ? 'sector-active' : '']}
            data-sector={i}
            type="button"
          >
            <span>{s.emoji}</span> {s.name}
          </button>
        ))}
      </div>

      <!-- Panels -->
      {sectors.map((s, i) => (
        <div
          class:list={['sector-panel', i !== 0 ? 'hidden' : '']}
          data-panel={i}
        >
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">

            <!-- Gauche : Ce que ça fait -->
            <div class="glass rounded-2xl p-8 flex flex-col">
              <div class="text-4xl mb-4">{s.emoji}</div>
              <h3 class="text-2xl font-black text-white mb-2">{s.name}</h3>
              <p class="text-[#9090b0] mb-6 leading-relaxed">{s.subtitle}</p>

              <ul class="space-y-3 mb-8 flex-1">
                {s.gains.map(g => (
                  <li class="flex items-start gap-3">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#7c5cfc" stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="text-sm text-[#c0c0e0] leading-relaxed">{g}</span>
