---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact & Audit IA Gratuit | Vulcia"
  description="Réservez votre audit IA gratuit de 30 minutes. On identifie vos gains de temps et d'argent, sans engagement. Vulcia, agence IA France."
>
  <Nav />

  <section class="min-h-screen pt-32 pb-24 px-6">
    <div class="max-w-6xl mx-auto">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">

        <!-- Left: Info -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-[#7c5cfc] mb-4">Audit gratuit</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Parlez-nous de<br/><span class="gradient-text">votre projet</span>
          </h1>
          <p class="text-[#8888aa] leading-relaxed mb-10">
            En 30 minutes, on analyse votre situation et on vous propose un plan d'action concret avec un ROI estime. Aucun engagement, aucune pression commerciale.
          </p>

          <div class="space-y-6">
            {[
              { icon: '⚡', title: 'Réponse en moins de 24h', desc: 'On prend le temps de comprendre votre besoin avant de vous rappeler.' },
              { icon: '🎯', title: 'Audit personnalisé', desc: 'Pas de présentation générique. On analyse votre site, vos processus, votre marché.' },
              { icon: '📊', title: 'ROI chiffré', desc: 'On vous sort un potentiel de gain concret avant de signer quoi que ce soit.' },
            ].map(item => (
              <div class="flex items-start gap-4">
                <div class="text-2xl">{item.icon}</div>
                <div>
                  <h3 class="text-white font-semibold text-sm mb-1">{item.title}</h3>
                  <p class="text-[#8888aa] text-sm">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-10 glass rounded-2xl p-6">
            <p class="text-white font-semibold text-sm mb-2">Ou par email</p>
            <a href="mailto:contact@vulcia.fr" class="text-[#7c5cfc] hover:text-white transition-colors text-sm">contact@vulcia.fr</a>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="glass rounded-2xl p-8">
          <h2 class="text-xl font-bold text-white mb-6">Demander mon audit gratuit</h2>

          <!-- Success state (hidden by default) -->
          <div id="form-success" class="hidden text-center py-10">
            <div class="text-4xl mb-4">✓</div>
            <h3 class="text-white font-black text-xl mb-2">Message envoyé !</h3>
            <p class="text-[#8888aa] text-sm">On revient vers vous sous 24h avec un plan d'action concret.</p>
          </div>

          <form id="contact-form" class="space-y-5" novalidate>
            <!-- Honeypot anti-spam -->
            <input type="text" name="_hp" style="display:none" tabindex="-1" autocomplete="off" />

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Prénom</label>
                <input
                  type="text"
                  name="prenom"
                  required
                  class="w-full px-4 py-3 rounded-xl text-white text-sm outline-none transition-all"
                  style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                  placeholder="Jean"
                />
              </div>
              <div>
                <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Nom</label>
                <input
                  type="text"
                  name="nom"
                  required
                  class="w-full px-4 py-3 rounded-xl text-white text-sm outline-none transition-all"
                  style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                  placeholder="Dupont"
                />
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Email professionnel</label>
              <input
                type="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-xl text-white text-sm outline-none transition-all"
                style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                placeholder="jean@entreprise.fr"
              />
            </div>

            <div>
              <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Site web (facultatif)</label>
              <input
                type="url"
                name="site"
                class="w-full px-4 py-3 rounded-xl text-white text-sm outline-none transition-all"
                style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                placeholder="https://votresite.fr"
              />
            </div>

            <div>
              <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Secteur d'activité</label>
              <select
                name="secteur"
                class="w-full px-4 py-3 rounded-xl text-[#8888aa] text-sm outline-none transition-all"
                style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
              >
                <option value="">Choisir...</option>
                <option>E-commerce / Retail</option>
                <option>Professions libérales / Santé</option>
                <option>Immobilier</option>
                <option>Juridique / Comptabilité</option>
                <option>B2B / SaaS</option>
                <option>Restauration / Hôtellerie</option>
                <option>Artisan / PME</option>
                <option>Autre</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Votre objectif principal</label>
              <textarea
                name="objectif"
                rows="3"
                class="w-full px-4 py-3 rounded-xl text-white text-sm outline-none transition-all resize-none"
                style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                placeholder="Ex: Je veux automatiser ma prise de RDV, améliorer mon SEO, créer un site qui convertit mieux..."
              ></textarea>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Budget mensuel</label>
                <select
                  name="budget"
                  class="w-full px-4 py-3 rounded-xl text-[#8888aa] text-sm outline-none transition-all"
                  style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                >
                  <option value="">Choisir...</option>
                  <option>Moins de 300 €/mois</option>
                  <option>300 — 800 €/mois</option>
                  <option>800 — 1 500 €/mois</option>
                  <option>Plus de 1 500 €/mois</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Délai souhaité</label>
                <select
                  name="delai"
                  class="w-full px-4 py-3 rounded-xl text-[#8888aa] text-sm outline-none transition-all"
                  style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                >
                  <option value="">Choisir...</option>
                  <option>Le plus tôt possible</option>
                  <option>Dans le mois</option>
                  <option>Dans les 3 mois</option>
                  <option>Je me renseigne</option>
                </select>
              </div>
            </div>

            <div id="form-error" class="hidden rounded-xl px-4 py-3 text-sm text-red-400" style="background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.2);">
              Une erreur s'est produite. Réessayez ou écrivez à <a href="mailto:contact@vulcia.fr" class="underline">contact@vulcia.fr</a>.
            </div>

            <button
              id="submit-btn"
              type="submit"
              class="w-full py-4 rounded-xl text-white font-bold text-base transition-all duration-200 hover:opacity-90 hover:scale-[1.01]"
              style="background: linear-gradient(135deg, #7c5cfc, #5b3fdb); box-shadow: 0 0 30px rgba(124,92,252,0.3);"
            >
              Envoyer ma demande d'audit &rarr;
            </button>

            <p class="text-center text-xs text-[#8888aa]">
              Réponse sous 24h. Aucun engagement, aucun spam.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
const form    = document.getElementById('contact-form') as HTMLFormElement;
const success = document.getElementById('form-success') as HTMLElement;
const error   = document.getElementById('form-error') as HTMLElement;
const btn     = document.getElementById('submit-btn') as HTMLButtonElement;

form?.addEventListener('submit', async (e) => {
  e.preventDefault();

  btn.disabled = true;
  btn.textContent = 'Envoi en cours…';
  error.classList.add('hidden');

  const data = new FormData(form);

  try {
    const res = await fetch('/api/contact.php', {
      method: 'POST',
      body: data,
    });

    const json = await res.json();

    if (json.ok) {
      form.classList.add('hidden');
      success.classList.remove('hidden');
    } else {
      throw new Error(json.error ?? 'error');
    }
  } catch {
    error.classList.remove('hidden');
    btn.disabled = false;
    btn.textContent = 'Envoyer ma demande d\'audit →';
  }
});
</script>
