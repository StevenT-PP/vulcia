---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact & Audit IA Gratuit | IAForge"
  description="Reservez votre audit IA gratuit de 30 minutes. On identifie vos gains de temps et d'argent, sans engagement. IAForge, agence IA France."
>
  <Nav />

  <section class="min-h-screen pt-32 pb-24 px-6">
    <div class="max-w-6xl mx-auto">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">

        <!-- Left: Info -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-[#7c5cfc] mb-4">Audit gratuit</p>
          <h1 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Parlez-nous de<br/><span class="gradient-text">votre projet</span>
          </h1>
          <p class="text-[#8888aa] leading-relaxed mb-10">
            En 30 minutes, on analyse votre situation et on vous propose un plan d'action concret avec un ROI estime. Aucun engagement, aucune pression commerciale.
          </p>

          <div class="space-y-6">
            {[
              { icon: '⚡', title: 'Reponse en moins de 24h', desc: 'On prend le temps de comprendre votre besoin avant de vous rappeler.' },
              { icon: '🎯', title: 'Audit personalise', desc: 'Pas de presentation generique. On analyse votre site, vos processus, votre marche.' },
              { icon: '📊', title: 'ROI chiffre', desc: 'On vous sort un potentiel de gain concret avant de signer quoi que ce soit.' },
            ].map(item => (
              <div class="flex items-start gap-4">
                <div class="text-2xl">{item.icon}</div>
                <div>
                  <h3 class="text-white font-semibold text-sm mb-1">{item.title}</h3>
                  <p class="text-[#8888aa] text-sm">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-10 glass rounded-2xl p-6">
            <p class="text-white font-semibold text-sm mb-2">Ou par email</p>
            <a href="mailto:contact@iaforge.fr" class="text-[#7c5cfc] hover:text-white transition-colors text-sm">contact@iaforge.fr</a>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="glass rounded-2xl p-8">
          <h2 class="text-xl font-bold text-white mb-6">Demander mon audit gratuit</h2>

          <form
            action="https://formspree.io/f/mojodjon"
            method="POST"
            class="space-y-5"
          >
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Prenom</label>
                <input
                  type="text"
                  name="prenom"
                  required
                  class="w-full px-4 py-3 rounded-xl text-white text-sm outline-none focus:ring-1 transition-all"
                  style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                  placeholder="Jean"
                />
              </div>
              <div>
                <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Nom</label>
                <input
                  type="text"
                  name="nom"
                  required
                  class="w-full px-4 py-3 rounded-xl text-white text-sm outline-none focus:ring-1 transition-all"
                  style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                  placeholder="Dupont"
                />
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Email professionnel</label>
              <input
                type="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-xl text-white text-sm outline-none focus:ring-1 transition-all"
                style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                placeholder="jean@entreprise.fr"
              />
            </div>

            <div>
              <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Site web (facultatif)</label>
              <input
                type="url"
                name="site"
                class="w-full px-4 py-3 rounded-xl text-white text-sm outline-none focus:ring-1 transition-all"
                style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                placeholder="https://votresite.fr"
              />
            </div>

            <div>
              <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Secteur d'activite</label>
              <select
                name="secteur"
                class="w-full px-4 py-3 rounded-xl text-[#8888aa] text-sm outline-none focus:ring-1 transition-all"
                style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
              >
                <option value="">Choisir...</option>
                <option>E-commerce / Retail</option>
                <option>Professions liberales / Sante</option>
                <option>Immobilier</option>
                <option>Juridique / Comptabilite</option>
                <option>B2B / SaaS</option>
                <option>Restauration / Hotellerie</option>
                <option>Artisan / PME</option>
                <option>Autre</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-semibold text-[#8888aa] uppercase tracking-wider mb-2">Votre objectif principal</label>
              <textarea
                name="objectif"
                rows="3"
                class="w-full px-4 py-3 rounded-xl text-white text-sm outline-none focus:ring-1 transition-all resize-none"
                style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"
                placeholder="Ex: Je veux automatiser ma prise de RDV, ameliorer mon SEO, creer un site qui convertit mieux..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full py-4 rounded-xl text-white font-bold text-base transition-all duration-200 hover:opacity-90 hover:scale-[1.01]"
              style="background: linear-gradient(135deg, #7c5cfc, #5b3fdb); box-shadow: 0 0 30px rgba(124,92,252,0.3);"
            >
              Envoyer ma demande d'audit &rarr;
            </button>

            <p class="text-center text-xs text-[#8888aa]">
              Reponse sous 24h. Aucun engagement, aucun spam.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
