---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const tiers = [
  {
    id: 'solo',
    name: 'Solo',
    price: 149,
    pitch: 'Votre site répond pour vous — 24h/24',
    target: 'Artisans, indépendants, petits commerces avec site existant',
    color: '#38bdf8',
    badge: null,
    features: [
      '1 agent IA configuré pour votre secteur et vos processus',
      'Réponses automatiques : questions, RDV, devis, qualification',
      "Jusqu'à 500 conversations/mois incluses",
      'Personnalisation complète : vocabulaire, ton, processus',
      'Tableau de bord — toutes vos conversations en un coup d\'œil',
      'Rapport mensuel des leads générés',
      'Installation sur votre site existant en 7 jours',
      'Support par email sous 48h',
    ],
    not_included: ['Nouveau site web', 'Articles SEO', 'Google Business'],
    sector_examples: [
      { sector: 'Médecin', use: 'Agenda de RDV configuré à vos créneaux' },
      { sector: 'Restaurant', use: 'Réservations de table automatiques' },
      { sector: 'Artisan', use: 'Formulaire de devis intelligent' },
      { sector: 'Coach', use: 'Qualification et inscription aux formations' },
    ],
  },
  {
    id: 'essentiel',
    name: 'Essentiel',
    price: 349,
    pitch: 'Site + IA + Google — visible et disponible dès le 1er jour',
    target: 'TPE, créateurs, professions libérales qui partent de zéro',
    color: '#7c5cfc',
    badge: null,
    features: [
      'Nouveau site web 6 pages (ultrarapide, design sur-mesure)',
      '2 agents IA configurés (ex : chatbot + prise de RDV)',
      'Fiche Google Business complète et optimisée',
      '3 articles de blog SEO optimisés par mois',
      'Rapport mensuel : positions Google, trafic, leads',
      '0€ de frais d\'installation',
      'Support email sous 48h',
    ],
    not_included: ['Google Business posts auto', 'Dashboard avancé', 'Audit concurrent.'],
    sector_examples: [
      { sector: 'Kiné / Psy', use: 'Site + agent de RDV + article santé/mois' },
      { sector: 'Plombier', use: 'Site + agent devis urgence + article conseil/mois' },
      { sector: 'Boutique', use: 'Site + agent stock/questions + article produit/mois' },
      { sector: 'Avocat', use: 'Site + agent qualification dossiers + article juridique/mois' },
    ],
  },
  {
    id: 'croissance',
    name: 'Croissance',
    price: 790,
    pitch: 'La solution complète pour dominer votre marché',
    target: 'PME, e-commerce, agences, B2B établis',
    color: '#7c5cfc',
    badge: 'Notre recommandation',
    features: [
      'Site complet multi-pages + blog + landing pages',
      '3 agents IA spécialisés (librement configurables)',
      '8 articles SEO optimisés par mois',
      'Google Business + 3 publications automatiques/semaine',
      'Tableau de bord de supervision IA complet',
      'Rapport ROI mensuel + audit concurrentiel',
      'Intégration avec votre agenda, email ou CRM simple',
      'Support prioritaire sous 24h ouvrées',
      '0€ de frais d\'installation',
    ],
    not_included: [],
    sector_examples: [
      { sector: 'Cabinet dentaire', use: 'Site + agent RDV + agent FAQ + 8 articles SEO santé' },
      { sector: 'Agence immo', use: 'Site + agent qualification + agent visites + 8 articles marché' },
      { sector: 'E-commerce', use: 'Site + agent support + agent relance paniers + 8 fiches produit SEO' },
      { sector: 'Cabinet compta.', use: 'Site + agent dossiers + agent collecte pièces + 8 articles fiscaux' },
    ],
  },
  {
    id: 'pro',
    name: 'Pro',
    price: 1490,
    pitch: 'Pour les entreprises qui veulent la position de leader',
    target: 'ETI, multi-sites, franchises, grands comptes',
    color: '#a78bfa',
    badge: null,
    features: [
      'Site ultra-personnalisé + espace client ou extranet',
      '5 agents IA sur-mesure (configurable sans limite)',
      '15 articles SEO/mois — stratégie nationale et locale',
      'Intégrations avancées : CRM, ERP, logiciels métier',
      'Formation de vos équipes (2 sessions/an incluses)',
      'Account manager dédié à votre compte',
      'SLA garanti sous 8h ouvrées',
      'Reporting exécutif en temps réel',
      '0€ de frais d\'installation',
    ],
    not_included: [],
    sector_examples: [
      { sector: 'Réseau de franchises', use: 'Agents mutualisés + reporting par enseigne' },
      { sector: 'Cabinet RH', use: 'Agent tri CV + agent onboarding + contenu marque employeur' },
      { sector: 'Groupe médical', use: 'Multi-agents par spécialité + portail patient' },
      { sector: 'ETI B2B', use: 'Agent prospection + CRM + contenu thought leadership' },
    ],
  },
];
---

<Layout
  title="Offres & Tarifs | Vulcia — Agent IA dès 149€/mois, sans engagement"
  description="Tarifs transparents dès 149€/mois. 0€ de frais d'installation. Garantie résultat 90 jours. Sans engagement. Agent IA configuré pour votre métier en 7 jours."
>
  <script type="application/ld+json" slot="head">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Puis-je passer d'un pack à l'autre ?",
        "acceptedAnswer": { "@type": "Answer", "text": "Oui, à tout moment et sans frais. Vous passez au pack supérieur quand vous voulez — facturation au prorata. Vous downgrade si besoin — aucune pénalité." }
      },
      {
        "@type": "Question",
        "name": "Comment s'installe l'agent IA sur mon site existant ?",
        "acceptedAnswer": { "@type": "Answer", "text": "On intègre votre assistant via un simple code à copier-coller dans votre site, compatible avec WordPress, Wix, Squarespace, Webflow, Shopify ou tout site codé sur-mesure. Configuration et mise en ligne en moins de 7 jours." }
      },
      {
        "@type": "Question",
        "name": "L'agent IA est-il vraiment configuré pour mon secteur, ou c'est générique ?",
        "acceptedAnswer": { "@type": "Answer", "text": "Il est configuré spécifiquement pour votre activité. On passe du temps à comprendre vos processus, votre vocabulaire, vos questions fréquentes, vos horaires, vos tarifs. L'agent répond comme si c'était vous — pas comme un robot générique." }
      },
      {
        "@type": "Question",
        "name": "Combien de temps avant de voir des résultats SEO ?",
        "acceptedAnswer": { "@type": "Answer", "text": "Votre agent IA est opérationnel dès la 1ère semaine. Pour le SEO Google, les effets commencent à se faire sentir entre 6 et 12 semaines selon votre secteur et vos mots-clés. Les articles sont publiés dès le premier mois." }
      },
      {
        "@type": "Question",
        "name": "Que couvre exactement la garantie résultat 90 jours ?",
        "acceptedAnswer": { "@type": "Answer", "text": "Avant de démarrer, on définit ensemble des indicateurs de succès clairs (ex : +X leads/mois, page 1 Google sur Y mots-clés, X heures récupérées). Si ces objectifs ne sont pas atteints à 90 jours, on continue de travailler gratuitement jusqu'à ce qu'ils le soient." }
      },
      {
        "@type": "Question",
        "name": "Mes données sont-elles sécurisées et hébergées en France ?",
        "acceptedAnswer": { "@type": "Answer", "text": "Vos données vous appartiennent entièrement. Pour les secteurs sensibles (santé, juridique, RH, comptabilité), on utilise Mistral AI — hébergé à Paris — pour garantir que vos données ne quittent pas le territoire européen et respectent le RGPD." }
      },
      {
        "@type": "Question",
        "name": "Comment fonctionne le financement BPI France ?",
        "acceptedAnswer": { "@type": "Answer", "text": "Le dispositif Diag IA de BPI France permet aux PME de moins de 250 salariés de faire financer jusqu'à 50% d'un diagnostic numérique. Notre audit à 590€ HT est éligible : votre coût réel peut descendre à 295€." }
      }
    ]
  })}</script>
  <Nav />

  <section class="pt-32 pb-24 px-6">
    <div class="max-w-7xl mx-auto">

      <!-- ═══ EN-TÊTE ═══ -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-6">
          <span class="w-2 h-2 rounded-full bg-[#34d399] animate-pulse"></span>
          <span class="text-xs text-[#8888aa] font-medium">Audit gratuit offert · Réponse sous 24h</span>
        </div>

        <h1 class="text-5xl md:text-6xl font-black text-white mb-6 leading-tight">
          Des offres simples,<br/>des résultats concrets.<br/><span class="gradient-text">Sans surprise.</span>
        </h1>
        <p class="text-[#8888aa] max-w-2xl mx-auto text-lg mb-8">
          Tarifs affichés dès 149€/mois, sans frais d'installation ni engagement de durée. Chaque pack inclut un agent IA configuré spécifiquement pour votre métier — pas un chatbot générique copié-collé.
        </p>

        <!-- Badges garanties -->
        <div class="flex flex-wrap justify-center gap-3">
          {[
            { icon: '🛡️', text: 'Résultat garanti 90 jours' },
            { icon: '💳', text: '0€ de frais d\'installation' },
            { icon: '🔓', text: 'Sans engagement de durée' },
            { icon: '🇫🇷', text: 'Équipe française, données France' },
          ].map(b => (
            <div class="flex items-center gap-2 px-4 py-2 rounded-full glass text-sm font-semibold text-white">
              <span>{b.icon}</span> {b.text}
            </div>
          ))}
        </div>
      </div>

      <!-- ═══ NOS ENGAGEMENTS ═══ -->
      <div class="glass rounded-2xl p-6 md:p-8 mb-6">
        <p class="text-center text-xs font-semibold text-[#8888aa] uppercase tracking-widest mb-8">Ce qu'on vous promet dès le départ</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
          {[
            { icon: '💳', title: '0€ de frais d\'installation', desc: 'Pas de frais cachés au démarrage. Le prix affiché est le prix réel, point.' },
            { icon: '🔓', title: 'Sans engagement de durée', desc: 'Vous résiliez quand vous voulez, sans pénalité et sans avoir à vous justifier.' },
            { icon: '⚡', title: 'En ligne en 3 semaines', desc: 'Votre agent IA configuré et votre site mis en ligne rapidement — pas en 3 mois.' },
            { icon: '🛡️', title: 'Résultat garanti 90 jours', desc: 'Si les objectifs définis ensemble ne sont pas atteints, on continue gratuitement.' },
          ].map(e => (
            <div class="text-center p-2">
              <div class="text-3xl mb-3">{e.icon}</div>
              <div class="text-white font-bold text-sm mb-2">{e.title}</div>
              <div class="text-[#8888aa] text-xs leading-relaxed">{e.desc}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- ═══ BPI FINANCING ═══ -->
      <div class="rounded-xl p-5 mb-14 flex flex-col sm:flex-row items-center gap-4" style="background: rgba(251,191,36,0.06); border: 1px solid rgba(251,191,36,0.25);">
        <div class="text-3xl">💡</div>
        <div class="flex-1">
          <p class="text-white font-bold text-sm mb-1">Jusqu'à 50% de financement via BPI France — pour toute PME de moins de 250 salariés</p>
          <p class="text-[#8888aa] text-xs">Le diagnostic IA est éligible au dispositif Diag IA de BPI France. Sur présentation, votre audit (590€) peut être pris en charge à 50% — soit 295€ net. Nous vous accompagnons dans les démarches.</p>
        </div>
        <a href="/contact" class="text-[#fbbf24] text-xs font-bold hover:text-white transition-colors whitespace-nowrap">En savoir plus →</a>
      </div>

      <!-- ═══ GRILLE TARIFAIRE ═══ -->
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-5 mb-10">
        {tiers.map(tier => (
          <div
            class:list={['rounded-3xl p-7 flex flex-col relative', tier.badge ? 'featured-card' : 'glass']}
            style={tier.badge ? `background: linear-gradient(145deg, rgba(124,92,252,0.14), rgba(56,189,248,0.06)); border: 2px solid rgba(124,92,252,0.5); box-shadow: 0 0 80px rgba(124,92,252,0.12);` : ''}
          >
            {tier.badge && (
              <div class="absolute -top-4 left-4 right-4 text-center">
                <span class="inline-block px-4 py-1.5 rounded-full text-[11px] font-black text-white whitespace-nowrap" style="background: linear-gradient(135deg, #7c5cfc, #38bdf8);">{tier.badge}</span>
              </div>
            )}

            <div class="mb-5">
              <p class="text-xs font-bold uppercase tracking-widest mb-2" style={`color: ${tier.color};`}>{tier.name}</p>
              <div class="flex items-baseline gap-1 mb-1">
                <span class="text-4xl font-black text-white">{tier.price}€</span>
                <span class="text-[#8888aa] text-sm">/mois</span>
              </div>
              <p class="text-xs text-[#34d399] font-semibold mb-3">0€ de frais d'installation</p>
              <p class="text-xs text-[#8888aa] leading-relaxed">{tier.target}</p>
            </div>

            <div class="h-px mb-5" style={tier.badge ? 'background: rgba(124,92,252,0.3);' : 'background: var(--border);'}></div>

            <p class="text-white font-semibold text-sm mb-4">{tier.pitch}</p>

            <ul class="space-y-2.5 mb-5 flex-1">
              {tier.features.map(f => (
                <li class="flex items-start gap-2.5 text-xs" style={`color: ${tier.badge ? 'white' : '#9090b0'};`}>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke={tier.color} stroke-width="2.5" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {f}
                </li>
              ))}
              {tier.not_included.length > 0 && tier.not_included.map(f => (
                <li class="flex items-start gap-2.5 text-xs text-[#8888aa]/50">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="rgba(136,136,170,0.4)" stroke-width="2" class="flex-shrink-0 mt-0.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
                  {f}
                </li>
              ))}
            </ul>

            <div class="mt-auto">
              <a
                href="/contact"
                class="block text-center py-3.5 rounded-xl text-sm font-bold transition-all"
                style={tier.badge
                  ? 'background: linear-gradient(135deg, #7c5cfc, #5b3fdb); color: white;'
                  : 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: white;'}
              >
                {tier.badge ? 'Démarrer maintenant →' : 'Choisir ce pack →'}
              </a>
              <p class="text-center text-[10px] text-[#8888aa] mt-2">Sans engagement · Résiliable par mois</p>
            </div>
          </div>
        ))}
      </div>

      <!-- ═══ PERSONNALISATION PAR SECTEUR ═══ -->
      <div class="glass rounded-2xl p-8 mb-10">
        <div class="text-center mb-8">
          <p class="text-xs font-bold uppercase tracking-widest text-[#7c5cfc] mb-2">Adapté à votre métier</p>
          <h2 class="text-2xl font-black text-white mb-3">Chaque pack est configuré pour votre secteur — sans surcoût</h2>
          <p class="text-[#9090b0] text-sm max-w-xl mx-auto">Pas de chatbot générique copié-collé. On configure l'agent avec votre vocabulaire, vos processus, vos horaires, vos tarifs. En 7 jours, il parle comme vous.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
          {tiers.map(tier => (
            <div class="rounded-xl p-5" style={`background: ${tier.color}08; border: 1px solid ${tier.color}20;`}>
              <p class="font-bold text-sm mb-3" style={`color: ${tier.color};`}>Pack {tier.name} — exemples</p>
              <div class="space-y-2">
                {tier.sector_examples.map(ex => (
                  <div class="flex items-start gap-2">
                    <span class="text-[10px] font-bold px-2 py-0.5 rounded text-white mt-0.5 flex-shrink-0" style={`background: ${tier.color}30;`}>{ex.sector}</span>
                    <span class="text-[11px] text-[#9090b0] leading-relaxed">{ex.use}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 pt-6 border-t border-white/5">
          <p class="text-center text-xs text-[#8888aa] mb-4 font-semibold">Secteurs couverts (liste non exhaustive)</p>
          <div class="flex flex-wrap justify-center gap-2">
            {['Médecin / Dentiste', 'Kiné / Psy', 'Avocat', 'Comptable', 'Notaire', 'Restaurant', 'Hôtel', 'Traiteur', 'Artisan BTP', 'Plombier', 'Électricien', 'E-commerce', 'Immobilier', 'Coach', 'Formateur', 'RH', 'Agence marketing', 'SaaS', 'Pharmacie', 'Vétérinaire', 'Garage auto', 'Fleuriste'].map(s => (
              <span class="px-3 py-1 rounded-full text-[11px] text-[#9090b0] glass">{s}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- ═══ COMPARATIF DES PACKS ═══ -->
      <div class="mb-14 overflow-x-auto">
        <h2 class="text-2xl font-black text-white text-center mb-6">Comparatif détaillé</h2>
        <div class="glass rounded-2xl overflow-hidden">
          <table class="w-full min-w-[700px] text-sm">
            <thead>
              <tr style="background: rgba(255,255,255,0.03);">
                <th class="text-left px-6 py-4 text-[#8888aa] font-semibold w-48">Fonctionnalité</th>
                <th class="px-4 py-4 text-center text-white font-black text-xs">Solo<br/><span class="text-[#38bdf8] font-black">149€</span></th>
                <th class="px-4 py-4 text-center text-white font-black text-xs">Essentiel<br/><span class="text-[#7c5cfc] font-black">349€</span></th>
                <th class="px-4 py-4 text-center text-white font-black text-xs" style="background: rgba(124,92,252,0.06);">Croissance<br/><span class="text-[#7c5cfc] font-black">790€</span></th>
                <th class="px-4 py-4 text-center text-white font-black text-xs">Pro<br/><span class="text-[#a78bfa] font-black">1 490€</span></th>
              </tr>
            </thead>
            <tbody>
              {[
                ['Agents IA inclus', '1', '2', '3', '5+'],
                ['Conversations/mois', '500', '1 000', '5 000', 'Illimité'],
                ['Nouveau site web', '✗', '6 pages', 'Multi-pages + blog', 'Sur-mesure'],
                ['Articles SEO/mois', '✗', '3', '8', '15'],
                ['Google Business', '✗', '✅ Optimisé', '✅ + posts auto', '✅ + stratégie'],
                ['Dashboard supervision', '✗', '✗', '✅', '✅ Temps réel'],
                ['Audit concurrentiel', '✗', '✗', 'Mensuel', 'Continu'],
                ['Intégrations', '✗', '✗', 'Email / Agenda', 'CRM / ERP'],
                ['Formation équipes', '✗', '✗', '✗', '2x/an'],
                ['Account manager', '✗', '✗', '✗', '✅ Dédié'],
                ['Frais installation', '0€', '0€', '0€', '0€'],
                ['Support', '48h email', '48h email', 'Prioritaire 24h', 'SLA < 8h'],
              ].map(row => (
                <tr class="border-t border-white/5 hover:bg-white/[0.01]">
                  <td class="px-6 py-3 text-[#9090b0]">{row[0]}</td>
                  <td class="px-4 py-3 text-center text-[#9090b0]">{row[1]}</td>
                  <td class="px-4 py-3 text-center text-[#9090b0]">{row[2]}</td>
                  <td class="px-4 py-3 text-center text-white font-medium" style="background: rgba(124,92,252,0.04);">{row[3]}</td>
                  <td class="px-4 py-3 text-center text-[#9090b0]">{row[4]}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- ═══ AUDIT ONE-SHOT ═══ -->
      <div class="rounded-2xl p-8 mb-14 flex flex-col md:flex-row items-center justify-between gap-6" style="background: rgba(52,211,153,0.05); border: 1px solid rgba(52,211,153,0.2);">
        <div class="flex items-start gap-5">
          <span class="text-4xl">🔍</span>
          <div>
            <div class="flex items-center gap-3 flex-wrap mb-2">
              <h2 class="text-xl font-black text-white">Audit IA complet</h2>
              <span class="px-3 py-1 rounded-full text-xs font-bold text-[#34d399]" style="background: rgba(52,211,153,0.1); border: 1px solid rgba(52,211,153,0.3);">One-shot sans engagement</span>
              <span class="px-3 py-1 rounded-full text-xs font-bold text-[#fbbf24]" style="background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.3);">BPI : jusqu'à 50% remboursé</span>
            </div>
            <p class="text-[#8888aa] text-sm max-w-xl">
              Une journée d'analyse complète de votre entreprise : processus, visibilité Google, outils, concurrents. Livrable : rapport PDF avec les 5 actions prioritaires, ROI projeté par action, plan à 90 jours. Ideal avant de choisir un pack ou de convaincre votre direction.
            </p>
          </div>
        </div>
        <div class="flex items-center gap-6 flex-shrink-0">
          <div class="text-right">
            <span class="text-3xl font-black text-white">590€</span>
            <p class="text-xs text-[#8888aa]">HT · one-shot</p>
            <p class="text-xs text-[#34d399] font-semibold">→ 295€ net avec BPI</p>
          </div>
          <a href="/contact" class="px-6 py-3 rounded-xl text-white text-sm font-bold transition-all hover:opacity-90 whitespace-nowrap" style="background: linear-gradient(135deg, #34d399, #059669);">
            Réserver l'audit →
          </a>
        </div>
      </div>

      <!-- ═══ GARANTIE ═══ -->
      <div class="relative rounded-2xl p-8 md:p-10 mb-14 text-center overflow-hidden" style="background: rgba(124,92,252,0.06); border: 1px solid rgba(124,92,252,0.25);">
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse at center, rgba(124,92,252,0.08), transparent 70%);"></div>
        <div class="relative">
          <div class="text-5xl mb-4">🛡️</div>
          <h2 class="text-3xl font-black text-white mb-4">Garantie résultat 90 jours</h2>
          <p class="text-[#9090b0] max-w-xl mx-auto mb-6">
            Si votre ROI n'est pas positif à 90 jours, on continue de travailler gratuitement jusqu'à ce qu'il le soit. Pas de remboursement — une promesse de résultat. On est dans le bateau avec vous.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-2xl mx-auto">
            {[
              { icon: '📊', title: 'ROI mesuré', desc: 'On définit ensemble les métriques de succès avant de démarrer' },
              { icon: '🔄', title: 'On continue si besoin', desc: 'Si les objectifs ne sont pas atteints à 90j, on poursuit gratuitement' },
              { icon: '💬', title: 'Communication totale', desc: 'Rapport mensuel + point mensuel obligatoire pour suivre l\'avancement' },
            ].map(g => (
              <div class="glass rounded-xl p-5">
                <div class="text-2xl mb-2">{g.icon}</div>
