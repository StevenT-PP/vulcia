---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Quel type de site web créez-vous ?", "acceptedAnswer": { "@type": "Answer", "text": "Sites vitrines, sites de prise de rendez-vous, portfolios, sites e-commerce et landing pages. Tous sont construits avec des technologies modernes (Astro, performance maximale) et intègrent nativement le SEO et un agent IA si vous le souhaitez." } },
    { "@type": "Question", "name": "Combien de temps pour livrer mon site ?", "acceptedAnswer": { "@type": "Answer", "text": "7 jours pour un site vitrine standard. 2 à 3 semaines pour un site e-commerce ou un projet sur-mesure. Délai compté à partir de la réception de vos contenus (textes, photos, infos)." } },
    { "@type": "Question", "name": "Mon site sera-t-il bien positionné sur Google ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui. Chaque site Vulcia est livré avec le SEO technique inclus : structure de pages optimisée, balises méta, schema JSON-LD, sitemap XML, Core Web Vitals optimaux. Le référencement de contenu (articles, pages secteur) est disponible en option ou dans le Pack Croissance." } },
    { "@type": "Question", "name": "Puis-je modifier mon site moi-même après la livraison ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui. On vous forme sur l'interface de modification ou on intègre un CMS adapté à votre niveau. Pour les modifications complexes, notre équipe intervient dans les 48h." } },
    { "@type": "Question", "name": "Est-ce que l'agent IA peut être intégré à mon site existant ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui, si vous avez déjà un site. L'intégration prend en général 24 à 48h. Si votre site est trop lent ou mal structuré pour le SEO, on vous proposera une refonte — mais ce n'est pas obligatoire." } }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création de site web sur-mesure",
  "provider": { "@type": "Organization", "name": "Vulcia", "url": "https://vulcia.fr" },
  "description": "Création de sites web vitrines, e-commerce et landing pages optimisés SEO pour PME françaises. Livraison en 7 jours, agent IA intégré sur demande.",
  "areaServed": { "@type": "Country", "name": "France" },
  "offers": { "@type": "AggregateOffer", "priceCurrency": "EUR", "lowPrice": "349", "highPrice": "1490", "offerCount": "3", "description": "Abonnement mensuel sans engagement" }
};
---

<Layout
  title="Création site web sur-mesure livré en 7 jours | Vulcia"
  description="Votre site web vitrine, e-commerce ou landing page livré en 7 jours. SEO inclus, agent IA intégré, optimisé pour Google. Dès 349€/mois pour les PME françaises."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />

  <Nav />

  <!-- Hero -->
  <section class="pt-32 pb-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div style="position:absolute;width:700px;height:700px;top:-15%;left:0%;background:radial-gradient(circle,rgba(56,189,248,0.12),transparent 70%);filter:blur(80px);"></div>
      <div style="position:absolute;width:500px;height:500px;bottom:-10%;right:0%;background:radial-gradient(circle,rgba(124,92,252,0.1),transparent 70%);filter:blur(80px);"></div>
    </div>
    <div class="max-w-4xl mx-auto text-center relative">
      <p class="text-xs font-bold uppercase tracking-widest text-[#38bdf8] mb-4">Création site web</p>
      <h1 class="text-5xl md:text-6xl font-black text-white leading-[1.05] mb-6">
        Votre site web livré en 7 jours.<br />
        <span style="background: linear-gradient(135deg, #38bdf8, #7c5cfc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">SEO inclus. Agent IA intégré.</span>
      </h1>
      <p class="text-xl text-[#9090b0] max-w-2xl mx-auto mb-10 leading-relaxed">Un site rapide, beau et optimisé pour Google. Conçu pour convertir vos visiteurs en clients — pas juste pour exister en ligne.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl text-white font-bold text-base transition-all hover:opacity-90" style="background: linear-gradient(135deg, #38bdf8, #7c5cfc); box-shadow: 0 0 40px rgba(56,189,248,0.25);">Obtenir un devis gratuit →</a>
        <a href="/tarifs" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl text-white font-semibold text-base glass hover:bg-white/10 transition-all">Voir les tarifs →</a>
      </div>
    </div>
  </section>

  <!-- Ce qu'on livre -->
  <section class="py-20 px-6" style="background: var(--bg-2);">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#38bdf8] mb-3">Ce qu'on livre</p>
        <h2 class="text-4xl font-black text-white mb-4">Tout ce que votre site doit avoir — et que la plupart n'ont pas</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="glass rounded-2xl p-6">
          <h3 class="font-bold mb-4" style="color: #38bdf8;">Performance maximale</h3>
          <ul class="space-y-2.5">
            {['Score Lighthouse > 95/100', 'Chargement < 1 seconde', 'HTTP/3 + CDN inclus', 'Optimisé Core Web Vitals', 'Images WebP automatiques'].map(f => (
              <li class="flex items-center gap-2.5 text-sm text-[#9090b0]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
        <div class="glass rounded-2xl p-6">
          <h3 class="font-bold mb-4" style="color: #7c5cfc;">SEO technique inclus</h3>
          <ul class="space-y-2.5">
            {['Balises title & meta optimisées', 'Schema JSON-LD structuré', 'Sitemap XML automatique', 'Canonical URLs propres', 'Robots.txt configuré'].map(f => (
              <li class="flex items-center gap-2.5 text-sm text-[#9090b0]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#7c5cfc" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
        <div class="glass rounded-2xl p-6">
          <h3 class="font-bold mb-4" style="color: #34d399;">Prêt à convertir</h3>
          <ul class="space-y-2.5">
            {['Design mobile-first', 'CTA stratégiquement placés', 'Formulaires de contact', 'Intégration Google Analytics', 'Agent IA en option'].map(f => (
              <li class="flex items-center gap-2.5 text-sm text-[#9090b0]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Types de projets -->
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#38bdf8] mb-3">Types de projets</p>
        <h2 class="text-4xl font-black text-white mb-4">Quel site avez-vous besoin ?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { icon: '🏠', name: 'Site vitrine', delay: '7 jours', color: '#38bdf8', desc: 'Votre présence en ligne professionnelle. Présente votre activité, vos services et vos coordonnées de façon claire et convaincante.', ideal: 'Artisans, professions libérales, PME locales' },
          { icon: '🎯', name: 'Landing page', delay: '3 à 5 jours', color: '#7c5cfc', desc: 'Une page unique ultra-optimisée pour convertir. Idéale pour une offre spécifique, une campagne Google Ads ou un lancement.', ideal: 'Campagnes publicitaires, offres promotionnelles' },
          { icon: '🛒', name: 'Site e-commerce', delay: '2 à 3 semaines', color: '#34d399', desc: 'Votre boutique en ligne avec paiement sécurisé, gestion des stocks et fiches produits optimisées pour Google Shopping.', ideal: 'Boutiques, artisans vendant en ligne, créateurs' },
          { icon: '⚙️', name: 'Site sur-mesure', delay: '3 à 6 semaines', color: '#f59e0b', desc: 'Fonctionnalités avancées, intégrations CRM, espace client, réservation en ligne, multi-langues. On code ce dont vous avez besoin.', ideal: 'Cliniques, agences, franchises, multi-sites' },
        ].map(p => (
          <div class="glass rounded-2xl p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-2xl">{p.icon}</span>
              <h3 class="text-white font-black">{p.name}</h3>
              <span class="ml-auto text-xs px-2 py-1 rounded-full font-semibold" style={`background: ${p.color}18; color: ${p.color};`}>{p.delay}</span>
            </div>
            <p class="text-[#9090b0] text-sm leading-relaxed mb-3">{p.desc}</p>
            <p class="text-xs" style={`color: ${p.color};`}>Idéal pour : {p.ideal}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Processus -->
  <section class="py-20 px-6" style="background: var(--bg-2);">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#38bdf8] mb-3">Processus</p>
        <h2 class="text-4xl font-black text-white mb-4">Votre site en 7 jours, étape par étape</h2>
      </div>
      <div class="space-y-4">
        {[
          { n: '01', color: '#38bdf8', title: 'Brief & maquette (Jour 1)', desc: "On discute de votre activité, vos cibles, vos concurrents. On vous soumet une maquette de la page d'accueil sous 24h." },
          { n: '02', color: '#7c5cfc', title: 'Développement (Jour 2-5)', desc: 'On construit toutes les pages, on intègre vos textes et photos, on configure le SEO technique et les formulaires.' },
          { n: '03', color: '#34d399', title: 'Révisions avec vous (Jour 6)', desc: "Vous testez sur tous les appareils. On ajuste couleurs, textes, mise en page jusqu'à ce que vous soyez 100% satisfait." },
          { n: '04', color: '#f59e0b', title: 'Mise en ligne & suivi (Jour 7)', desc: 'Le site est déployé sur votre domaine. On soumet le sitemap à Google. Vous recevez un rapport mensuel de performance.' },
        ].map(s => (
          <div class="glass rounded-xl p-6 flex gap-5 items-start">
            <div class="text-2xl font-black flex-shrink-0" style={`color: ${s.color};`}>{s.n}</div>
            <div>
              <h3 class="text-white font-bold mb-1">{s.title}</h3>
              <p class="text-[#9090b0] text-sm leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-black text-white text-center mb-10">Questions sur la création de site web</h2>
      <div class="space-y-2">
        {[
          { q: 'Quel type de site web créez-vous ?', a: "Sites vitrines, sites de prise de rendez-vous, portfolios, sites e-commerce et landing pages. Tous sont construits avec des technologies modernes (Astro, performance maximale) et intègrent nativement le SEO et un agent IA si vous le souhaitez." },
          { q: 'Combien de temps pour livrer mon site ?', a: "7 jours pour un site vitrine standard. 2 à 3 semaines pour un site e-commerce ou un projet sur-mesure. Délai compté à partir de la réception de vos contenus (textes, photos, infos)." },
          { q: 'Mon site sera-t-il bien positionné sur Google ?', a: "Oui. Chaque site Vulcia est livré avec le SEO technique inclus : structure de pages optimisée, balises méta, schema JSON-LD, sitemap XML, Core Web Vitals optimaux. Le référencement de contenu (articles, pages secteur) est disponible en option ou dans le Pack Croissance." },
          { q: 'Puis-je modifier mon site moi-même après la livraison ?', a: "Oui. On vous forme sur l'interface de modification ou on intègre un CMS adapté à votre niveau. Pour les modifications complexes, notre équipe intervient dans les 48h." },
          { q: "Est-ce que l'agent IA peut être intégré à mon site existant ?", a: "Oui, si vous avez déjà un site. L'intégration prend en général 24 à 48h. Si votre site est trop lent ou mal structuré pour le SEO, on vous proposera une refonte — mais ce n'est pas obligatoire." },
        ].map(item => (
          <details class="glass rounded-xl group">
            <summary class="px-6 py-5 cursor-pointer text-white font-semibold text-sm flex items-center justify-between list-none">
              <span>{item.q}</span>
              <svg class="w-4 h-4 text-[#8888aa] transition-transform duration-300 group-open:rotate-180 flex-shrink-0 ml-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </summary>
            <div class="px-6 pb-5 pt-2">
              <p class="text-[#8888aa] text-sm leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-20 px-6" style="background: var(--bg-2);">
    <div class="max-w-4xl mx-auto">
      <div class="glass rounded-3xl p-12 md:p-16 text-center relative overflow-hidden">
        <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, rgba(56,189,248,0.08), transparent 70%);"></div>
        <div class="relative">
          <h2 class="text-4xl font-black text-white mb-4">Votre site en ligne dans 7 jours</h2>
          <p class="text-[#9090b0] max-w-lg mx-auto mb-8">On discute de votre projet, on vous envoie un devis sous 24h. Gratuit, sans engagement. Si vous aimez la maquette, on démarre.</p>
          <a href="/contact" class="inline-flex items-center gap-2 px-10 py-4 rounded-xl text-white font-bold text-base transition-all hover:opacity-90" style="background: linear-gradient(135deg, #38bdf8, #7c5cfc); box-shadow: 0 0 40px rgba(56,189,248,0.25);">Demander un devis gratuit →</a>
          <p class="text-xs text-[#8888aa] mt-5">Gratuit · Sous 24h · Sans engagement</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  details summary::-webkit-details-marker { display: none; }
  details[open] summary { color: #38bdf8; }
</style>
