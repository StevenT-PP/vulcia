---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const tools = [
  {
    name: "ChatGPT Plus",
    price: "20 $/mois",
    forBusiness: false,
    memory: false,
    integration: false,
    rgpd: false,
    support: false,
    configured: false,
    score: 2,
    color: "#10a37f",
    verdict: "Outil génial pour un usage personnel. Inefficace en production sans configuration poussée.",
  },
  {
    name: "Claude (Anthropic)",
    price: "20 $/mois",
    forBusiness: false,
    memory: false,
    integration: false,
    rgpd: false,
    support: false,
    configured: false,
    score: 2,
    color: "#d97706",
    verdict: "Excellente qualité de rédaction. Même limite : pas configuré pour votre activité.",
  },
  {
    name: "Gemini for Business",
    price: "30 $/mois",
    forBusiness: true,
    memory: false,
    integration: true,
    rgpd: false,
    support: false,
    configured: false,
    score: 3,
    color: "#4285f4",
    verdict: "Intégré à Google Workspace. Reste un outil générique sans mémoire de votre activité.",
  },
  {
    name: "Agent IA Vulcia",
    price: "Dès 149 €/mois",
    forBusiness: true,
    memory: true,
    integration: true,
    rgpd: true,
    support: true,
    configured: true,
    score: 6,
    color: "#7c5cfc",
    verdict: "Configuré pour votre secteur. Connecté à vos outils. Opérationnel en 7 jours.",
    highlight: true,
  },
];

const criteria = [
  { key: "forBusiness", label: "Conçu pour les PME" },
  { key: "memory", label: "Mémorise votre activité" },
  { key: "integration", label: "Connecté à vos outils" },
  { key: "rgpd", label: "Hébergement RGPD France" },
  { key: "support", label: "Support et suivi humain" },
  { key: "configured", label: "Configuré pour votre secteur" },
];

const scenarios = [
  {
    title: "Un client pose une question à 22h",
    generic: "ChatGPT ne sait pas qui vous êtes, n'a pas accès à vos horaires ou tarifs. Le client reçoit une réponse générique inutile ou rien du tout.",
    vulcia: "L'agent connaît vos horaires, vos tarifs et vos FAQ. Il répond en 3 secondes à la question précise, propose un RDV si nécessaire, et note la demande dans votre CRM.",
  },
  {
    title: "Un prospect demande un devis",
    generic: "ChatGPT peut aider à rédiger un modèle de devis générique. Il ne connaît pas vos prix, vos options, vos délais. L'humain doit tout reprendre.",
    vulcia: "L'agent pose les bonnes questions (surface, localisation, urgence pour un artisan), calcule une estimation selon votre grille, et envoie un PDF signable.",
  },
  {
    title: "Données médicales ou juridiques",
    generic: "GPT-4o et Claude stockent les données sur des serveurs américains. Non-conforme RGPD pour les données de santé ou judiciaires.",
    vulcia: "Option Mistral hébergé à Paris : vos données ne quittent pas la France. Conforme RGPD natif pour les secteurs sensibles.",
  },
  {
    title: "Suivi et amélioration",
    generic: "Aucun tableau de bord. Vous ne savez pas ce que l'outil fait, combien de questions il reçoit, où il échoue.",
    vulcia: "Dashboard temps réel : toutes les conversations, taux de résolution, questions sans réponse, leads qualifiés. On améliore en continu sur la base des données.",
  },
];

const faqItems = [
  {
    q: "Un agent IA Vulcia utilise bien ChatGPT ou Claude en dessous ?",
    a: "Oui. Vulcia orchestre GPT-4o, Claude Sonnet ou Mistral selon votre secteur et vos contraintes. La différence : on ajoute la couche de configuration, de mémoire, d'intégration et de supervision qui rend ces modèles utiles pour votre activité spécifique.",
  },
  {
    q: "Pourquoi ne pas utiliser directement ChatGPT Team ou Claude for Work ?",
    a: "Ces offres donnent accès au modèle brut dans une interface. Pour en faire un vrai agent métier, il faut configurer des instructions système précises, connecter des APIs (agenda, CRM, devis), gérer le flux de conversation, et surveiller les performances. C'est exactement ce qu'on fait chez Vulcia.",
  },
  {
    q: "Est-ce que l'agent peut remplacer tous mes outils actuels ?",
    a: "Non, et c'est volontaire. L'agent s'intègre à vos outils existants (Google Calendar, Doctolib, HubSpot, Notion…) plutôt que de les remplacer. Il automatise les interactions clients et alimente vos outils en données — il ne les duplique pas.",
  },
  {
    q: "Combien de temps pour être opérationnel ?",
    a: "7 jours pour le Pack Solo (agent sur votre site existant). 3 semaines pour les packs incluant la refonte du site. Ce délai inclut audit, configuration, tests et mise en ligne.",
  },
  {
    q: "Que se passe-t-il si l'agent fait une erreur ?",
    a: "Toutes les conversations sont enregistrées et consultables. Vous pouvez corriger les réponses incorrectes via le dashboard, et les corrections sont apprises immédiatement. Pour les cas critiques, l'agent escalade automatiquement vers vous.",
  },
];
---

<Layout
  title="Comparatif agents IA 2026 pour PME | Vulcia"
  description="ChatGPT, Claude ou Gemini pour votre PME ? Comparatif objectif des outils IA génériques vs agents configurés sur-mesure. Tableau, scénarios réels, verdict."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />

  <Nav />

  <!-- HERO -->
  <section class="pt-32 pb-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div style="position:absolute;width:700px;height:500px;top:-5%;right:-10%;background:radial-gradient(circle,rgba(124,92,252,0.12),transparent 70%);filter:blur(80px);"></div>
    </div>
    <div class="max-w-4xl mx-auto text-center relative">
      <p class="text-xs font-bold uppercase tracking-widest text-[#7c5cfc] mb-4">Comparatif IA 2026</p>
      <h1 class="text-[clamp(2.2rem,5vw,4rem)] font-black text-white leading-[1.05] mb-6">
        ChatGPT, Claude, Gemini :<br/>
        <span class="gradient-text">pourquoi les PME choisissent<br/>un agent IA sur-mesure</span>
      </h1>
      <p class="text-lg text-[#8888aa] max-w-2xl mx-auto mb-10 leading-relaxed">
        Les outils IA génériques sont puissants. Ils ne sont pas conçus pour répondre à vos clients à 22h, réserver des rendez-vous dans votre agenda, ou collecter des pièces justificatives pour votre dossier. Voici la différence en données réelles.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold text-base transition-all hover:opacity-90 hover:scale-[1.02]" style="background: linear-gradient(135deg, #7c5cfc, #5b3fdb); box-shadow: 0 0 40px rgba(124,92,252,0.3);">
        Voir quel outil est fait pour moi &rarr;
      </a>
    </div>
  </section>

  <!-- TABLEAU COMPARATIF -->
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-black text-white text-center mb-4">Comparatif fonctionnel</h2>
      <p class="text-[#8888aa] text-center mb-12">6 critères clés pour une utilisation en entreprise</p>

      <div class="overflow-x-auto">
        <table class="w-full min-w-[640px]">
          <thead>
            <tr>
              <th class="text-left py-4 pr-4 text-[#8888aa] text-sm font-semibold w-1/4">Critère</th>
              {tools.map(t => (
                <th class="py-4 px-3 text-center">
                  <div class={`text-sm font-black ${t.highlight ? 'text-[#7c5cfc]' : 'text-white'}`}>{t.name}</div>
                  <div class="text-xs text-[#8888aa] mt-1">{t.price}</div>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {criteria.map(c => (
              <tr class="border-t border-white/5">
                <td class="py-4 pr-4 text-[#8888aa] text-sm">{c.label}</td>
                {tools.map(t => (
                  <td class="py-4 px-3 text-center">
                    {(t as any)[c.key]
                      ? <span class="text-green-400 font-bold text-base">✓</span>
                      : <span class="text-[#444466] text-base">✗</span>
                    }
                  </td>
                ))}
              </tr>
            ))}
            <tr class="border-t border-white/10">
              <td class="py-4 pr-4 text-[#8888aa] text-sm font-semibold">Score /6</td>
              {tools.map(t => (
                <td class="py-4 px-3 text-center">
                  <span class="text-lg font-black" style={`color: ${t.color};`}>{t.score}/6</span>
                </td>
              ))}
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Verdicts -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-10">
        {tools.map(t => (
          <div class={`glass rounded-xl p-5 ${t.highlight ? 'ring-1 ring-[#7c5cfc]/50' : ''}`}>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-sm font-black" style={`color: ${t.color};`}>{t.name}</span>
              {t.highlight && <span class="text-xs px-2 py-0.5 rounded-full text-white font-semibold" style="background: rgba(124,92,252,0.3);">Recommandé PME</span>}
            </div>
            <p class="text-[#8888aa] text-sm">{t.verdict}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SCÉNARIOS RÉELS -->
  <section class="py-20 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-black text-white text-center mb-4">4 situations concrètes</h2>
      <p class="text-[#8888aa] text-center mb-12">Ce que chaque approche produit en pratique</p>

      <div class="space-y-6">
        {scenarios.map((s, i) => (
          <div class="glass rounded-2xl p-6">
            <h3 class="text-white font-black text-base mb-5">
              <span class="text-[#7c5cfc] mr-2">0{i + 1}.</span>{s.title}
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="rounded-xl p-4" style="background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.15);">
                <p class="text-xs font-bold text-red-400 uppercase tracking-wider mb-2">Outil générique</p>
                <p class="text-[#8888aa] text-sm leading-relaxed">{s.generic}</p>
              </div>
              <div class="rounded-xl p-4" style="background: rgba(124,92,252,0.06); border: 1px solid rgba(124,92,252,0.2);">
                <p class="text-xs font-bold text-[#7c5cfc] uppercase tracking-wider mb-2">Agent IA Vulcia</p>
                <p class="text-[#8888aa] text-sm leading-relaxed">{s.vulcia}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- POURQUOI SUR-MESURE -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-[#7c5cfc] mb-4">Ce qui fait la différence</p>
          <h2 class="text-3xl font-black text-white mb-6">Un modèle IA, c'est un moteur.<br/>Un agent sur-mesure, c'est une voiture.</h2>
          <p class="text-[#8888aa] leading-relaxed mb-6">
            GPT-4o et Claude sont des moteurs extraordinaires. Mais personne ne conduit un moteur seul. L'agent Vulcia, c'est toute la voiture : carrosserie (interface adaptée à votre site), GPS (votre agenda et vos données), compteur (tableau de bord de supervision) — et nous au volant pour les ajustements.
          </p>
          <a href="/agent-ia" class="text-[#7c5cfc] hover:text-white transition-colors text-sm font-semibold">Voir comment fonctionne un agent IA &rarr;</a>
        </div>
        <div class="space-y-4">
          {[
            { label: "Configuration métier", desc: "Vos horaires, tarifs, FAQ, vocabulaire, règles de gestion — l'agent les connaît parfaitement." },
            { label: "Connexions aux outils", desc: "Google Calendar, Doctolib, HubSpot, WooCommerce — l'agent agit, pas seulement dans son interface." },
            { label: "Mémoire des conversations", desc: "L'agent reconnaît vos clients récurrents et adapte ses réponses à l'historique." },
            { label: "Supervision continue", desc: "Dashboard, alertes, revue mensuelle — vous restez informé et en contrôle." },
          ].map(item => (
            <div class="glass rounded-xl p-4 flex items-start gap-3">
              <div class="w-2 h-2 rounded-full bg-[#7c5cfc] mt-2 flex-shrink-0"></div>
              <div>
                <p class="text-white font-semibold text-sm mb-1">{item.label}</p>
                <p class="text-[#8888aa] text-xs">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-6" style="background: var(--bg-2, #0d0d1a);">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-black text-white text-center mb-12">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqItems.map(f => (
          <details class="glass rounded-xl group">
            <summary class="p-5 cursor-pointer flex items-center justify-between text-white font-semibold text-sm list-none">
              {f.q}
              <span class="text-[#7c5cfc] ml-4 flex-shrink-0 transition-transform group-open:rotate-45 text-lg">+</span>
            </summary>
            <p class="px-5 pb-5 text-[#8888aa] text-sm leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-black text-white mb-4">Quel outil est adapté à votre situation ?</h2>
      <p class="text-[#8888aa] mb-8">En 30 minutes d'audit gratuit, on identifie si un agent sur-mesure vous apporte un ROI réel — ou si un outil générique suffit. Réponse honnête garantie.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-white font-bold text-base transition-all hover:opacity-90 hover:scale-[1.02]" style="background: linear-gradient(135deg, #7c5cfc, #5b3fdb); box-shadow: 0 0 40px rgba(124,92,252,0.3);">
        Audit gratuit — réponse sous 24h &rarr;
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  details summary::-webkit-details-marker { display: none; }
</style>
